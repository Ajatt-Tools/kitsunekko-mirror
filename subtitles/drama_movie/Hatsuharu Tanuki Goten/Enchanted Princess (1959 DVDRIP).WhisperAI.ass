Dialogue: 0,0:02:31.73,0:02:34.13,Default,,0,0,0,,店はもう閉めたでよ
Dialogue: 0,0:02:34.49,0:02:36.62,Default,,0,0,0,,明日のことにしてくんろ
Dialogue: 0,0:02:36.97,0:02:39.89,Default,,0,0,0,,よそりゃ腰が痛むでな
Dialogue: 0,0:02:42.14,0:02:46.15,Default,,0,0,0,,どづくで寝やけばぶっ壊れんじゃねえかい
Dialogue: 0,0:02:46.15,0:02:47.91,Default,,0,0,0,,しわけのめあん
Dialogue: 0,0:02:50.15,0:02:53.16,Default,,0,0,0,,夢中の野郎だな
Dialogue: 0,0:03:03.80,0:03:06.54,Default,,0,0,0,,のろくでなし野郎め
Dialogue: 0,0:03:06.54,0:03:08.01,Default,,0,0,0,,よそりゃな
Dialogue: 0,0:03:08.01,0:03:11.68,Default,,0,0,0,,山が早ねに決まってるだ
Dialogue: 0,0:03:11.68,0:03:13.52,Default,,0,0,0,,このごくど野郎め
Dialogue: 0,0:03:13.94,0:03:15.80,Default,,0,0,0,,何て野郎だろ
Dialogue: 0,0:03:19.62,0:03:22.53,Default,,0,0,0,,あのー お酒をこれに
Dialogue: 0,0:03:23.40,0:03:24.66,Default,,0,0,0,,すいません
Dialogue: 0,0:03:26.47,0:03:30.10,Default,,0,0,0,,見かけにねーとんだが
Dialogue: 0,0:03:30.10,0:03:32.38,Default,,0,0,0,,おとっちゃんの根酒かな
Dialogue: 0,0:03:32.38,0:03:33.14,Default,,0,0,0,,はい
Dialogue: 0,0:03:33.14,0:03:34.89,Default,,0,0,0,,あーそうか
Dialogue: 0,0:03:35.02,0:03:39.04,Default,,0,0,0,,竹の道やったこれが切るとうるさくてな
Dialogue: 0,0:03:40.34,0:03:43.75,Default,,0,0,0,,でお前は一人で来たのか
Dialogue: 0,0:03:43.75,0:03:44.60,Default,,0,0,0,,はい
Dialogue: 0,0:03:44.60,0:03:50.39,Default,,0,0,0,,ようきた関心だ
Dialogue: 0,0:03:50.39,0:03:55.23,Default,,0,0,0,,月夜でもこの夜道をお前ここまでな
Dialogue: 0,0:03:55.39,0:03:56.78,Default,,0,0,0,,関心な子だ
Dialogue: 0,0:03:57.24,0:04:00.01,Default,,0,0,0,,よしよしそのカーリンジャー
Dialogue: 0,0:04:00.15,0:04:03.47,Default,,0,0,0,,まつめはおまけにしておくだりな
Dialogue: 0,0:04:04.22,0:04:06.95,Default,,0,0,0,,おらの味だけだがな
Dialogue: 0,0:04:06.95,0:04:09.85,Default,,0,0,0,,あじゃあ自慢の乗物だ
Dialogue: 0,0:04:09.90,0:04:13.08,Default,,0,0,0,,とくるでな いいたりだ
Dialogue: 0,0:04:13.08,0:04:15.41,Default,,0,0,0,,とくるでな いいたりだ
Dialogue: 0,0:04:16.57,0:04:17.64,Default,,0,0,0,,いません
Dialogue: 0,0:04:17.64,0:04:20.53,Default,,0,0,0,,あのお金はこれだけありますから
Dialogue: 0,0:04:20.53,0:04:23.54,Default,,0,0,0,,いいともいいとこれでいいだ
Dialogue: 0,0:04:23.54,0:04:25.37,Default,,0,0,0,,すいません
Dialogue: 0,0:04:29.66,0:04:33.32,Default,,0,0,0,,ああかけてたよ
Dialogue: 0,0:04:33.90,0:04:37.20,Default,,0,0,0,,気をつけて行きなよ 気をつけてな
Dialogue: 0,0:04:37.20,0:04:41.58,Default,,0,0,0,,近頃村外れに悪い狸が出るそうだで
Dialogue: 0,0:04:41.58,0:04:47.98,Default,,0,0,0,,見かけねえ娘だがなかなか
Dialogue: 0,0:04:47.98,0:04:50.70,Default,,0,0,0,,ん?あれ?うん
Dialogue: 0,0:04:51.11,0:04:52.50,Default,,0,0,0,,木の葉じゃねえか?
Dialogue: 0,0:04:52.64,0:04:56.54,Default,,0,0,0,,銭（ぜに）がねえぞ
Dialogue: 0,0:04:56.92,0:04:59.54,Default,,0,0,0,,銭が木の葉に
Dialogue: 0,0:04:59.54,0:05:03.27,Default,,0,0,0,,あ、そうか、今が狸か
Dialogue: 0,0:05:03.89,0:05:06.90,Default,,0,0,0,,あ、やあ お黒
Dialogue: 0,0:05:23.00,0:05:29.29,Default,,0,0,0,,森の細道
Dialogue: 0,0:05:29.29,0:05:34.12,Default,,0,0,0,,日が暮れる
Dialogue: 0,0:05:35.02,0:05:40.69,Default,,0,0,0,,あの子は里を
Dialogue: 0,0:05:40.69,0:05:45.57,Default,,0,0,0,,去る春に
Dialogue: 0,0:05:47.00,0:05:51.84,Default,,0,0,0,,小遣いのお金で
Dialogue: 0,0:05:51.84,0:05:56.99,Default,,0,0,0,,酒買いに
Dialogue: 0,0:05:57.87,0:06:02.69,Default,,0,0,0,,行かけば おとおに 行かられる
Dialogue: 0,0:06:02.90,0:06:10.91,Default,,0,0,0,,行かられる
Dialogue: 0,0:06:22.40,0:06:24.40,Default,,0,0,0,,お父ちゃん、遅くなりまして
Dialogue: 0,0:06:25.05,0:06:26.23,Default,,0,0,0,,じゃ、お黒
Dialogue: 0,0:06:26.62,0:06:28.97,Default,,0,0,0,,何をグズグズしてやったんだよ
Dialogue: 0,0:06:29.50,0:06:31.80,Default,,0,0,0,,そんなこと言ったって
Dialogue: 0,0:06:31.80,0:06:33.80,Default,,0,0,0,,うるせえ 酒こっちだぜ
Dialogue: 0,0:06:33.80,0:06:34.60,Default,,0,0,0,,はい
Dialogue: 0,0:06:34.60,0:06:37.80,Default,,0,0,0,,おっ タップル言ってやるな
Dialogue: 0,0:06:37.80,0:06:41.50,Default,,0,0,0,,おい 責めきょうは 嫌にバケっぽいんじゃないか
Dialogue: 0,0:06:41.50,0:06:43.20,Default,,0,0,0,,私 気量が悪いから
Dialogue: 0,0:06:43.20,0:06:46.10,Default,,0,0,0,,それくらいの娘に バケらえりゃ 結構だ
Dialogue: 0,0:06:46.10,0:06:48.00,Default,,0,0,0,,それはお父さんの子ですもん
Dialogue: 0,0:06:48.00,0:06:52.04,Default,,0,0,0,,ヘイ 踊ってるねえ
Dialogue: 0,0:06:52.04,0:06:53.40,Default,,0,0,0,,ヘヘヘヘ
Dialogue: 0,0:06:53.40,0:06:56.52,Default,,0,0,0,,これでも若い自分はよ
Dialogue: 0,0:06:56.52,0:06:58.48,Default,,0,0,0,,お父さん そんなに飲んだら毒だわよ
Dialogue: 0,0:06:58.48,0:06:59.76,Default,,0,0,0,,やがて
Dialogue: 0,0:06:59.76,0:07:02.84,Default,,0,0,0,,このガチガチ山の泥の様は
Dialogue: 0,0:07:02.84,0:07:05.68,Default,,0,0,0,,一生は二生の酒で御様る気
Dialogue: 0,0:07:05.68,0:07:06.80,Default,,0,0,0,,まあ
Dialogue: 0,0:07:06.80,0:07:09.48,Default,,0,0,0,,私の苦労も知らない
Dialogue: 0,0:07:09.48,0:07:13.00,Default,,0,0,0,,なんでなんでそのメスメスしやって
Dialogue: 0,0:07:13.00,0:07:14.28,Default,,0,0,0,,ああ
Dialogue: 0,0:07:14.28,0:07:15.96,Default,,0,0,0,,そうか
Dialogue: 0,0:07:15.96,0:07:18.84,Default,,0,0,0,,そうやって目もそろそろ年頃だし
Dialogue: 0,0:07:18.84,0:07:20.80,Default,,0,0,0,,あら嫌なとっちゃん
Dialogue: 0,0:07:20.80,0:07:23.96,Default,,0,0,0,,じゃあそれだけ飲んだら飲めましょうね
Dialogue: 0,0:07:23.96,0:07:25.36,Default,,0,0,0,,言ってことよ
Dialogue: 0,0:07:25.36,0:07:27.76,Default,,0,0,0,,お黒 魚として
Dialogue: 0,0:07:27.76,0:07:30.24,Default,,0,0,0,,そこの？
Dialogue: 0,0:07:30.24,0:07:31.88,Default,,0,0,0,,そんなものありません
Dialogue: 0,0:07:31.88,0:07:33.19,Default,,0,0,0,,何ねえ
Dialogue: 0,0:07:33.74,0:07:36.57,Default,,0,0,0,,酒飲むのに魚なくてどうすんだよ
Dialogue: 0,0:07:38.04,0:07:39.18,Default,,0,0,0,,やお黒
Dialogue: 0,0:07:39.67,0:07:42.03,Default,,0,0,0,,鶏取ってもらったのか
Dialogue: 0,0:07:42.32,0:07:45.68,Default,,0,0,0,,おとっちゃんあれほど言ってるの\N鶏どうして取ってくれん
Dialogue: 0,0:07:45.68,0:07:50.50,Default,,0,0,0,,だって そんな人様に\Nご迷惑かけることばっかりできませんわ
Dialogue: 0,0:07:50.50,0:07:51.81,Default,,0,0,0,,ねえ 何を言ってやんねえ
Dialogue: 0,0:07:51.81,0:07:54.24,Default,,0,0,0,,狸のくせに生意気なことばかりのおかげよ
Dialogue: 0,0:07:54.54,0:07:58.84,Default,,0,0,0,,お父さん 私この派手お酒買うことだって
Dialogue: 0,0:07:58.84,0:08:00.62,Default,,0,0,0,,死ぬより辛い思いなのよ
Dialogue: 0,0:08:01.14,0:08:03.08,Default,,0,0,0,,なんぼ狸だといない
Dialogue: 0,0:08:03.08,0:08:04.94,Default,,0,0,0,,そんなもんか 切ってやくてるわ
Dialogue: 0,0:08:04.94,0:08:06.92,Default,,0,0,0,,よし もうてめえ泣かない
Dialogue: 0,0:08:06.92,0:08:08.26,Default,,0,0,0,,お父さん どこ行くの
Dialogue: 0,0:08:08.26,0:08:09.90,Default,,0,0,0,,はい、うるさはい
Dialogue: 0,0:08:13.84,0:08:15.82,Default,,0,0,0,,お父さん どこ行くの
Dialogue: 0,0:08:32.49,0:08:33.90,Default,,0,0,0,,寝るにゃ惜しい \N 良い月だ
Dialogue: 0,0:08:35.82,0:08:37.67,Default,,0,0,0,,あああ
Dialogue: 0,0:08:44.67,0:08:46.28,Default,,0,0,0,,どういうこと
Dialogue: 0,0:08:46.28,0:08:47.27,Default,,0,0,0,,あああ
Dialogue: 0,0:08:47.62,0:08:49.85,Default,,0,0,0,,このこの
Dialogue: 0,0:08:52.43,0:08:53.54,Default,,0,0,0,,さあ
Dialogue: 0,0:08:53.53,0:08:54.51,Default,,0,0,0,,狸か
Dialogue: 0,0:08:49.74,0:08:51.74,Default,,0,0,0,,うえうえ
Dialogue: 0,0:09:02.08,0:09:04.36,Default,,0,0,0,,ん エルニャお日
Dialogue: 0,0:09:04.36,0:09:07.69,Default,,0,0,0,,いい月だ !
Dialogue: 0,0:09:10.36,0:09:19.58,Default,,0,0,0,,この林は朧月
Dialogue: 0,0:09:19.70,0:09:25.00,Default,,0,0,0,,機嫌直して腹鼓
Dialogue: 0,0:09:25.62,0:09:37.60,Default,,0,0,0,,ちょいと野暮な泥右衛門
Dialogue: 0,0:09:37.60,0:09:54.73,Default,,0,0,0,,くるしいの姿 \N 色姿の 
Dialogue: 0,0:09:54.73,0:09:57.73,Default,,0,0,0,,どうぞお月様のその美しい光で
Dialogue: 0,0:09:57.73,0:09:59.73,Default,,0,0,0,,一日も早くお父さんの悪い心で
Dialogue: 0,0:09:59.73,0:10:02.23,Default,,0,0,0,,速い お黒 何をぐるぐる言ってやんね
Dialogue: 0,0:10:02.23,0:10:05.23,Default,,0,0,0,,まあ お父さん そんなにたくさん鶏よ
Dialogue: 0,0:10:05.23,0:10:08.23,Default,,0,0,0,,へへ 羽ばかりの腹
Dialogue: 0,0:10:07.15,0:10:08.59,Default,,0,0,0,,お父さんがちょっと顔出した
Dialogue: 0,0:10:08.23,0:10:09.23,Default,,0,0,0,,こんなもんで
Dialogue: 0,0:10:09.23,0:10:10.73,Default,,0,0,0,,じゃあやっぱりお父さん
Dialogue: 0,0:10:10.73,0:10:13.99,Default,,0,0,0,,あたりめえよ \N 今でこそ落ち目になっちゃいるが
Dialogue: 0,0:10:13.99,0:10:16.69,Default,,0,0,0,,これでも昔はカチカチ山の泥右衛門よ
Dialogue: 0,0:10:16.69,0:10:18.23,Default,,0,0,0,,少しは世間に知られた
Dialogue: 0,0:10:18.23,0:10:19.73,Default,,0,0,0,,返しもとよ
Dialogue: 0,0:10:19.73,0:10:20.73,Default,,0,0,0,,おて
Dialogue: 0,0:10:20.73,0:10:21.73,Default,,0,0,0,,おいでーで
Dialogue: 0,0:10:21.73,0:10:22.73,Default,,0,0,0,,お父さん
Dialogue: 0,0:10:22.73,0:10:23.73,Default,,0,0,0,,おいで
Dialogue: 0,0:10:23.73,0:10:26.73,Default,,0,0,0,,ああ大きなことを言うもの
Dialogue: 0,0:10:26.73,0:10:28.23,Default,,0,0,0,,やっぱり歳には変わってない
Dialogue: 0,0:10:28.23,0:10:29.23,Default,,0,0,0,,大丈夫お父さん
Dialogue: 0,0:10:29.23,0:10:31.23,Default,,0,0,0,,ああいて
Dialogue: 0,0:10:31.23,0:10:33.03,Default,,0,0,0,,10年目に
Dialogue: 0,0:10:33.03,0:10:34.73,Default,,0,0,0,,カチカチ山で
Dialogue: 0,0:10:34.73,0:10:35.73,Default,,0,0,0,,うわーせー
Dialogue: 0,0:10:35.73,0:10:36.73,Default,,0,0,0,,うわーせー
Dialogue: 0,0:10:36.73,0:10:37.73,Default,,0,0,0,,うわーせー
Dialogue: 0,0:10:37.73,0:10:38.73,Default,,0,0,0,,うわーせー
Dialogue: 0,0:10:38.73,0:10:41.27,Default,,0,0,0,,うわーせー
Dialogue: 0,0:10:41.27,0:10:45.27,Default,,0,0,0,,わーわーわーわー
Dialogue: 0,0:10:45.27,0:10:48.27,Default,,0,0,0,,少しは世間に知られた
Dialogue: 0,0:10:48.27,0:10:51.27,Default,,0,0,0,,火傷の古傷が痛むんだ
Dialogue: 0,0:10:51.27,0:10:52.27,Default,,0,0,0,,ご覧なさいお父さん
Dialogue: 0,0:10:52.27,0:10:54.27,Default,,0,0,0,,悪いことはできないわよ
Dialogue: 0,0:10:54.27,0:10:55.27,Default,,0,0,0,,何言ってやるんだよ
Dialogue: 0,0:10:55.27,0:10:57.27,Default,,0,0,0,,ほら早く薬つけてくれ
Dialogue: 0,0:11:06.08,0:11:09.96,Default,,0,0,0,,やけど 切り傷
Dialogue: 0,0:11:10.31,0:11:12.43,Default,,0,0,0,,毒あたり
Dialogue: 0,0:11:12.43,0:11:18.25,Default,,0,0,0,,シ　シ
Dialogue: 0,0:11:14.65,0:11:18.52,Default,,0,0,0,,小さき病の
Dialogue: 0,0:11:18.94,0:11:21.28,Default,,0,0,0,,傷に塗り
Dialogue: 0,0:11:23.28,0:11:25.64,Default,,0,0,0,,なみに効かない
Dialogue: 0,0:11:25.64,0:11:31.65,Default,,0,0,0,,ええ　こにういう山に
Dialogue: 0,0:11:36.41,0:11:42.87,Default,,0,0,0,,こころあるなら
Dialogue: 0,0:11:42.87,0:11:45.18,Default,,0,0,0,,おくろのたに
Dialogue: 0,0:11:45.18,0:11:49.33,Default,,0,0,0,,こちらむかんで
Dialogue: 0,0:11:49.33,0:11:51.67,Default,,0,0,0,,向く顔が
Dialogue: 0,0:11:53.43,0:11:56.06,Default,,0,0,0,,折れた山にがの
Dialogue: 0,0:11:56.06,0:12:00.95,Default,,0,0,0,,ええきける薬
Dialogue: 0,0:12:10.06,0:12:13.74,Default,,0,0,0,,ああ　栗助さんいつもの薬くださいね
Dialogue: 0,0:12:13.74,0:12:16.72,Default,,0,0,0,,お黒ちゃん　父さんの火傷　痛むのかい
Dialogue: 0,0:12:17.68,0:12:19.47,Default,,0,0,0,,寒くなるとズキズキね
Dialogue: 0,0:12:19.47,0:12:21.33,Default,,0,0,0,,黙ってろい
Dialogue: 0,0:12:22.56,0:12:23.57,Default,,0,0,0,,困ったな
Dialogue: 0,0:12:23.77,0:12:25.09,Default,,0,0,0,,いくら薬飲んだって
Dialogue: 0,0:12:25.24,0:12:26.94,Default,,0,0,0,,朝から酒ばかり飲んでちゃ
Dialogue: 0,0:12:26.94,0:12:28.00,Default,,0,0,0,,なんだぞ
Dialogue: 0,0:12:28.27,0:12:30.58,Default,,0,0,0,,酒ばかり飲むからどういたぞ
Dialogue: 0,0:12:30.58,0:12:32.33,Default,,0,0,0,,そうじゃないのよ 父ちゃん
Dialogue: 0,0:12:32.33,0:12:34.88,Default,,0,0,0,,栗助さんはお父さんの火傷を心配して
Dialogue: 0,0:12:34.88,0:12:36.33,Default,,0,0,0,,心配なんかそのもんか
Dialogue: 0,0:12:36.59,0:12:37.77,Default,,0,0,0,,いや栗助
Dialogue: 0,0:12:38.10,0:12:40.74,Default,,0,0,0,,てめえまた妙に男に化けやがって
Dialogue: 0,0:12:42.23,0:12:44.33,Default,,0,0,0,,お黒__
Dialogue: 0,0:12:46.99,0:12:49.56,Default,,0,0,0,,お黒ちゃん、また来るよ
Dialogue: 0,0:12:50.89,0:12:52.89,Default,,0,0,0,,栗助さん じゃあまたね
Dialogue: 0,0:12:53.43,0:12:55.12,Default,,0,0,0,,おめぇもお父さんの娘なら
Dialogue: 0,0:12:55.12,0:12:57.65,Default,,0,0,0,,あんなzとていとていしたの___わ
Dialogue: 0,0:12:57.89,0:13:00.12,Default,,0,0,0,,でも栗助さんって良い方よ
Dialogue: 0,0:13:00.35,0:13:01.66,Default,,0,0,0,,そんな良言だから
Dialogue: 0,0:13:01.66,0:13:03.63,Default,,0,0,0,,いつまで 持ってみは良い狸になるの
Dialogue: 0,0:13:03.89,0:13:06.89,Default,,0,0,0,,だからこれから少年をしっかり 入れれ
Dialogue: 0,0:13:06.89,0:13:08.89,Default,,0,0,0,,狸御殿の偉方
Dialogue: 0,0:13:08.89,0:13:11.89,Default,,0,0,0,,ここからの埋め付け修繕を垂らし込んでよ
Dialogue: 0,0:13:11.89,0:13:15.89,Default,,0,0,0,,追い詐欺見逃げお父さんを左包みで
Dialogue: 0,0:13:15.89,0:13:17.89,Default,,0,0,0,,振らさして塗ろい
Dialogue: 0,0:13:17.89,0:13:20.89,Default,,0,0,0,,でもお父さん私にそんなことを
Dialogue: 0,0:13:20.89,0:13:21.89,Default,,0,0,0,,できないことがあるのか
Dialogue: 0,0:13:21.89,0:13:23.89,Default,,0,0,0,,てめぐれの器用なら
Dialogue: 0,0:13:26.07,0:13:28.00,Default,,0,0,0,,お父さん鉄砲よ
Dialogue: 0,0:13:28.00,0:13:29.00,Default,,0,0,0,,しょうが
Dialogue: 0,0:13:29.00,0:13:30.65,Default,,0,0,0,,おい 逃げろ
Dialogue: 0,0:13:31.62,0:13:32.70,Default,,0,0,0,,お黒、こっちだ！
Dialogue: 0,0:13:32.70,0:13:33.00,Default,,0,0,0,,お父さん
Dialogue: 0,0:13:37.55,0:13:38.37,Default,,0,0,0,,おいこっちじゃだめだ
Dialogue: 0,0:13:39.95,0:13:40.61,Default,,0,0,0,,お黒
Dialogue: 0,0:13:41.17,0:13:42.38,Default,,0,0,0,,はは　早く逃げる
Dialogue: 0,0:13:42.38,0:13:43.47,Default,,0,0,0,,だらかほんとだ
Dialogue: 0,0:13:44.80,0:13:45.92,Default,,0,0,0,,お　こちはだめだ
Dialogue: 0,0:13:46.40,0:13:47.40,Default,,0,0,0,,逃げる
Dialogue: 0,0:13:47.64,0:13:48.81,Default,,0,0,0,,あ　こちはだめ
Dialogue: 0,0:13:48.81,0:13:50.81,Default,,0,0,0,,ここには　しよ
Dialogue: 0,0:13:55.00,0:13:55.85,Default,,0,0,0,,お父さん
Dialogue: 0,0:13:55.85,0:13:56.82,Default,,0,0,0,,お黒 こっちだろう
Dialogue: 0,0:13:56.82,0:13:58.10,Default,,0,0,0,,１
Dialogue: 0,0:13:58.10,0:14:01.10,Default,,0,0,0,,２
Dialogue: 0,0:14:01.10,0:14:02.44,Default,,0,0,0,,3
Dialogue: 0,0:14:02.44,0:14:04.01,Default,,0,0,0,,しょうがねえから何かに化けちまえ！
Dialogue: 0,0:14:04.01,0:14:04.73,Default,,0,0,0,,動いた
Dialogue: 0,0:14:04.73,0:14:04.84,Default,,0,0,0,,化けちめれ!うっしゃ!
Dialogue: 0,0:14:13.42,0:14:14.96,Default,,0,0,0,,- 里の百姓たちが
Dialogue: 0,0:14:14.96,0:14:16.62,Default,,0,0,0,,狸狩りを始めたらしいわ
Dialogue: 0,0:14:16.82,0:14:18.98,Default,,0,0,0,,あんたがあんまり化けて
Dialogue: 0,0:14:18.98,0:14:19.02,Default,,0,0,0,,ばっかりいるからよ
Dialogue: 0,0:14:19.02,0:14:21.02,Default,,0,0,0,,- あら!私ばっかりじゃないことよ
Dialogue: 0,0:14:21.22,0:14:24.02,Default,,0,0,0,,- でも驚いた!疲れちゃった!
Dialogue: 0,0:14:24.22,0:14:26.72,Default,,0,0,0,,- 私たち近頃化け疲れちゃったのよ
Dialogue: 0,0:14:26.92,0:14:28.92,Default,,0,0,0,,- こいつも人間にばかり化けてえちゃ
Dialogue: 0,0:14:29.12,0:14:30.72,Default,,0,0,0,,- とっても心が疲れるもの
Dialogue: 0,0:14:31.02,0:14:32.42,Default,,0,0,0,,- 本当ね
Dialogue: 0,0:14:32.42,0:14:34.39,Default,,0,0,0,,ああ
Dialogue: 0,0:14:34.57,0:14:36.86,Default,,0,0,0,,たまには誰はばからずしっぽだ
Dialogue: 0,0:14:37.38,0:14:39.58,Default,,0,0,0,,まあ あなた
Dialogue: 0,0:14:39.69,0:14:42.98,Default,,0,0,0,,え、あれ、うしましょう
Dialogue: 0,0:14:44.48,0:14:45.55,Default,,0,0,0,,ごめんなさい
Dialogue: 0,0:14:45.69,0:14:46.72,Default,,0,0,0,,いいわよ
Dialogue: 0,0:14:46.72,0:14:48.49,Default,,0,0,0,,みんなバケ疲れてるんですもの
Dialogue: 0,0:14:48.58,0:14:51.62,Default,,0,0,0,,たまには本来のたぬきの姿に帰って伸び伸び
Dialogue: 0,0:14:51.62,0:14:53.22,Default,,0,0,0,,歌って踊って来いをして
Dialogue: 0,0:14:53.22,0:14:54.87,Default,,0,0,0,,狸林や腹づつん
Dialogue: 0,0:14:55.84,0:14:57.26,Default,,0,0,0,, はら　よし遊ばせよ
Dialogue: 0,0:14:57.26,0:14:58.88,Default,,0,0,0,,狸ってこともわかるじゃん
Dialogue: 0,0:14:58.88,0:15:00.62,Default,,0,0,0,,姫姫様に聞こえたら大変よ
Dialogue: 0,0:15:00.62,0:15:03.18,Default,,0,0,0,,これものよ とまではいかなくとも
Dialogue: 0,0:15:03.18,0:15:05.02,Default,,0,0,0,,ともかくご機嫌は悪いわよ
Dialogue: 0,0:15:05.02,0:15:06.03,Default,,0,0,0,,姫姫様って言ったら
Dialogue: 0,0:15:06.03,0:15:07.76,Default,,0,0,0,,とってもご理想がお高いから
Dialogue: 0,0:15:07.76,0:15:09.58,Default,,0,0,0,,狸と言われることがお嫌なのよ
Dialogue: 0,0:15:09.58,0:15:11.46,Default,,0,0,0,,だって狸は狸じゃん
Dialogue: 0,0:15:11.58,0:15:12.46,Default,,0,0,0,, うなのよ
Dialogue: 0,0:15:12.46,0:15:13.82,Default,,0,0,0,,どうにもならないことだけど
Dialogue: 0,0:15:13.82,0:15:15.42,Default,,0,0,0,,そこが理想がお高いのよ
Dialogue: 0,0:15:15.42,0:15:17.28,Default,,0,0,0,,狸そのものがお嫌なのよ
Dialogue: 0,0:15:17.98,0:15:19.94,Default,,0,0,0,,だから今度厳しいおふれが出て
Dialogue: 0,0:15:19.94,0:15:22.58,Default,,0,0,0,,今後一切、狸の姿でいること相成ら
Dialogue: 0,0:15:22.58,0:15:25.22,Default,,0,0,0,,人間の姿に化けていろ っていうことね
Dialogue: 0,0:15:25.22,0:15:27.64,Default,,0,0,0,,したがって腹づついもいっさいごはっとね
Dialogue: 0,0:15:27.78,0:15:30.50,Default,,0,0,0,,さらば人間の歌に3曲
Dialogue: 0,0:15:30.74,0:15:32.64,Default,,0,0,0,,♪1
Dialogue: 0,0:15:36.51,0:15:37.64,Default,,0,0,0,,♪はい、はい
Dialogue: 0,0:15:37.64,0:15:42.16,Default,,0,0,0,,やれん とらん、とらん、とらん
Dialogue: 0,0:15:42.50,0:15:44.39,Default,,0,0,0,,とらん、とらん
Dialogue: 0,0:15:44.39,0:15:45.54,Default,,0,0,0,,はい、はい
Dialogue: 0,0:15:45.54,0:15:49.97,Default,,0,0,0,,春が来たよともに吹く風が
Dialogue: 0,0:15:49.97,0:15:54.81,Default,,0,0,0,,若い二人の絵あな姿
Dialogue: 0,0:15:54.81,0:16:00.29,Default,,0,0,0,,やさえ　てんや　さあのどっこいしょ
Dialogue: 0,0:16:00.31,0:16:03.06,Default,,0,0,0,,どっこいしょ、どっこいしょ
Dialogue: 0,0:16:07.68,0:16:08.73,Default,,0,0,0,,♪はい、はい
Dialogue: 0,0:16:08.73,0:16:13.23,Default,,0,0,0,,やれん とらん、とらん、とらん
Dialogue: 0,0:16:13.57,0:16:15.41,Default,,0,0,0,,とらん、とらん
Dialogue: 0,0:16:15.41,0:16:16.61,Default,,0,0,0,,♪はい、はい
Dialogue: 0,0:16:16.61,0:16:21.06,Default,,0,0,0,,祭おいもの祭のあとも
Dialogue: 0,0:16:21.29,0:16:25.90,Default,,0,0,0,,そっとあいたいへ人があるちょい
Dialogue: 0,0:16:25.90,0:16:26.97,Default,,0,0,0,,あやさえ
Dialogue: 0,0:16:26.97,0:16:30.97,Default,,0,0,0,,てんやさのどっこいしょ
Dialogue: 0,0:16:30.97,0:16:34.22,Default,,0,0,0,,どっこいしょ　どっこいしょ
Dialogue: 0,0:16:42.29,0:16:43.57,Default,,0,0,0,,あら　雨が降ってきた
Dialogue: 0,0:16:43.87,0:16:46.31,Default,,0,0,0,,困ったな　速く御殿帰らないと
Dialogue: 0,0:16:46.31,0:16:49.31,Default,,0,0,0,,あら　傘ならここにありますよ
Dialogue: 0,0:16:49.31,0:16:52.31,Default,,0,0,0,,その傘ね
Dialogue: 0,0:17:12.68,0:17:14.40,Default,,0,0,0,,そのごろ
Dialogue: 0,0:17:14.40,0:17:17.40,Default,,0,0,0,,ま
Dialogue: 0,0:17:17.40,0:17:17.98,Default,,0,0,0,,あ余計なこと とんでもない
Dialogue: 0,0:17:18.11,0:17:21.18,Default,,0,0,0,,今日という姫様お見合いの大切な日に
Dialogue: 0,0:17:21.18,0:17:22.57,Default,,0,0,0,,どこをお付き合わせるのだ
Dialogue: 0,0:17:22.57,0:17:23.05,Default,,0,0,0,,はい
Dialogue: 0,0:17:23.05,0:17:25.45,Default,,0,0,0,,早くあちらでお出迎えだ
Dialogue: 0,0:17:25.45,0:17:27.84,Default,,0,0,0,,??  ?? そんな傘
Dialogue: 0,0:17:28.05,0:17:30.05,Default,,0,0,0,,ねえそんな見苦しい傘を持ち込んで
Dialogue: 0,0:17:30.05,0:17:33.05,Default,,0,0,0,,若姫のおめでとまったのなんて
Dialogue: 0,0:17:33.05,0:17:35.05,Default,,0,0,0,,若姫様とおっしゃると
Dialogue: 0,0:17:35.05,0:17:37.05,Default,,0,0,0,,本日ご庭院へお越しになる
Dialogue: 0,0:17:37.05,0:17:40.05,Default,,0,0,0,,駆泉山の多狸吉郎
Dialogue: 0,0:17:40.05,0:17:42.21,Default,,0,0,0,,分かるかれ発射が一瞬にし
Dialogue: 0,0:17:42.05,0:17:44.21,Default,,0,0,0,,姫様に聞こえたらなんとさ
Dialogue: 0,0:17:44.21,0:17:46.31,Default,,0,0,0,,じゃ　ともかくあちらで
Dialogue: 0,0:17:46.31,0:17:48.31,Default,,0,0,0,,あちでお見合いのお仕事や
Dialogue: 0,0:17:48.31,0:17:50.95,Default,,0,0,0,,こんな見苦しい傘は 焼き捨てて
Dialogue: 0,0:17:50.95,0:17:52.05,Default,,0,0,0,,かしこまりました
Dialogue: 0,0:17:55.42,0:17:57.43,Default,,0,0,0,,ねえ　ちょっと　狸吉郎さま
Dialogue: 0,0:17:57.43,0:17:58.64,Default,,0,0,0,,本当にお出でないのかしら
Dialogue: 0,0:17:58.64,0:18:01.35,Default,,0,0,0,,本当よ 姫君様とのお見合い
Dialogue: 0,0:18:01.35,0:18:02.61,Default,,0,0,0,,私どうしましょう
Dialogue: 0,0:18:02.61,0:18:04.34,Default,,0,0,0,,皆さんとにかく早くお支度...
Dialogue: 0,0:18:04.34,0:18:05.39,Default,,0,0,0,,え　え
Dialogue: 0,0:18:09.53,0:18:11.39,Default,,0,0,0,,焼き捨てられてたまる気
Dialogue: 0,0:18:11.39,0:18:13.53,Default,,0,0,0,,お父さん大きな声出さないでよ
Dialogue: 0,0:18:13.53,0:18:15.47,Default,,0,0,0,,言ってやったよ
Dialogue: 0,0:18:15.47,0:18:18.63,Default,,0,0,0,,しかし立派な御殿だなぁ
Dialogue: 0,0:18:18.63,0:18:21.57,Default,,0,0,0,,まあ やっぱりたね御殿だ
Dialogue: 0,0:18:21.57,0:18:23.71,Default,,0,0,0,,どうしよう 私たね御殿に来たんだ
Dialogue: 0,0:18:23.71,0:18:26.41,Default,,0,0,0,,そうなったらどうせ御殿へ来たついてだ
Dialogue: 0,0:18:26.41,0:18:28.61,Default,,0,0,0,,何かこう金目のものでもいただいていい
Dialogue: 0,0:18:28.61,0:18:29.91,Default,,0,0,0,,お父さん何を言うの
Dialogue: 0,0:18:29.91,0:18:31.71,Default,,0,0,0,,心配それは任しとき
Dialogue: 0,0:18:31.71,0:18:33.29,Default,,0,0,0,,こう見えたってお父さん
Dialogue: 0,0:18:33.29,0:18:35.25,Default,,0,0,0,,今でこそお知りになっちゃいるわ
Dialogue: 0,0:18:35.25,0:18:37.45,Default,,0,0,0,,分かってるわよ 静かにして
Dialogue: 0,0:18:43.10,0:18:44.67,Default,,0,0,0,,お父さん
Dialogue: 0,0:18:44.37,0:18:45.88,Default,,0,0,0,,ここ覗いてくれ
Dialogue: 0,0:18:45.88,0:18:47.18,Default,,0,0,0,,いやよ 覗いたりして悪くない
Dialogue: 0,0:18:47.18,0:18:50.18,Default,,0,0,0,,ここ覗いてくれ
Dialogue: 0,0:18:51.18,0:18:52.76,Default,,0,0,0,,そんな覗きにしたりして悪くない
Dialogue: 0,0:18:52.76,0:19:01.20,Default,,0,0,0,,言ってるだろう 売り二つって言うけれど
Dialogue: 0,0:19:01.20,0:19:05.90,Default,,0,0,0,,どなたでしょ まるで私がそこにいるみた
Dialogue: 0,0:19:05.90,0:19:07.58,Default,,0,0,0,,姫君様かもしれないわ
Dialogue: 0,0:19:07.90,0:19:10.58,Default,,0,0,0,,姫君様だ
Dialogue: 0,0:19:10.58,0:19:11.90,Default,,0,0,0,,でもそんなもったいな
Dialogue: 0,0:19:11.90,0:19:13.13,Default,,0,0,0,,いくらたしにてるったって
Dialogue: 0,0:19:13.58,0:19:15.02,Default,,0,0,0,,私よりはご立派だ
Dialogue: 0,0:19:15.98,0:19:17.05,Default,,0,0,0,,お敵に
Dialogue: 0,0:21:02.18,0:21:05.15,Default,,0,0,0,,探しに囲まれちゃバケる隙間何も
Dialogue: 0,0:21:01.40,0:21:06.02,Default,,0,0,0,,あったもんじゃねえ
Dialogue: 0,0:21:07.40,0:21:09.01,Default,,0,0,0,,お父さん
Dialogue: 0,0:21:16.82,0:21:17.38,Default,,0,0,0,,何
Dialogue: 0,0:21:22.97,0:21:25.97,Default,,0,0,0,,?
Dialogue: 0,0:21:25.38,0:21:34.96,Default,,0,0,0,,あそっちたちは姫君様に向かって何事じゃ
Dialogue: 0,0:21:34.96,0:21:35.96,Default,,0,0,0,,いや私違う
Dialogue: 0,0:21:35.96,0:21:39.78,Default,,0,0,0,,これ姫君様を
Dialogue: 0,0:21:39.78,0:21:41.78,Default,,0,0,0,,これなるもの姫君さんでございません
Dialogue: 0,0:21:41.78,0:21:44.78,Default,,0,0,0,,姫君様にはあちらにおいででございます
Dialogue: 0,0:21:44.78,0:21:52.65,Default,,0,0,0,,そういえばどことなく物ごし態度の癒しげな
Dialogue: 0,0:21:52.65,0:21:56.66,Default,,0,0,0,,よく似たものがあるもの
Dialogue: 0,0:22:09.31,0:22:11.61,Default,,0,0,0,,姫君様のお部屋間近にいらしたら
Dialogue: 0,0:22:17.42,0:22:19.42,Default,,0,0,0,,姫様これにか
Dialogue: 0,0:22:19.42,0:22:22.42,Default,,0,0,0,,ただいま小泉山は
Dialogue: 0,0:22:22.42,0:22:25.42,Default,,0,0,0,,狸城君ご到着にございます
Dialogue: 0,0:22:25.90,0:22:29.74,Default,,0,0,0,,姫様 姫様
Dialogue: 0,0:22:29.89,0:22:32.89,Default,,0,0,0,,これは知ったり姫様には
Dialogue: 0,0:22:32.89,0:22:35.89,Default,,0,0,0,,狸に入れたわゆみゆ
Dialogue: 0,0:22:35.89,0:22:38.57,Default,,0,0,0,,姫様 お目覚めなさりませ
Dialogue: 0,0:22:42.86,0:22:46.03,Default,,0,0,0,,うるさいはね \N 誰なのよ
Dialogue: 0,0:22:46.03,0:22:49.35,Default,,0,0,0,,家間  狸右衛門にございます
Dialogue: 0,0:22:46.03,0:22:49.35,Note,,0,0,0,,Iema Tanuemon at your service
Dialogue: 0,0:22:49.83,0:22:51.47,Default,,0,0,0,,そうだろうね
Dialogue: 0,0:22:51.83,0:22:53.47,Default,,0,0,0,,今自分古臭い腹づつみなど撃つものは
Dialogue: 0,0:22:53.47,0:22:55.91,Default,,0,0,0,,ない 古臭い腹づつみ
Dialogue: 0,0:22:55.91,0:22:57.83,Default,,0,0,0,,それに何よその顔は
Dialogue: 0,0:22:57.91,0:22:59.83,Default,,0,0,0,,まるで狸の顔みたい
Dialogue: 0,0:22:59.83,0:23:01.43,Default,,0,0,0,,これはいなことを受けたんがある
Dialogue: 0,0:23:01.83,0:23:03.43,Default,,0,0,0,, タヌキがタヌキの顔です
Dialogue: 0,0:23:03.43,0:23:07.19,Default,,0,0,0,,お黙り 例えタヌキであろうとも
Dialogue: 0,0:23:07.19,0:23:11.39,Default,,0,0,0,,美しい人間の姿形は見習うべきだと思わない
Dialogue: 0,0:23:11.39,0:23:13.99,Default,,0,0,0,,お言葉ながら姫様
Dialogue: 0,0:23:13.39,0:23:15.99,Default,,0,0,0,,イニシエよりの真似するカラスとて
Dialogue: 0,0:23:15.99,0:23:17.75,Default,,0,0,0,,ええお黙り
Dialogue: 0,0:23:17.99,0:23:19.75,Default,,0,0,0,,嫉妬なそんな顔は見とうもない
Dialogue: 0,0:23:19.75,0:23:21.19,Default,,0,0,0,,早く人間にお化けったら
Dialogue: 0,0:23:21.19,0:23:22.23,Default,,0,0,0,,姫
Dialogue: 0,0:23:22.23,0:23:24.39,Default,,0,0,0,,ええ早く人間に化けとしまい
Dialogue: 0,0:23:24.39,0:23:28.03,Default,,0,0,0,,はい 今命のれば
Dialogue: 0,0:23:28.03,0:23:32.34,Default,,0,0,0,,ぜひもなけことを
Dialogue: 0,0:23:32.34,0:23:36.34,Default,,0,0,0,,それでよいそれでよ
Dialogue: 0,0:23:36.34,0:23:40.50,Default,,0,0,0,,今気をつけて下品な腹づつみなど歌ねよ
Dialogue: 0,0:23:40.34,0:23:44.50,Default,,0,0,0,,私はそんな浅ましい姿を思うだけでも憂鬱だわ
Dialogue: 0,0:23:44.50,0:23:49.42,Default,,0,0,0,,私この頃憂鬱よ 狸も18番茶もではな
Dialogue: 0,0:23:49.42,0:23:53.30,Default,,0,0,0,,お年頃のせいでございましょうまあいやらしい
Dialogue: 0,0:23:53.42,0:23:56.30,Default,,0,0,0,,嫌なじ嫌なじいでも年の子
Dialogue: 0,0:23:56.30,0:23:58.48,Default,,0,0,0,,そんなことだろうと存じまして
Dialogue: 0,0:23:58.30,0:24:01.48,Default,,0,0,0,,本日兼ねて申し上げておきました
Dialogue: 0,0:24:01.48,0:24:03.06,Default,,0,0,0,,お見合いということに
Dialogue: 0,0:24:03.06,0:24:05.22,Default,,0,0,0,,取り図らえおきまして ござります
Dialogue: 0,0:24:05.22,0:24:06.52,Default,,0,0,0,,何?お見合い?
Dialogue: 0,0:24:06.52,0:24:08.88,Default,,0,0,0,,{\clip(591.39,651.2,613.82,652.8)}はっ 靴見山田抜吉郎君
Dialogue: 0,0:24:08.88,0:24:10.36,Default,,0,0,0,,姫様とお見合いのため
Dialogue: 0,0:24:10.88,0:24:13.36,Default,,0,0,0,,既にご到着になってでございますが
Dialogue: 0,0:24:13.36,0:24:14.46,Default,,0,0,0,,- 姪!- はっ
Dialogue: 0,0:24:14.46,0:24:16.12,Default,,0,0,0,,誰がそんなことを頼みました?
Dialogue: 0,0:24:16.12,0:24:17.16,Default,,0,0,0,,いえ それはもう
Dialogue: 0,0:24:17.12,0:24:19.16,Default,,0,0,0,,この姪にお任せ下されば
Dialogue: 0,0:24:19.16,0:24:21.06,Default,,0,0,0,,- バカ!- バカ
Dialogue: 0,0:24:21.06,0:24:23.86,Default,,0,0,0,,姫はお見合いなどいたしません
Dialogue: 0,0:24:23.86,0:24:26.16,Default,,0,0,0,,私は田抜の夫など持ちません
Dialogue: 0,0:24:26.16,0:24:28.88,Default,,0,0,0,,姫理想も今も結構ながらボンを越え
Dialogue: 0,0:24:28.16,0:24:31.88,Default,,0,0,0,,己を分けまえざるご理想は
Dialogue: 0,0:24:31.88,0:24:34.04,Default,,0,0,0,,愚か者だと言うんだろう
Dialogue: 0,0:24:34.04,0:24:35.64,Default,,0,0,0,,何とでも言えばいい
Dialogue: 0,0:24:35.64,0:24:37.72,Default,,0,0,0,,私はたぬきの夫は持ちません
Dialogue: 0,0:24:37.72,0:24:39.96,Default,,0,0,0,,私の夫は人間です
Dialogue: 0,0:24:39.96,0:24:41.68,Default,,0,0,0,,姫にはあの人間は
Dialogue: 0,0:24:41.68,0:24:43.32,Default,,0,0,0,,何をそんなに驚くの
Dialogue: 0,0:24:43.32,0:24:45.12,Default,,0,0,0,,私はこんなに美しい
Dialogue: 0,0:24:45.12,0:24:48.16,Default,,0,0,0,,ほらこんなに美しい
Dialogue: 0,0:24:48.16,0:24:51.79,Default,,0,0,0,,それにとっても魅惑的
Dialogue: 0,0:24:51.79,0:24:58.69,Default,,0,0,0,,いかがこの趣味この好み
Dialogue: 0,0:24:58.69,0:24:59.69,Default,,0,0,0,,違ったわ
Dialogue: 0,0:24:59.69,0:25:03.61,Default,,0,0,0,,おかく私は美しい
Dialogue: 0,0:25:03.61,0:25:05.15,Default,,0,0,0,,私はタヌキではあるけれど
Dialogue: 0,0:25:05.61,0:25:07.15,Default,,0,0,0,,タヌキ以上のものなのよ
Dialogue: 0,0:25:07.15,0:25:10.25,Default,,0,0,0,,まずお聞きなされません 姫様
Dialogue: 0,0:25:10.25,0:25:12.35,Default,,0,0,0,,タヌキはタヌキ 人は人
Dialogue: 0,0:25:12.35,0:25:14.19,Default,,0,0,0,,いかに巧みに化けようと
Dialogue: 0,0:25:14.19,0:25:17.29,Default,,0,0,0,,いや 私はタヌキの夫は持ちません
Dialogue: 0,0:25:17.29,0:25:19.83,Default,,0,0,0,,私の夫は人間です
Dialogue: 0,0:25:19.83,0:25:22.97,Default,,0,0,0,,そうだ 私は後天を出て行こう
Dialogue: 0,0:25:22.97,0:25:25.83,Default,,0,0,0,,誰がこんな古いお姫に縛られて
Dialogue: 0,0:25:25.83,0:25:27.61,Default,,0,0,0,,姫 縛るか 縛るかお前
Dialogue: 0,0:25:27.61,0:25:30.83,Default,,0,0,0,,いや これでお前たちとはさようなら
Dialogue: 0,0:25:30.83,0:25:31.19,Default,,0,0,0,,いいえ
Dialogue: 0,0:25:31.83,0:25:34.19,Default,,0,0,0,,狸の世界ともこれで永久にさようなら
Dialogue: 0,0:25:34.19,0:25:35.27,Default,,0,0,0,,姫
Dialogue: 0,0:25:35.27,0:25:38.70,Default,,0,0,0,,話して
Dialogue: 0,0:25:38.70,0:25:42.14,Default,,0,0,0,,私は私の力を持って私の理想に前進する
Dialogue: 0,0:25:42.14,0:25:42.82,Default,,0,0,0,,姫
Dialogue: 0,0:25:42.82,0:25:44.38,Default,,0,0,0,,今こそ歴史的瞬間よ
Dialogue: 0,0:25:44.38,0:25:45.66,Default,,0,0,0,,姫
Dialogue: 0,0:25:45.66,0:25:47.34,Default,,0,0,0,,姫
Dialogue: 0,0:25:47.34,0:25:48.50,Default,,0,0,0,,姫
Dialogue: 0,0:25:48.50,0:25:50.06,Default,,0,0,0,,あてま
Dialogue: 0,0:25:50.06,0:25:53.82,Default,,0,0,0,,時間頃の若いお方は気が早い
Dialogue: 0,0:25:53.82,0:25:55.50,Default,,0,0,0,,姫君
Dialogue: 0,0:25:55.50,0:25:56.38,Default,,0,0,0,,姫君
Dialogue: 0,0:25:56.38,0:25:58.50,Default,,0,0,0,,おお これは心
Dialogue: 0,0:25:58.50,0:26:00.10,Default,,0,0,0,,いや先ほどより
Dialogue: 0,0:26:00.10,0:26:03.22,Default,,0,0,0,,タヌキ士郎様お待ちかねでございますが
Dialogue: 0,0:26:03.22,0:26:06.50,Default,,0,0,0,,タヌジョウ殿姫にはただいま
Dialogue: 0,0:26:06.50,0:26:11.42,Default,,0,0,0,,たったいまお家でなされました
Dialogue: 0,0:26:11.42,0:26:13.18,Default,,0,0,0,,それはまた突然に
Dialogue: 0,0:26:13.18,0:26:14.82,Default,,0,0,0,,どうしたことでございます
Dialogue: 0,0:26:14.82,0:26:18.58,Default,,0,0,0,,実は近々こういうわけ
Dialogue: 0,0:26:18.58,0:26:21.10,Default,,0,0,0,,それは優しきお家の大
Dialogue: 0,0:26:21.10,0:26:23.22,Default,,0,0,0,,およすぎだけのことではな
Dialogue: 0,0:26:23.22,0:26:26.26,Default,,0,0,0,,そのことじゃ今この傾きかけた
Dialogue: 0,0:26:26.26,0:26:29.58,Default,,0,0,0,,タヌキ五天の運命はいつにかかって
Dialogue: 0,0:26:29.58,0:26:32.22,Default,,0,0,0,,姫様のご双剣に終わすの
Dialogue: 0,0:26:32.22,0:26:34.26,Default,,0,0,0,,大きな声では言われませんが
Dialogue: 0,0:26:34.26,0:26:36.38,Default,,0,0,0,,おとう家の立つ方のかは
Dialogue: 0,0:26:36.38,0:26:38.14,Default,,0,0,0,,今夜のお見合いで決まります
Dialogue: 0,0:26:38.14,0:26:39.82,Default,,0,0,0,,しゅびよくご縁談がまとまれば
Dialogue: 0,0:26:39.82,0:26:42.06,Default,,0,0,0,,百万丁分のくれまやしと
Dialogue: 0,0:26:42.06,0:26:43.82,Default,,0,0,0,,千万丁分の芋畑を
Dialogue: 0,0:26:43.82,0:26:47.58,Default,,0,0,0,,たぬきちろう君お腰入れのお手土産として
Dialogue: 0,0:26:47.58,0:26:49.58,Default,,0,0,0,,ごじさんを遊ばされ
Dialogue: 0,0:26:49.58,0:26:51.22,Default,,0,0,0,,それだけあれば
Dialogue: 0,0:26:51.22,0:26:52.78,Default,,0,0,0,,それで我が家はご飯会に
Dialogue: 0,0:26:52.78,0:26:54.70,Default,,0,0,0,,うまくいったと思ったら
Dialogue: 0,0:26:54.70,0:26:58.42,Default,,0,0,0,,その肝心の姫君は突然を家で遊ばすと
Dialogue: 0,0:26:58.42,0:27:00.08,Default,,0,0,0,,トランの狸の川だよ
Dialogue: 0,0:27:00.42,0:27:02.08,Default,,0,0,0,,車両行っている場合でない
Dialogue: 0,0:27:02.08,0:27:04.72,Default,,0,0,0,,この上は一時も早く
Dialogue: 0,0:27:04.08,0:27:06.72,Default,,0,0,0,,姫のお行方を探し出し
Dialogue: 0,0:27:06.72,0:27:09.43,Default,,0,0,0,,それにしても差し詰め今夜のお見合いは
Dialogue: 0,0:27:09.43,0:27:10.22,Default,,0,0,0,,そうか
Dialogue: 0,0:27:10.22,0:27:11.61,Default,,0,0,0,,あ 狸の御様
Dialogue: 0,0:27:11.61,0:27:14.90,Default,,0,0,0,,先ほどよりまだかまだかとお待ちかね
Dialogue: 0,0:27:14.90,0:27:18.54,Default,,0,0,0,,狸人とだ この上は白髭矢も狸も
Dialogue: 0,0:27:18.54,0:27:22.30,Default,,0,0,0,,シワバラ切って申し訳つかまって 御家郎
Dialogue: 0,0:27:22.30,0:27:25.74,Default,,0,0,0,,御家郎様 この狸に良い資案がございまする
Dialogue: 0,0:27:25.74,0:27:28.24,Default,,0,0,0,,何を知らんと言いますと
Dialogue: 0,0:27:28.24,0:27:30.58,Default,,0,0,0,,ええ殺すなら早く殺せろ
Dialogue: 0,0:27:30.58,0:27:32.74,Default,,0,0,0,,殺してたぬき汁を何ともしてやろ
Dialogue: 0,0:27:32.74,0:27:35.28,Default,,0,0,0,,静かにしろもうたぬき汁など食いや来たわ
Dialogue: 0,0:27:35.28,0:27:36.08,Default,,0,0,0,,やが欲しいじゃん
Dialogue: 0,0:27:36.08,0:27:37.98,Default,,0,0,0,,お父さんもう大人しく諦めて
Dialogue: 0,0:27:37.98,0:27:39.38,Default,,0,0,0,,立派にお裁きを受けましょう
Dialogue: 0,0:27:39.38,0:27:40.88,Default,,0,0,0,,うるせぇやしようねこうなったら
Dialogue: 0,0:27:40.88,0:27:43.30,Default,,0,0,0,,やだやだ
Dialogue: 0,0:27:43.30,0:27:45.46,Default,,0,0,0,,こいつらはこっちがたぬき汁にされちまうよ
Dialogue: 0,0:27:45.46,0:27:46.26,Default,,0,0,0,,お前はみなさんで殺せろ
Dialogue: 0,0:27:46.46,0:27:47.26,Default,,0,0,0,,早く殺せろ
Dialogue: 0,0:27:47.26,0:27:48.06,Default,,0,0,0,,お父さん
Dialogue: 0,0:27:48.06,0:27:48.90,Default,,0,0,0,,お父さんしろ
Dialogue: 0,0:27:48.90,0:27:49.84,Default,,0,0,0,,今のうちに早く逃げちゃう
Dialogue: 0,0:27:49.84,0:27:52.06,Default,,0,0,0,,いやうるさい静かにしろ
Dialogue: 0,0:27:52.06,0:27:54.04,Default,,0,0,0,,彼女は大事なものまで盗み出して
Dialogue: 0,0:27:54.04,0:27:56.40,Default,,0,0,0,,なんて言ったでしょって 殺すのか
Dialogue: 0,0:27:56.40,0:27:59.44,Default,,0,0,0,,あの お願いでございます
Dialogue: 0,0:27:59.44,0:28:00.18,Default,,0,0,0,,お父さんの背中を
Dialogue: 0,0:28:00.44,0:28:02.18,Default,,0,0,0,,叩かないであげてくださいな
Dialogue: 0,0:28:02.18,0:28:05.04,Default,,0,0,0,,やけどの黒傷が 痛むんです
Dialogue: 0,0:28:05.04,0:28:09.63,Default,,0,0,0,,静かにしろ ご老女様 飲んでました
Dialogue: 0,0:28:09.63,0:28:11.43,Default,,0,0,0,,それ お黒の縄目を解き
Dialogue: 0,0:28:11.43,0:28:16.08,Default,,0,0,0,,直ちに奥へ 連れ参りましょう
Dialogue: 0,0:28:16.08,0:28:19.84,Default,,0,0,0,,いやいや お黒 どこ連れてくんだよ
Dialogue: 0,0:28:19.84,0:28:22.88,Default,,0,0,0,,おい お黒を殺すんなら
Dialogue: 0,0:28:22.84,0:28:24.88,Default,,0,0,0,,俺を代わりに殺してくれ
Dialogue: 0,0:28:24.88,0:28:26.52,Default,,0,0,0,,かわいそうにお黒のやつ
Dialogue: 0,0:28:26.88,0:28:30.52,Default,,0,0,0,,タルキジルでもされちまうのか
Dialogue: 0,0:28:30.52,0:28:34.82,Default,,0,0,0,,みなさん あいつは親孝行の娘でございますから
Dialogue: 0,0:28:34.82,0:28:36.68,Default,,0,0,0,,命だけは助けてやっておくのだい
Dialogue: 0,0:28:36.82,0:28:38.68,Default,,0,0,0,,心配しなくても大丈夫よ
Dialogue: 0,0:28:38.68,0:28:44.51,Default,,0,0,0,,実はお黒ちゃんお借りして
Dialogue: 0,0:28:44.68,0:28:48.51,Default,,0,0,0,,黒は姫君様のおみなわれ
Dialogue: 0,0:28:48.51,0:28:50.11,Default,,0,0,0,,どうじゃない
Dialogue: 0,0:28:50.51,0:28:51.11,Default,,0,0,0,,支度はできたかな
Dialogue: 0,0:28:51.11,0:28:53.19,Default,,0,0,0,,ご安心なされません
Dialogue: 0,0:28:53.11,0:28:54.19,Default,,0,0,0,,お召し会させましたら
Dialogue: 0,0:28:54.19,0:28:56.59,Default,,0,0,0,,まるでもう姫君様とブリフターが
Dialogue: 0,0:28:56.59,0:28:58.59,Default,,0,0,0,,いや それはよかった ありがたい
Dialogue: 0,0:28:58.59,0:29:02.23,Default,,0,0,0,,では タヌジオルトの声だぞ
Dialogue: 0,0:29:02.23,0:29:04.93,Default,,0,0,0,,なるほど 力はさっそくそのように
Dialogue: 0,0:29:04.93,0:29:06.33,Default,,0,0,0,,ああ これこれ
Dialogue: 0,0:29:06.33,0:29:07.63,Default,,0,0,0,,これは ご用任様
Dialogue: 0,0:29:07.63,0:29:10.73,Default,,0,0,0,,突然だが これからすぐタヌキ祭りを始めなさい
Dialogue: 0,0:29:10.73,0:29:12.91,Default,,0,0,0,,あの 本日お見合いの儀式と受けたましてください
Dialogue: 0,0:29:12.91,0:29:14.55,Default,,0,0,0,,それをいささら変更して
Dialogue: 0,0:29:14.91,0:29:15.55,Default,,0,0,0,,お見合いを兼ねて
Dialogue: 0,0:29:15.55,0:29:17.75,Default,,0,0,0,,盛大なタヌキ祭りを
Dialogue: 0,0:29:17.55,0:29:18.75,Default,,0,0,0,,催すことに遭えなくてな
Dialogue: 0,0:29:18.75,0:29:20.55,Default,,0,0,0,,なんせ 姫には偽物だ
Dialogue: 0,0:29:20.55,0:29:21.95,Default,,0,0,0,,困ったことになりましたな
Dialogue: 0,0:29:21.95,0:29:23.89,Default,,0,0,0,,静かなお見合いなどやっていて
Dialogue: 0,0:29:23.89,0:29:26.51,Default,,0,0,0,,お身代わりだということを感じかれては大変
Dialogue: 0,0:29:26.51,0:29:27.17,Default,,0,0,0,,なるほど
Dialogue: 0,0:29:27.17,0:29:29.85,Default,,0,0,0,,この日は一層バカ騒ぎに騒ぎだって
Dialogue: 0,0:29:29.85,0:29:32.56,Default,,0,0,0,,若君の置きを逸らすことが感じんじゃね
Dialogue: 0,0:29:32.79,0:29:33.62,Default,,0,0,0,,わかったな
Dialogue: 0,0:29:33.62,0:29:34.07,Default,,0,0,0,,はい
Dialogue: 0,0:29:34.07,0:29:37.79,Default,,0,0,0,,では早速全国の山山森影ホラーなより
Dialogue: 0,0:29:37.79,0:29:41.45,Default,,0,0,0,,{\clip(818.96,326.4,818.96,326.4)}たぬきこだぬき狩り集めたぬき祭りの
Dialogue: 0,0:29:41.45,0:29:43.11,Default,,0,0,0,,始まり始まり
Dialogue: 0,0:29:55.34,0:29:57.42,Default,,0,0,0,,わっしょい、わっしょい
Dialogue: 0,0:29:57.42,0:29:59.50,Default,,0,0,0,,わっしょい、わっしょい
Dialogue: 0,0:30:12.42,0:30:14.42,Default,,0,0,0,,わっしょい、わっしょい
Dialogue: 0,0:30:16.32,0:30:19.64,Default,,0,0,0,,春だ祭りだ　祭りだ春だ
Dialogue: 0,0:30:20.19,0:30:24.58,Default,,0,0,0,,揃ったのだよ　良い子が揃った
Dialogue: 0,0:30:24.58,0:30:27.81,Default,,0,0,0,,青いしんめを見るように
Dialogue: 0,0:30:28.22,0:30:32.12,Default,,0,0,0,,あーっと繰り出せピチピチと
Dialogue: 0,0:30:32.89,0:30:35.81,Default,,0,0,0,,狸ばやしで
Dialogue: 0,0:30:36.56,0:30:40.55,Default,,0,0,0,,よりとなそれ、よりとなそれ、それ
Dialogue: 0,0:30:40.55,0:30:45.14,Default,,0,0,0,,わっしょい、わっしょい、わっしょい、わっしょい、
Dialogue: 0,0:30:45.14,0:30:48.77,Default,,0,0,0,,歌だ踊りだ踊りだ歌だ
Dialogue: 0,0:30:49.22,0:30:53.42,Default,,0,0,0,,森の神明にゃで村もあるが
Dialogue: 0,0:30:53.42,0:30:56.62,Default,,0,0,0,,揃った子狸にゃ村がない
Dialogue: 0,0:30:56.62,0:30:57.28,Default,,0,0,0,,それ
Dialogue: 0,0:30:57.28,0:31:01.28,Default,,0,0,0,,さっと笑顔でぴちぴちと
Dialogue: 0,0:31:01.70,0:31:06.99,Default,,0,0,0,,狸ばやしで よほいとな
Dialogue: 0,0:31:06.99,0:31:09.07,Default,,0,0,0,,それ、よほいとな
Dialogue: 0,0:31:09.07,0:31:14.22,Default,,0,0,0,,それ、わっしよい、わっしよい、わっしよい、わっしよい
Dialogue: 0,0:31:32.62,0:31:39.88,Default,,0,0,0,,森は春、狸も春
Dialogue: 0,0:31:39.88,0:31:46.29,Default,,0,0,0,,どこも集まり
Dialogue: 0,0:31:46.29,0:31:50.02,Default,,0,0,0,,若君様の
Dialogue: 0,0:31:50.32,0:31:57.09,Default,,0,0,0,,お出まし
Dialogue: 0,0:32:03.66,0:32:08.11,Default,,0,0,0,,皆様ようこそ
Dialogue: 0,0:32:08.11,0:32:12.11,Default,,0,0,0,,今日は森の祭り
Dialogue: 0,0:32:12.11,0:32:16.35,Default,,0,0,0,,思い切り歌いましょう
Dialogue: 0,0:32:16.35,0:32:20.59,Default,,0,0,0,,思い切り踊りましょう
Dialogue: 0,0:32:20.59,0:32:24.99,Default,,0,0,0,,皆様ようこそようこそ
Dialogue: 0,0:32:24.99,0:32:27.99,Default,,0,0,0,,僕の名前は
Dialogue: 0,0:32:27.99,0:32:31.99,Default,,0,0,0,,狸吉郎　（タヌキジロー）
Dialogue: 0,0:33:00.01,0:33:08.01,Default,,0,0,0,,♪
Dialogue: 0,0:33:08.31,0:33:12.85,Default,,0,0,0,,♪ 歌は先ぶち
Dialogue: 0,0:33:12.85,0:33:18.31,Default,,0,0,0,,このま　富士の
Dialogue: 0,0:33:23.81,0:33:29.53,Default,,0,0,0,,♪姿にいるようで
Dialogue: 0,0:33:29.53,0:33:35.05,Default,,0,0,0,,♪ほんにみるようです
Dialogue: 0,0:33:38.00,0:33:42.56,Default,,0,0,0,,♪ほれ　ばぬき
Dialogue: 0,0:33:43.53,0:33:46.53,Default,,0,0,0,,♪やっけ　やっけ　やっけ　よい
Dialogue: 0,0:33:51.53,0:33:53.53,Default,,0,0,0,,♪これは　楽んです
Dialogue: 0,0:33:54.43,0:33:58.53,Default,,0,0,0,,♪あめなようう
Dialogue: 0,0:40:55.75,0:40:59.02,Default,,0,0,0,,まあ 本当に世の中に
Dialogue: 0,0:40:59.02,0:41:02.02,Default,,0,0,0,,いろんなことがあるね
Dialogue: 0,0:41:02.02,0:41:05.02,Default,,0,0,0,,あの美し
Dialogue: 0,0:42:12.27,0:42:14.27,Default,,0,0,0,,姫様のことが余裕に召し
Dialogue: 0,0:42:14.27,0:42:16.10,Default,,0,0,0,,お二人きりで水いらず
Dialogue: 0,0:42:16.10,0:42:18.27,Default,,0,0,0,,ご対面なさりたいとおっしゃるのか
Dialogue: 0,0:41:18.52,0:42:19.14,Default,,0,0,0,,ああ　
Dialogue: 0,0:42:19.14,0:42:20.71,Default,,0,0,0,,困ったことになりました
Dialogue: 0,0:42:20.71,0:42:22.27,Default,,0,0,0,,毎日のことがあったらどうしよう
Dialogue: 0,0:42:22.27,0:42:24.27,Default,,0,0,0,,毎日のこととおっしゃると
Dialogue: 0,0:42:25.00,0:42:27.32,Default,,0,0,0,,遠くて近くはダンジョの中
Dialogue: 0,0:42:27.32,0:42:29.92,Default,,0,0,0,,ああ近頃の若いものは気が早い
Dialogue: 0,0:42:29.92,0:42:31.44,Default,,0,0,0,,あらね
Dialogue: 0,0:42:31.44,0:42:31.97,Default,,0,0,0,,ながし
Dialogue: 0,0:42:31.97,0:42:35.51,Default,,0,0,0,,お身が悪いとも知らないで
Dialogue: 0,0:42:35.51,0:42:37.00,Default,,0,0,0,,お黒の手でも握ったら
Dialogue: 0,0:42:37.00,0:42:37.35,Default,,0,0,0,,いや
Dialogue: 0,0:42:37.35,0:42:38.88,Default,,0,0,0,,てぐらいならよろしいん
Dialogue: 0,0:42:39.71,0:42:41.70,Default,,0,0,0,,これはなるほど困ったな
Dialogue: 0,0:42:41.70,0:42:44.86,Default,,0,0,0,,とはいえ狸吉郎君には先ほどから
Dialogue: 0,0:42:44.86,0:42:47.71,Default,,0,0,0,,姫を夢見を手はえも
Dialogue: 0,0:42:47.71,0:42:50.04,Default,,0,0,0,,あの黒のことを起きにめし
Dialogue: 0,0:42:50.04,0:42:50.91,Default,,0,0,0,,ええ
Dialogue: 0,0:42:51.07,0:42:52.75,Default,,0,0,0,,これからいよいよご正式に
Dialogue: 0,0:42:52.75,0:42:54.32,Default,,0,0,0,,お見合いをなさるそうでございます
Dialogue: 0,0:42:54.42,0:42:56.70,Default,,0,0,0,,そこなくちゃいい
Dialogue: 0,0:42:56.70,0:42:57.40,Default,,0,0,0,,えっ
Dialogue: 0,0:42:57.87,0:43:00.04,Default,,0,0,0,,嫌なおかげでどうやらね
Dialogue: 0,0:43:03.04,0:43:05.24,Default,,0,0,0,,お黒ちゃん立ってみて
Dialogue: 0,0:43:05.24,0:43:06.32,Default,,0,0,0,,立って
Dialogue: 0,0:43:06.48,0:43:07.87,Default,,0,0,0,,わ、きれい
Dialogue: 0,0:43:07.87,0:43:10.30,Default,,0,0,0,,ああ　それで、できました
Dialogue: 0,0:43:10.30,0:43:12.98,Default,,0,0,0,,本当にみればみるほど瓜二つ（うりふたつ）
Dialogue: 0,0:43:12.98,0:43:15.14,Default,,0,0,0,,じゃ　お黒ちゃん　おめでちゃうよ
Dialogue: 0,0:43:15.54,0:43:16.73,Default,,0,0,0,,はい
Dialogue: 0,0:43:19.73,0:43:21.74,Default,,0,0,0,,まあ　よくは似合いね
Dialogue: 0,0:43:21.74,0:43:23.42,Default,,0,0,0,,まあ　ご立派ね
Dialogue: 0,0:43:23.42,0:43:24.95,Default,,0,0,0,,あっ、ご家老様が！
Dialogue: 0,0:43:28.25,0:43:31.04,Default,,0,0,0,,ああ　出来たて　出来たて　立派に出来ました
Dialogue: 0,0:43:31.04,0:43:32.74,Default,,0,0,0,,では若君さんもお待ちかね
Dialogue: 0,0:43:32.74,0:43:34.10,Default,,0,0,0,,早速お対面ということ
Dialogue: 0,0:43:34.10,0:43:36.28,Default,,0,0,0,,ああこれ \N さようなところ彼女はない
Dialogue: 0,0:43:36.28,0:43:38.43,Default,,0,0,0,,姫様のご品位にも関わります
Dialogue: 0,0:43:38.43,0:43:39.29,Default,,0,0,0,,これお黒
Dialogue: 0,0:43:39.90,0:43:41.40,Default,,0,0,0,,命を助けていただいた上に
Dialogue: 0,0:43:41.40,0:43:43.40,Default,,0,0,0,,たんまりご法律をいただくのだ
Dialogue: 0,0:43:43.40,0:43:45.30,Default,,0,0,0,,必ず尻尾な形出ねえぞ
Dialogue: 0,0:43:45.30,0:43:46.12,Default,,0,0,0,,はい
Dialogue: 0,0:43:46.82,0:43:49.14,Default,,0,0,0,,申し聞かせたご挨拶の言葉
Dialogue: 0,0:43:49.14,0:43:51.12,Default,,0,0,0,,必ず忘れては相成らぬ
Dialogue: 0,0:43:51.32,0:43:51.90,Default,,0,0,0,,はい
Dialogue: 0,0:43:52.08,0:43:53.02,Default,,0,0,0,,言うてみ
Dialogue: 0,0:43:53.11,0:43:53.82,Default,,0,0,0,,はい
Dialogue: 0,0:43:54.34,0:43:57.32,Default,,0,0,0,,小泉山家に置かれましては
Dialogue: 0,0:43:57.32,0:43:58.62,Default,,0,0,0,,ごかんをいよいよ
Dialogue: 0,0:43:59.10,0:43:59.84,Default,,0,0,0,,いよいよ
Dialogue: 0,0:43:59.84,0:44:00.80,Default,,0,0,0,,ご飯へ
Dialogue: 0,0:44:01.02,0:44:02.02,Default,,0,0,0,,ご飯へ
Dialogue: 0,0:44:02.32,0:44:05.11,Default,,0,0,0,,狸吉郎お君様におかれましても
Dialogue: 0,0:44:05.24,0:44:06.10,Default,,0,0,0,,なに　あの
Dialogue: 0,0:44:07.68,0:44:10.03,Default,,0,0,0,,なに御つがいもあらせられる
Dialogue: 0,0:44:10.03,0:44:10.63,Default,,0,0,0,,はい
Dialogue: 0,0:44:10.72,0:44:12.94,Default,,0,0,0,,なに御つがいもあらせられる
Dialogue: 0,0:44:12.94,0:44:13.80,Default,,0,0,0,,さようなところが格調だね
Dialogue: 0,0:44:13.80,0:44:21.10,Default,,0,0,0,,それにくれぐれも言っておくが そなたは一時のお身代わりだで
Dialogue: 0,0:44:21.10,0:44:24.81,Default,,0,0,0,,ほんの一時のお身代わりだで ただ何事もしかえめ
Dialogue: 0,0:44:25.98,0:44:27.09,Default,,0,0,0,,しかいめ 
Dialogue: 0,0:45:59.68,0:46:07.31,Default,,0,0,0,,山家に置かれましては ご観をいよいよご飯へ
Dialogue: 0,0:46:07.31,0:46:11.51,Default,,0,0,0,,狸白おぎみさまに置かれましても 何
Dialogue: 0,0:46:11.51,0:46:13.27,Default,,0,0,0,,何
Dialogue: 0,0:46:13.27,0:46:23.70,Default,,0,0,0,,下乗り それ何
Dialogue: 0,0:46:23.70,0:46:42.10,Default,,0,0,0,,つつがも荒らせられず鶴と亀の 何をんつつがも荒らせられず鶴亀の
Dialogue: 0,0:46:42.10,0:46:45.88,Default,,0,0,0,,鶴亀の御代　千代に八千代に御治世
Dialogue: 0,0:46:45.88,0:46:48.64,Default,,0,0,0,,お黒うれし 違う違う
Dialogue: 0,0:46:48.64,0:46:53.14,Default,,0,0,0,,木塚嬉しくお祝い申し上げます
Dialogue: 0,0:46:53.14,0:46:56.22,Default,,0,0,0,,木塚姫としたことが
Dialogue: 0,0:46:56.22,0:46:59.42,Default,,0,0,0,,さあ そんな肩苦しい挨拶は抜きにして
Dialogue: 0,0:46:59.42,0:47:01.56,Default,,0,0,0,,まあもったいない若君様
Dialogue: 0,0:47:01.56,0:47:10.94,Default,,0,0,0,,なぜ逃げる気ぬために
Dialogue: 0,0:47:03.04,0:47:04.46,Default,,0,0,0,,いいえあの私
Dialogue: 0,0:47:05.07,0:47:05.95,Default,,0,0,0,,姫
Dialogue: 0,0:47:10.94,0:47:23.22,Default,,0,0,0,,気ぬた姫私は私はお身代わり いい
Dialogue: 0,0:47:23.22,0:47:24.94,Default,,0,0,0,,私は嬉しくて
Dialogue: 0,0:47:25.42,0:47:26.38,Default,,0,0,0,,姫
Dialogue: 0,0:47:27.93,0:47:29.64,Default,,0,0,0,,___さま
Dialogue: 0,0:47:30.39,0:47:32.68,Default,,0,0,0,,狸吉郎は幸せじゃ
Dialogue: 0,0:47:46.09,0:47:49.36,Default,,0,0,0,,姫 春雨が
Dialogue: 0,0:51:03.42,0:51:08.60,Default,,0,0,0,,虹ばん星星見つけば
Dialogue: 0,0:51:03.42,0:51:08.60,Note,,0,0,0,,When the rainbow-colored stars appear,
Dialogue: 0,0:51:09.05,0:51:14.86,Default,,0,0,0,,にばん星星見つけば
Dialogue: 0,0:51:09.05,0:51:14.86,Note,,0,0,0,,When the evening stars appear
Dialogue: 0,0:51:30.86,0:51:35.86,Note,,0,0,0,,
Dialogue: 0,0:52:26.77,0:52:32.71,Default,,0,0,0,,木下姫が家でし \Nてどうやらいうことになるところ 
Dialogue: 0,0:52:30.58,0:52:32.71,Default,,0,0,0,,おめえの身代わりで助かってよ
Dialogue: 0,0:52:32.71,0:52:34.83,Default,,0,0,0,,また飲んでんのねお父さん
Dialogue: 0,0:52:34.83,0:52:36.86,Default,,0,0,0,,それってみもうご用済んだのか
Dialogue: 0,0:52:37.95,0:52:42.21,Default,,0,0,0,,さっき若君様は小包山へお帰りになったもの
Dialogue: 0,0:52:42.21,0:52:44.91,Default,,0,0,0,,お帰りになれば用なしか
Dialogue: 0,0:52:44.91,0:52:48.63,Default,,0,0,0,,そりゃそうよ \N 私は一時のお身代わり
Dialogue: 0,0:52:48.63,0:52:50.59,Default,,0,0,0,,馬鹿野郎
Dialogue: 0,0:52:50.59,0:52:52.67,Default,,0,0,0,,おい　お黒
Dialogue: 0,0:52:52.67,0:52:54.16,Default,,0,0,0,,若君はおめえに
Dialogue: 0,0:52:54.27,0:52:56.19,Default,,0,0,0,,ジョッコ置きしまったって言いじゃねえか
Dialogue: 0,0:52:56.19,0:52:57.82,Default,,0,0,0,,下品のとっちゃん
Dialogue: 0,0:52:58.32,0:53:00.39,Default,,0,0,0,,それだけ飲んだらもう寝ましょうね
Dialogue: 0,0:53:01.31,0:53:03.27,Default,,0,0,0,,さすがにおめぇ俺の子だ
Dialogue: 0,0:53:03.66,0:53:06.35,Default,,0,0,0,,上手く若いみを垂らし込んだよな
Dialogue: 0,0:53:06.35,0:53:09.47,Default,,0,0,0,,何言ってんのよとっちゃん
Dialogue: 0,0:53:09.47,0:53:11.17,Default,,0,0,0,,ご家労様のおっしゃる通り
Dialogue: 0,0:53:11.80,0:53:13.87,Default,,0,0,0,,私はほんの一時のお見代わり
Dialogue: 0,0:53:14.91,0:53:16.77,Default,,0,0,0,,お家でなさった姫君が
Dialogue: 0,0:53:17.17,0:53:19.18,Default,,0,0,0,,御殿にお戻りになるその日まで
Dialogue: 0,0:53:21.08,0:53:22.65,Default,,0,0,0,,私は一時のお見代わり
Dialogue: 0,0:53:22.65,0:53:27.24,Default,,0,0,0,,何御殿を飛び出すようなそんな不良権の姫君は今頃
Dialogue: 0,0:53:27.24,0:53:31.48,Default,,0,0,0,,どっかのものあてで犬でも \N 噛みつかれて死ぬれ
Dialogue: 0,0:53:31.48,0:53:33.38,Default,,0,0,0,,なお黒
Dialogue: 0,0:53:33.38,0:53:35.18,Default,,0,0,0,,もし万が一そうなりゃ
Dialogue: 0,0:53:35.18,0:53:38.50,Default,,0,0,0,,お目は差し詰め若君のたぬきちょろの
Dialogue: 0,0:53:38.50,0:53:40.14,Default,,0,0,0,,奥方よ
Dialogue: 0,0:53:40.14,0:53:42.54,Default,,0,0,0,,お父ちゃんって何を言うの
Dialogue: 0,0:53:42.54,0:53:44.46,Default,,0,0,0,,それと言うのもお目がよ
Dialogue: 0,0:53:44.46,0:53:47.74,Default,,0,0,0,,本当にお父ちゃんって\Nどうしてそんな悪いことばっかいたくらむの
Dialogue: 0,0:53:56.75,0:54:05.48,Default,,0,0,0,,やけど 切り傷 しょくあたり
Dialogue: 0,0:54:05.48,0:54:14.11,Default,,0,0,0,,ししゃくしびょうの ききぐすり
Dialogue: 0,0:54:14.11,0:54:22.11,Default,,0,0,0,,なぜに聞かない って はらぐろに
Dialogue: 0,0:54:30.80,0:54:34.09,Default,,0,0,0,,あ　栗助さん　いつものお薬くださいな
Dialogue: 0,0:54:34.74,0:54:36.53,Default,,0,0,0,,まだ痛むのかよ おとくちゃん
Dialogue: 0,0:54:36.53,0:54:37.05,Default,,0,0,0,,え
Dialogue: 0,0:54:37.16,0:54:38.54,Default,,0,0,0,,お酒ばかり飲むからよ
Dialogue: 0,0:54:38.63,0:54:41.97,Default,,0,0,0,,待ってろ! \N お黒ちゃん!
Dialogue: 0,0:54:41.97,0:54:43.54,Default,,0,0,0,,やめへん!
Dialogue: 0,0:54:54.00,0:55:00.05,Default,,0,0,0,,とてもさみしい
Dialogue: 0,0:55:00.05,0:55:05.69,Default,,0,0,0,,帰り道
Dialogue: 0,0:55:06.43,0:55:12.28,Default,,0,0,0,,赤い木の実が
Dialogue: 0,0:55:13.03,0:55:18.77,Default,,0,0,0,,落ちてくる
Dialogue: 0,0:55:19.16,0:55:21.67,Default,,0,0,0,,あの子も
Dialogue: 0,0:55:21.67,0:55:25.71,Default,,0,0,0,,敵と思うくせ
Dialogue: 0,0:55:25.71,0:55:31.50,Default,,0,0,0,,明日まさくく
Dialogue: 0,0:55:31.50,0:55:37.50,Default,,0,0,0,,風に泣く
Dialogue: 0,0:55:37.50,0:55:44.41,Default,,0,0,0,,落ち葉こそ頃
Dialogue: 0,0:55:44.41,0:55:51.91,Default,,0,0,0,,この道小道
Dialogue: 0,0:55:59.63,0:56:01.43,Default,,0,0,0,,今ころは
Dialogue: 0,0:56:01.79,0:56:04.64,Default,,0,0,0,,お家出なされた姫様には
Dialogue: 0,0:56:04.64,0:56:07.54,Default,,0,0,0,,いずこの空でこの月を
Dialogue: 0,0:56:07.54,0:56:11.08,Default,,0,0,0,,思うまい　思うまい \N or 思わない 思わない
Dialogue: 0,0:56:13.76,0:56:14.69,Default,,0,0,0,,狸吉郎
Dialogue: 0,0:56:16.18,0:56:18.58,Default,,0,0,0,,あれはまさしく小泉山
Dialogue: 0,0:56:19.18,0:56:22.18,Default,,0,0,0,,狸吉郎おお君の御行列
Dialogue: 0,0:56:40.18,0:56:42.54,Default,,0,0,0,,確かに狸路御行列
Dialogue: 0,0:56:42.64,0:56:45.28,Default,,0,0,0,,これは困ったな
Dialogue: 0,0:56:45.28,0:56:47.67,Default,,0,0,0,,こうひめじめ通われては
Dialogue: 0,0:56:48.54,0:56:51.54,Default,,0,0,0,,ご家老　われお聞きなさいませ
Dialogue: 0,0:56:48.54,0:56:51.54,Note,,0,0,0,,家老 (karō) = Chief Retainer
Dialogue: 0,0:56:51.39,0:56:52.35,Default,,0,0,0,,狸吉郎おぎみ
Dialogue: 0,0:56:52.35,0:56:53.68,Default,,0,0,0,,不意のおなりでございます
Dialogue: 0,0:56:53.68,0:56:54.92,Default,,0,0,0,,いかんがいたそう
Dialogue: 0,0:56:54.92,0:56:56.44,Default,,0,0,0,,よわったな
Dialogue: 0,0:56:56.30,0:56:57.83,Default,,0,0,0,,まだ姫君様のおゆくへ
Dialogue: 0,0:56:57.83,0:56:58.90,Default,,0,0,0,,もわからんというの
Dialogue: 0,0:56:58.90,0:57:00.18,Default,,0,0,0,,いたしかったことがありません
Dialogue: 0,0:57:00.18,0:57:01.98,Default,,0,0,0,,もう一度だけお身代わりで
Dialogue: 0,0:57:01.98,0:57:03.78,Default,,0,0,0,,お家の大事じゃ絶品もない
Dialogue: 0,0:57:03.78,0:57:06.82,Default,,0,0,0,,誰かあるお黒のところへ休止を立て
Dialogue: 0,0:57:06.82,0:57:08.22,Default,,0,0,0,,かしこまりました
Dialogue: 0,0:57:10.82,0:57:13.42,Default,,0,0,0,,ただいま狸吉郎のみにお月でございます
Dialogue: 0,0:57:13.42,0:57:15.46,Default,,0,0,0,,もうついた？ああ　よかったな
Dialogue: 0,0:57:15.46,0:57:16.90,Default,,0,0,0,,お月になるなりもう
Dialogue: 0,0:57:16.90,0:57:18.42,Default,,0,0,0,,きぬた姫きぬた姫と
Dialogue: 0,0:57:18.42,0:57:20.30,Default,,0,0,0,,いかんがいたそうよかったな
Dialogue: 0,0:57:20.30,0:57:21.74,Default,,0,0,0,,お黒が到着いたすまで
Dialogue: 0,0:57:21.91,0:57:23.26,Default,,0,0,0,,なんとかつないでおかなくて
Dialogue: 0,0:57:23.26,0:57:26.36,Default,,0,0,0,,もう私たちの踊りなどお目もくれになりません
Dialogue: 0,0:57:26.45,0:57:28.49,Default,,0,0,0,,よしでは今日は試行変え
Dialogue: 0,0:58:58.76,0:58:59.76,Note,,0,0,0,,Lady with freather-fan
Dialogue: 0,1:00:05.40,1:00:16.46,Default,,0,0,0,,有名なさ有名でいいけれど
Dialogue: 0,1:00:18.28,1:00:24.99,Default,,0,0,0,,思い続けて　思い続けて
Dialogue: 0,1:00:24.99,1:00:30.68,Default,,0,0,0,,あの日続けて
Dialogue: 0,1:00:31.61,1:00:37.79,Default,,0,0,0,,森は林を吹く風を
Dialogue: 0,1:00:37.79,1:00:44.65,Default,,0,0,0,,いいけれど一人で
Dialogue: 0,1:01:45.17,1:01:50.06,Default,,0,0,0,,一つ目　二つ目
Dialogue: 0,1:01:50.06,1:01:53.06,Default,,0,0,0,,狐のようこそ
Dialogue: 0,1:01:55.61,1:01:59.88,Default,,0,0,0,,人やな娘
Dialogue: 0,1:00:44.56,1:00:46.56,Default,,0,0,0,,はいている
Dialogue: 0,1:03:03.42,1:06:37.42,Default,,0,0,0,,何を泣くのだきぬた姫 幸せに泣けてきて幸せ
Dialogue: 0,1:03:03.42,1:06:37.42,Default,,0,0,0,,何を泣くのだきぬた姫 幸せに泣けてきて幸せ
Dialogue: 0,1:03:09.44,1:03:11.59,Default,,0,0,0,,私のような癒しいもの
Dialogue: 0,1:03:11.95,1:03:13.77,Default,,0,0,0,,こうして一生に
Dialogue: 0,1:03:13.77,1:03:16.56,Default,,0,0,0,,一度で二度ではない
Dialogue: 0,1:03:18.84,1:03:28.71,Default,,0,0,0,,そなたを生涯の妻として いつまでもこうして離れません
Dialogue: 0,1:03:28.71,1:03:33.99,Default,,0,0,0,,姫 この世に花の咲く限り
Dialogue: 0,1:03:33.99,1:03:39.39,Default,,0,0,0,,この世に月の刺す限り この世に二人のある限り
Dialogue: 0,1:03:39.39,1:03:41.71,Default,,0,0,0,,このたぬきちろうの心は一つ
Dialogue: 0,1:03:41.71,1:03:46.43,Default,,0,0,0,,なぜにこの私を
Dialogue: 0,1:03:46.43,1:03:57.21,Default,,0,0,0,,何遠慮なんかすることはね
Dialogue: 0,1:03:46.43,1:03:57.21,Default,,0,0,0,,さあ契機よくやってくれ
Dialogue: 0,1:03:57.21,1:03:59.21,Default,,0,0,0,,おめでとう
Dialogue: 0,1:03:59.21,1:04:02.21,Default,,0,0,0,,こうなったらまあ、お黒も食うくり
Dialogue: 0,1:04:02.21,1:04:04.21,Default,,0,0,0,,若気みさまの奥方よ
Dialogue: 0,1:04:04.21,1:04:06.21,Default,,0,0,0,,グッド親分目と出たね
Dialogue: 0,1:04:06.21,1:04:08.21,Default,,0,0,0,,誰だと思ってんだよ
Dialogue: 0,1:04:08.21,1:04:12.21,Default,,0,0,0,,カチカチ山のドロエモン様よ
Dialogue: 0,1:04:12.21,1:04:16.21,Default,,0,0,0,,それじゃ今日は前祝いに、一つ契機よく
Dialogue: 0,1:04:16.21,1:05:02.02,Default,,0,0,0,,の花咲くぞろえもんなる 黒が御座れなさる
Dialogue: 0,1:05:02.02,1:06:05.86,Default,,0,0,0,,もほんわたさまにどこでしやねん
Dialogue: 0,1:06:05.86,1:06:06.58,Default,,0,0,0,,どうしたんで
Dialogue: 0,1:06:06.58,1:06:10.34,Default,,0,0,0,,実は 実は親分 こういうわけだ
Dialogue: 0,1:06:10.34,1:06:14.58,Default,,0,0,0,,ええ 木下姫が消えてきた
Dialogue: 0,1:06:14.58,1:06:16.90,Default,,0,0,0,,ええ 明日も何気なく行きあって
Dialogue: 0,1:06:16.90,1:06:19.78,Default,,0,0,0,,中途行ける女だからね
Dialogue: 0,1:06:16.90,1:06:19.78,Default,,0,0,0,,カチヤーなんて言っちゃって
Dialogue: 0,1:06:19.78,1:06:22.58,Default,,0,0,0,,馬鹿野郎 女と見ればすぐそれだ
Dialogue: 0,1:06:22.58,1:06:26.26,Default,,0,0,0,,すいません で ちょいとこう顔を覗いてみたんですが
Dialogue: 0,1:06:26.26,1:06:31.69,Default,,0,0,0,,うん、覗いてみて驚いた
Dialogue: 0,1:07:04.58,1:07:13.13,Default,,0,0,0,,御殿を飛び出してから
Dialogue: 0,1:07:04.58,1:07:13.13,Default,,0,0,0,,うどのくらいになるかしら
Dialogue: 0,1:07:13.13,1:07:16.63,Default,,0,0,0,,思えば私も馬鹿だった
Dialogue: 0,1:07:16.63,1:07:19.63,Default,,0,0,0,,わずかばかりの自分の力
Dialogue: 0,1:07:19.63,1:07:24.63,Default,,0,0,0,,自分の姿形に上られて 私の夫は人間だなんて
Dialogue: 0,1:07:24.63,1:07:31.68,Default,,0,0,0,,とんでもない夢を見て
Dialogue: 0,1:07:24.63,1:07:31.68,Default,,0,0,0,,五天を飛び出したまではよかったが
Dialogue: 0,1:07:31.68,1:07:38.68,Default,,0,0,0,,私に化かされる人間なんて
Dialogue: 0,1:07:31.68,1:07:38.68,Default,,0,0,0,,ただの一人もいなかったじゃないか
Dialogue: 0,1:07:38.68,1:07:57.02,Default,,0,0,0,,花の五天の日になびく 銀の花の美しや
Dialogue: 0,1:07:57.02,1:08:04.02,Default,,0,0,0,,たぬきばやしのおもしろさ
Dialogue: 0,1:08:04.02,1:08:14.52,Default,,0,0,0,,うてかえおじゃなし
Dialogue: 0,1:08:14.52,1:09:47.40,Default,,0,0,0,,なるほど
Dialogue: 0,1:09:47.40,1:09:48.40,Default,,0,0,0,,おくるちゃんじゃそっくりだが
Dialogue: 0,1:09:48.40,1:09:50.40,Default,,0,0,0,,こうまんつきなこのつぐら
Dialogue: 0,1:09:50.40,1:09:52.40,Default,,0,0,0,,きぬたひめにちげえねえや
Dialogue: 0,1:09:52.40,1:09:53.40,Default,,0,0,0,,いかにも私はきぬたひめ
Dialogue: 0,1:09:53.40,1:09:56.40,Default,,0,0,0,,今日久しぶりにこの山へ戻ってきて
Dialogue: 0,1:09:56.40,1:09:58.40,Default,,0,0,0,,その戻ってきたないけねえんだよ
Dialogue: 0,1:09:58.40,1:09:59.40,Default,,0,0,0,,おめえに今さらけやられたんじゃ
Dialogue: 0,1:09:59.40,1:10:01.40,Default,,0,0,0,,おくるちゃんの出世の邪魔になり
Dialogue: 0,1:10:01.40,1:10:03.40,Default,,0,0,0,,取らぬタネキの風よだよ
Dialogue: 0,1:10:03.40,1:10:04.40,Default,,0,0,0,,だから私はどうすんの
Dialogue: 0,1:10:04.40,1:10:06.40,Default,,0,0,0,,ええ! 死ぬ方の言わさず
Dialogue: 0,1:10:06.40,1:10:07.40,Default,,0,0,0,,つじめい!
Dialogue: 0,1:10:39.82,1:11:28.64,Default,,0,0,0,,これが本物だか? 別れしにやり直す
Dialogue: 0,1:11:28.64,1:11:30.64,Default,,0,0,0,,しゃーねー! 好きな奴にかかってきー!
Dialogue: 0,1:11:30.64,1:11:32.64,Default,,0,0,0,,よしだ!
Dialogue: 0,1:11:33.64,1:11:36.64,Default,,0,0,0,,野郎どもいつまで手間取ってやる
Dialogue: 0,1:11:36.64,1:11:39.64,Default,,0,0,0,,かまぁ どうせこうなったら
Dialogue: 0,1:11:39.64,1:11:42.64,Default,,0,0,0,,お黒は若い日々の奥のあたり
Dialogue: 0,1:11:42.64,1:11:48.66,Default,,0,0,0,,こっちは差し詰め御飲酒の泥えもんの神ってところだ
Dialogue: 0,1:11:48.66,1:11:52.06,Default,,0,0,0,,どうやらうーやーまあ
Dialogue: 0,1:11:52.06,1:11:53.98,Default,,0,0,0,,だるい
Dialogue: 0,1:11:53.98,1:11:56.90,Default,,0,0,0,,お黒か
Dialogue: 0,1:11:56.90,1:11:58.06,Default,,0,0,0,,ちょっと
Dialogue: 0,1:11:58.06,1:11:59.86,Default,,0,0,0,,お願いのものですけど
Dialogue: 0,1:11:59.86,1:12:03.38,Default,,0,0,0,,だだだだ取り込んでるから今はダメだ
Dialogue: 0,1:12:03.38,1:12:05.42,Default,,0,0,0,,ゆきくれって
Dialogue: 0,1:12:05.42,1:12:08.62,Default,,0,0,0,,何重している旅のもの
Dialogue: 0,1:12:08.62,1:12:11.18,Default,,0,0,0,,一夜の宿のお情けに
Dialogue: 0,1:12:11.18,1:12:13.18,Default,,0,0,0,,おすがりしたいと思いまして
Dialogue: 0,1:12:13.18,1:12:15.18,Default,,0,0,0,,俺んとこは宿じゃねえ
Dialogue: 0,1:12:15.18,1:12:17.18,Default,,0,0,0,,どこのものだか知らねえ
Dialogue: 0,1:12:17.18,1:12:19.18,Default,,0,0,0,,その辺にほら穴があるからよ
Dialogue: 0,1:12:19.18,1:12:23.18,Default,,0,0,0,,いいえ 決して怪しいものではございません
Dialogue: 0,1:12:23.18,1:12:26.18,Default,,0,0,0,,わけあってたぬきごてんを飛び出した
Dialogue: 0,1:12:26.18,1:12:30.18,Default,,0,0,0,,きぬたと申す愚か者
Dialogue: 0,1:12:30.18,1:12:32.18,Default,,0,0,0,,きぬた?
Dialogue: 0,1:12:32.18,1:12:34.18,Default,,0,0,0,,心柄とは言いながら
Dialogue: 0,1:12:34.18,1:12:36.18,Default,,0,0,0,,諸国をさまよい歩いた末
Dialogue: 0,1:12:36.18,1:12:39.18,Default,,0,0,0,,ようやくふるさとへ帰ってきて
Dialogue: 0,1:12:39.18,1:12:42.34,Default,,0,0,0,,いいえ帰ってくるなり今そこ
Dialogue: 0,1:12:42.59,1:12:44.87,Default,,0,0,0,,大勢の悪者に取り巻かれ
Dialogue: 0,1:12:45.18,1:12:47.18,Default,,0,0,0,,ようやく逃れはしたものの
Dialogue: 0,1:12:47.18,1:12:50.58,Default,,0,0,0,,君たち
Dialogue: 0,1:12:50.58,1:12:53.58,Default,,0,0,0,,いいえ今はもうただの女です
Dialogue: 0,1:12:53.58,1:12:57.79,Default,,0,0,0,,お助けくださいまし
Dialogue: 0,1:12:57.79,1:12:58.79,Default,,0,0,0,,悪い者に追いかけられ
Dialogue: 0,1:12:58.79,1:12:59.79,Default,,0,0,0,,へいへい
Dialogue: 0,1:12:59.79,1:13:00.79,Default,,0,0,0,,おい手立ちどれ
Dialogue: 0,1:13:00.79,1:13:01.79,Default,,0,0,0,,うそろい
Dialogue: 0,1:13:01.79,1:13:02.79,Default,,0,0,0,,はい
Dialogue: 0,1:13:05.79,1:13:07.79,Default,,0,0,0,,知らぬこととは言いながら
Dialogue: 0,1:13:07.79,1:13:08.79,Default,,0,0,0,,失礼を申し上げて
Dialogue: 0,1:13:08.79,1:13:09.79,Default,,0,0,0,,え
Dialogue: 0,1:13:09.79,1:13:10.79,Default,,0,0,0,,そんな親同
Dialogue: 0,1:13:10.79,1:13:13.79,Default,,0,0,0,,いいえもうこんなうさ苦しい暴れでよろしくはしたら
Dialogue: 0,1:13:13.79,1:13:15.79,Default,,0,0,0,,さあどうぞご縁じゃなくて
Dialogue: 0,1:13:15.79,1:13:16.79,Default,,0,0,0,,ありがとうございます
Dialogue: 0,1:13:16.79,1:13:17.79,Default,,0,0,0,,ええとあんでもねえ
Dialogue: 0,1:13:17.79,1:13:21.80,Default,,0,0,0,,見ればお疲れの御用さえ
Dialogue: 0,1:13:21.80,1:13:22.80,Default,,0,0,0,,それじゃそうだ
Dialogue: 0,1:13:22.80,1:13:25.80,Default,,0,0,0,,上を上がりになって一休み横におなりなせたらいいや
Dialogue: 0,1:13:25.80,1:13:27.80,Default,,0,0,0,,ありがとうございます
Dialogue: 0,1:13:27.80,1:13:29.80,Default,,0,0,0,,いろいろとご親切にと
Dialogue: 0,1:13:29.80,1:13:30.80,Default,,0,0,0,,なあに
Dialogue: 0,1:13:30.80,1:13:32.80,Default,,0,0,0,,とんでひねる
Dialogue: 0,1:14:12.65,1:14:15.13,Default,,0,0,0,,また会うその日はこんれいも
Dialogue: 0,1:14:14.26,1:14:20.80,Default,,0,0,0,,沐木散郎
Dialogue: 0,1:14:20.80,1:14:23.80,Default,,0,0,0,,もうそなたなしでは一日も
Dialogue: 0,1:14:23.80,1:14:25.80,Default,,0,0,0,,若気美様
Dialogue: 0,1:14:25.80,1:14:50.62,Default,,0,0,0,,私はおみがわり
Dialogue: 0,1:14:50.62,1:14:58.90,Default,,0,0,0,,ありがてぃぐっすり寝込んでやが
Dialogue: 0,1:14:58.90,1:15:02.50,Default,,0,0,0,,今更本物にだらちゃう
Dialogue: 0,1:15:02.50,1:15:04.50,Default,,0,0,0,,おころの出世の妨げだ
Dialogue: 0,1:15:04.50,1:15:45.96,Default,,0,0,0,,また何か悪いことしてんのね
Dialogue: 0,1:15:45.96,1:15:47.96,Default,,0,0,0,,親の心をこしらせた
Dialogue: 0,1:15:47.96,1:15:49.96,Default,,0,0,0,,おころ
Dialogue: 0,1:15:49.96,1:15:54.45,Default,,0,0,0,,え?今上でお休みなの?
Dialogue: 0,1:15:54.45,1:15:56.45,Default,,0,0,0,,旅の疲れでぐっすると
Dialogue: 0,1:15:56.45,1:15:58.45,Default,,0,0,0,,まあ
Dialogue: 0,1:15:58.45,1:15:59.45,Default,,0,0,0,,いいってことよ
Dialogue: 0,1:15:59.45,1:16:01.45,Default,,0,0,0,,悪いようにしねからお父さんにし
Dialogue: 0,1:16:01.45,1:16:02.45,Default,,0,0,0,,静かにお父さん
Dialogue: 0,1:16:02.45,1:16:04.45,Default,,0,0,0,,それにお父さん一人じゃ危ないし
Dialogue: 0,1:16:04.45,1:16:06.45,Default,,0,0,0,,私は先に様子を見てくるわ
Dialogue: 0,1:16:06.45,1:16:08.45,Default,,0,0,0,,じゃあおめぇ手助けをそろって
Dialogue: 0,1:16:08.45,1:16:11.45,Default,,0,0,0,,そりゃそうよ私の出世のためだもんな
Dialogue: 0,1:16:11.45,1:16:14.45,Default,,0,0,0,,じゃあお父さんはここで一杯飲んで待っててよ
Dialogue: 0,1:16:14.45,1:16:16.45,Default,,0,0,0,,じゃあ俺はここで一杯飲んで待ってるから
Dialogue: 0,1:16:16.45,1:16:18.45,Default,,0,0,0,,その間に私が様子を見て
Dialogue: 0,1:16:18.45,1:16:20.45,Default,,0,0,0,,もしよかったらその枝にこの前影をかけとくから
Dialogue: 0,1:16:20.45,1:16:22.45,Default,,0,0,0,,よしこの前影が
Dialogue: 0,1:16:22.45,1:16:25.45,Default,,0,0,0,,あの枝にかかってたら忍び込んでもいいんだよな
Dialogue: 0,1:16:25.45,1:16:26.45,Default,,0,0,0,,その時もしよかった
Dialogue: 0,1:16:26.45,1:16:28.45,Default,,0,0,0,,
Dialogue: 0,1:16:28.45,1:16:30.45,Default,,0,0,0,,
Dialogue: 0,1:16:30.45,1:16:32.45,Default,,0,0,0,,お父さんはここで一杯飲んで待ってて
Dialogue: 0,1:16:32.45,1:16:37.77,Default,,0,0,0,,こんでもいいんだよな
Dialogue: 0,1:16:33.56,1:16:35.54,Default,,0,0,0,,その時こそバッサイね
Dialogue: 0,1:16:37.77,1:16:41.85,Default,,0,0,0,,ええええええ ってめえ逃すんじゃあるめえな
Dialogue: 0,1:16:37.77,1:16:41.85,Default,,0,0,0,,ええええええ ってめえ逃すんじゃあるめえな
Dialogue: 0,1:16:41.85,1:16:45.13,Default,,0,0,0,,言ってんだよとっさん 私はとっさんの子じゃないの
Dialogue: 0,1:16:45.13,1:16:54.84,Default,,0,0,0,,この野郎 いいたぬ気になれやがった
Dialogue: 0,1:16:54.84,1:17:00.96,Default,,0,0,0,,持つべきものは我が子だと
Dialogue: 0,1:17:00.96,1:17:07.12,Default,,0,0,0,,機嫌なおして腹づつみ
Dialogue: 0,1:17:07.12,1:17:16.31,Default,,0,0,0,,ちょいとやぶんどろいやー
Dialogue: 0,1:17:16.31,1:17:19.27,Default,,0,0,0,,はすれ
Dialogue: 0,1:17:19.27,1:18:27.21,Default,,0,0,0,,はるだくみ
Dialogue: 0,1:18:27.21,1:18:38.20,Default,,0,0,0,,てめえ追い返せたんじゃ心の姿勢の邪魔になるんだ
Dialogue: 0,1:18:38.20,1:18:43.47,Default,,0,0,0,,はい
Dialogue: 0,1:18:43.47,1:19:00.88,Default,,0,0,0,,なんだ何を抜けちゃうんでいいかんじょん
Dialogue: 0,1:19:00.88,1:19:15.95,Default,,0,0,0,,だんだん
Dialogue: 0,1:19:15.95,1:19:16.75,Default,,0,0,0,,なっ
Dialogue: 0,1:19:16.75,1:19:18.98,Default,,0,0,0,,ですよ
Dialogue: 0,1:19:18.98,1:19:19.98,Default,,0,0,0,,何を言ってんだこの野郎
Dialogue: 0,1:19:19.98,1:19:20.80,Default,,0,0,0,,お父さん
Dialogue: 0,1:19:20.80,1:19:22.16,Default,,0,0,0,,なっやかまして
Dialogue: 0,1:19:22.16,1:19:22.74,Default,,0,0,0,,お父さん
Dialogue: 0,1:19:22.74,1:19:25.00,Default,,0,0,0,,__
Dialogue: 0,1:20:12.66,1:20:14.20,Default,,0,0,0,,にかけて
Dialogue: 0,1:20:14.20,1:20:22.98,Default,,0,0,0,,私と切られたのは 私だったからよかったのよ
Dialogue: 0,1:20:22.98,1:20:25.98,Default,,0,0,0,,私はお父さんの子です
Dialogue: 0,1:20:25.98,1:20:31.02,Default,,0,0,0,,お父さんに切られたって痛くない
Dialogue: 0,1:20:31.02,1:20:34.06,Default,,0,0,0,,もしこれが他の方だった
Dialogue: 0,1:20:34.06,1:20:35.66,Default,,0,0,0,,お父さん恨むわよ
Dialogue: 0,1:20:35.66,1:20:39.16,Default,,0,0,0,,おお黒許してくれ お父さん悪かった
Dialogue: 0,1:20:39.70,1:20:43.66,Default,,0,0,0,,これでも悪いことはやめるわね
Dialogue: 0,1:20:42.82,1:20:43.14,Default,,0,0,0,,はい
Dialogue: 0,1:20:43.66,1:20:46.66,Default,,0,0,0,,分かった \N よく分かった
Dialogue: 0,1:20:46.66,1:20:48.07,Default,,0,0,0,,カチカチ山の泥も
Dialogue: 0,1:20:48.43,1:20:50.34,Default,,0,0,0,,今日から心を入れていて
Dialogue: 0,1:20:51.38,1:20:54.46,Default,,0,0,0,,お黒　嬉しい
Dialogue: 0,1:20:56.63,1:20:57.83,Default,,0,0,0,,お父さん
Dialogue: 0,1:20:58.02,1:21:01.14,Default,,0,0,0,,お黒　しっかりしてくれるよ
Dialogue: 0,1:21:02.84,1:21:04.49,Default,,0,0,0,,あの吉郎様が笑って
Dialogue: 0,1:21:05.58,1:21:07.35,Default,,0,0,0,,私を抱いてくださる
Dialogue: 0,1:21:09.02,1:21:11.78,Default,,0,0,0,,でもお黒ではダメだわね
Dialogue: 0,1:21:11.78,1:21:15.94,Default,,0,0,0,,私は一時のおみがわりだった
Dialogue: 0,1:21:15.94,1:21:17.83,Default,,0,0,0,,死ぬまでお身がわりだったのね
Dialogue: 0,1:21:17.83,1:21:20.83,Default,,0,0,0,,お　お黒
Dialogue: 0,1:21:23.69,1:21:28.41,Default,,0,0,0,,お月様今度生まれてくる時は
Dialogue: 0,1:21:28.41,1:21:31.30,Default,,0,0,0,,姫君様なのにません
Dialogue: 0,1:21:32.40,1:21:35.93,Default,,0,0,0,,お黒　死ぬんじゃねーぞ
Dialogue: 0,1:21:37.68,1:21:38.93,Default,,0,0,0,,music
Dialogue: 0,1:21:47.06,1:21:55.77,Default,,0,0,0,,いやーけど切り傷 ショックああ
Dialogue: 0,1:21:55.77,1:22:04.31,Default,,0,0,0,,シーシャークし秒 どうも聞き
Dialogue: 0,1:22:04.31,1:22:08.03,Default,,0,0,0,,なぜに効かない
Dialogue: 0,1:22:08.03,1:22:17.77,Default,,0,0,0,,おくろちゃんとってもよく聞いたわ 傷薬
Dialogue: 0,1:22:17.77,1:22:20.77,Default,,0,0,0,,そりゃそうさ 根酢に作った薬だもん
Dialogue: 0,1:22:20.77,1:22:21.77,Default,,0,0,0,,黙ってろ
Dialogue: 0,1:22:21.77,1:22:23.77,Default,,0,0,0,,あら 根酢に
Dialogue: 0,1:22:23.77,1:22:26.77,Default,,0,0,0,,おくろちゃん
Dialogue: 0,1:22:26.77,1:22:30.88,Default,,0,0,0,,お父さんの土地なのかい
Dialogue: 0,1:22:30.88,1:22:35.88,Default,,0,0,0,,たむきごてんに行ったわよ 姫君様のご婚礼
Dialogue: 0,1:22:35.88,1:22:38.88,Default,,0,0,0,,おくろちゃんの婚礼は 何なりと
Dialogue: 0,1:22:38.88,1:22:39.88,Default,,0,0,0,,生まれたら
Dialogue: 0,1:22:39.88,1:23:10.17,Default,,0,0,0,,生まれたら
Dialogue: 0,1:23:10.17,1:23:15.77,Default,,0,0,0,,た生まれたらお黒という名をつけて
