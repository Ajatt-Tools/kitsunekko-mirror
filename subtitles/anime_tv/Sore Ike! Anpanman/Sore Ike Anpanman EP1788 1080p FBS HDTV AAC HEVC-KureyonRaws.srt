1
00:00:05,038 --> 00:00:25,058
♬〜

2
00:00:25,058 --> 00:00:45,078
♬〜

3
00:00:45,078 --> 00:01:05,032
♬〜

4
00:01:05,032 --> 00:01:14,032
♬〜

5
00:01:29,022 --> 00:01:30,957
(ようせいバック)
♪〜 フンフフン フフ〜ン

6
00:01:30,957 --> 00:01:34,961
♪〜 フンフフッフフ〜
フッフッフ〜…

7
00:01:34,961 --> 00:01:37,961
(ばいきんまん) まてまて〜！
ん？ あっ！

8
00:01:40,967 --> 00:01:42,969
(ぶたまんまん) ブヒブヒ〜！

9
00:01:42,969 --> 00:01:45,472
ぶたまんまん！
ぶたまん よこせ〜！

10
00:01:45,472 --> 00:01:47,974
やめるブヒ〜！

11
00:01:47,974 --> 00:01:50,974
よこせ〜！
ブヒ〜⁉

12
00:01:51,995 --> 00:01:53,480
ブヒ⁉

13
00:01:53,480 --> 00:01:55,982
さぁ おとなしく わたさないと…｡

14
00:01:55,982 --> 00:01:58,985
うぅ！ わかったブヒ｡

15
00:01:58,985 --> 00:02:01,488
グフ〜！ いただきま〜す！

16
00:02:01,488 --> 00:02:03,988
そのまえに あじみを…｡

17
00:02:06,493 --> 00:02:09,493
あ〜！ こら〜！

18
00:02:10,497 --> 00:02:11,998
はひ？

19
00:02:11,998 --> 00:02:14,501
だぁ⁉ どわ〜！

20
00:02:14,501 --> 00:02:16,503
フゥ… たすかったブヒ｡

21
00:02:16,503 --> 00:02:18,505
うわ〜！

22
00:02:18,505 --> 00:02:21,007
ん？ だれだブヒ？

23
00:02:21,007 --> 00:02:23,009
バック！
グゥ〜

24
00:02:23,009 --> 00:02:25,011
あっ！ ん…｡

25
00:02:25,011 --> 00:02:27,514
おなかすいたら ぶたまんブヒ｡

26
00:02:27,514 --> 00:02:29,516
さぁ つくるよ｡

27
00:02:29,516 --> 00:02:30,951
お〜！

28
00:02:30,951 --> 00:02:32,953
まず こむぎこに➡

29
00:02:32,953 --> 00:02:35,455
ちょうみりょうと
ぬるまゆ いれて➡

30
00:02:35,455 --> 00:02:38,458
こねくりまわす｡
うわ〜｡

31
00:02:38,458 --> 00:02:42,462
ひろげた きじに
おにくをつつんだら➡

32
00:02:42,462 --> 00:02:44,464
あとは むすだけ｡

33
00:02:44,464 --> 00:02:48,468
ブヒ〜 ブヒ〜｡

34
00:02:48,468 --> 00:02:50,470
クンクン｡

35
00:02:50,470 --> 00:02:52,973
おまたセイロ！

36
00:02:52,973 --> 00:02:54,975
いいにおいブヒ〜｡

37
00:02:54,975 --> 00:02:58,478
うわ〜！ たべたくな〜い！
ビックリ！

38
00:02:58,478 --> 00:03:00,981
いいにおいじゃないぞ〜！

39
00:03:00,981 --> 00:03:03,981
においも あじも せかいいちブヒ｡

40
00:03:08,989 --> 00:03:12,492
う〜ん おいしいね〜｡

41
00:03:12,492 --> 00:03:14,494
ぼく おなかいっぱい｡

42
00:03:14,494 --> 00:03:16,496
ウフフ… わたしのぶたまんは➡

43
00:03:16,496 --> 00:03:20,000
においだけでも
おなかいっぱいになるブヒ｡

44
00:03:20,000 --> 00:03:21,501
こねこね｡

45
00:03:21,501 --> 00:03:23,503
つめつめ｡

46
00:03:23,503 --> 00:03:25,503
ブヒ〜！

47
00:03:27,507 --> 00:03:30,443
わ〜！
そのまえに あじみを…｡

48
00:03:30,443 --> 00:03:31,943
うぅ…｡

49
00:03:32,946 --> 00:03:34,447
ん？

50
00:03:34,447 --> 00:03:37,450
うぅ〜…｡

51
00:03:37,450 --> 00:03:39,452
たべたいブヒか？
ん〜！ フフ〜！

52
00:03:39,452 --> 00:03:42,452
やっぱり ちょっと あじみだブヒ｡

53
00:03:45,458 --> 00:03:47,961
あっ！ たべたくないってば！

54
00:03:47,961 --> 00:03:49,963
(アンパンマン) お〜い！

55
00:03:49,963 --> 00:03:51,464
あっ！

56
00:03:51,464 --> 00:03:53,464
アンパンマン！

57
00:03:54,968 --> 00:03:57,470
⚟はんたいのこと いうブヒ〜？⚞

58
00:03:57,470 --> 00:03:59,472
バックが
たべたくないって いうのは➡

59
00:03:59,472 --> 00:04:02,475
｢たべたい｣ってことなんだ｡
ブッヒャ〜｡

60
00:04:02,475 --> 00:04:04,978
どうりで
おかしいとおもったブヒ｡

61
00:04:04,978 --> 00:04:07,981
わたしのぶたまんを
たべたくないなんて｡

62
00:04:07,981 --> 00:04:09,983
(チｰズ) アン アアン！

63
00:04:09,983 --> 00:04:12,983
あっ！ ごめんごめ〜ん｡

64
00:04:14,487 --> 00:04:17,490
(ジャムおじさん) かわがフワフワで
おいしいねぇ｡

65
00:04:17,490 --> 00:04:19,990
(バタコ)
ホント！ なかみも ぎっしり｡

66
00:04:21,995 --> 00:04:24,497
どうだブヒ？

67
00:04:24,497 --> 00:04:27,017
フゥ… おいしくな〜い！

68
00:04:27,017 --> 00:04:29,002
え〜⁉

69
00:04:29,002 --> 00:04:30,937
ブヒ〜…｡

70
00:04:30,937 --> 00:04:33,940
ぶたまんまん バックは
はんたいのことを いうから➡

71
00:04:33,940 --> 00:04:35,942
おいしくないは…｡

72
00:04:35,942 --> 00:04:38,445
｢おいしい｣ってことね！

73
00:04:38,445 --> 00:04:41,945
もっともっと たべたくな〜い！

74
00:04:43,950 --> 00:04:47,454
あ〜！ またないで〜！

75
00:04:47,454 --> 00:04:49,456
もっと ぶたまん たべたいから➡

76
00:04:49,456 --> 00:04:52,459
バックも いっしょに
まちへ いくんですって｡

77
00:04:52,459 --> 00:04:54,461
ア〜ン！
フフフ｡

78
00:04:54,461 --> 00:04:56,963
じゃあ ぼくは
パトロールに いってきますね｡

79
00:04:56,963 --> 00:04:59,463
たのんだよ｡
はい｡

80
00:05:01,468 --> 00:05:03,470
はひ〜！

81
00:05:03,470 --> 00:05:05,472
(ドキンちゃん)
どうしたの？ ばいきんまん｡

82
00:05:05,472 --> 00:05:07,474
どうも こうも➡

83
00:05:07,474 --> 00:05:09,976
ぶたまんまんの ぶたまん
たべようとおもったら…｡

84
00:05:09,976 --> 00:05:11,978
えっ！ ぶたまん⁉

85
00:05:11,978 --> 00:05:14,478
たべたい たべたい たべた〜い！

86
00:05:17,484 --> 00:05:19,486
こわくないぞ〜！

87
00:05:19,486 --> 00:05:22,489
はいはい こわくないよ〜｡

88
00:05:22,489 --> 00:05:26,493
あ〜ん！
ぜんぜん こわくないよ〜！

89
00:05:26,493 --> 00:05:29,496
ん？ こわくないってことは➡

90
00:05:29,496 --> 00:05:31,431
｢こわい｣ブヒか？

91
00:05:31,431 --> 00:05:33,433
バキバキッ
ん？

92
00:05:33,433 --> 00:05:35,435
バキッ
あっ！

93
00:05:35,435 --> 00:05:36,936
ヒャ〜！

94
00:05:36,936 --> 00:05:38,938
ブヒャ〜…｡

95
00:05:38,938 --> 00:05:40,440
ブヒ〜！

96
00:05:40,440 --> 00:05:42,442
ブヒ… ブヒヒ…｡

97
00:05:42,442 --> 00:05:45,445
ブハ〜！
うわ〜！

98
00:05:45,445 --> 00:05:48,948
ブヒッ ブヒヒヒ…｡

99
00:05:48,948 --> 00:05:50,950
(コンタ) のこった のこった…｡
(カバオ:クマタ) うぅ…｡

100
00:05:50,950 --> 00:05:52,952
(カバオ) よ〜っと｡
(クマタ) あぁ！

101
00:05:52,952 --> 00:05:55,455
カバオやまの かち〜｡

102
00:05:55,455 --> 00:05:57,457
(ウサコ) カバオくん つよ〜い！

103
00:05:57,457 --> 00:05:59,457
どすこ〜い！

104
00:06:01,461 --> 00:06:04,964
あっ ぶたまんまん！
バック？

105
00:06:04,964 --> 00:06:08,968
お〜い！ あそびたくないぞ〜！

106
00:06:08,968 --> 00:06:10,970
(コンタ) はっけよ〜い…➡

107
00:06:10,970 --> 00:06:13,973
のこった！
(バック:カバオ) んっ…！

108
00:06:13,973 --> 00:06:16,476
(ウサコ) バック がんばって！

109
00:06:16,476 --> 00:06:19,479
(コンタ) のこった のこった｡

110
00:06:19,479 --> 00:06:21,481
(カバオ) や〜！
わ〜！

111
00:06:21,481 --> 00:06:24,484
カバオやまの かち〜｡

112
00:06:24,484 --> 00:06:28,988
あ〜ん！
まけたいよ まけたいよ〜！

113
00:06:28,988 --> 00:06:32,926
う〜ん しょうがないブヒね〜｡

114
00:06:32,926 --> 00:06:34,928
ブヒ〜…｡

115
00:06:34,928 --> 00:06:37,430
(みんな) ん〜… フン！

116
00:06:37,430 --> 00:06:39,432
はっけよ〜い…➡

117
00:06:39,432 --> 00:06:41,434
のこった！
(みんな) うわ〜！

118
00:06:41,434 --> 00:06:44,437
ブヒ〜！
(みんな) わ〜！

119
00:06:44,437 --> 00:06:47,440
ぶたまんまんの かち〜！

120
00:06:47,440 --> 00:06:51,940
ごっつぁんブヒ｡
わ〜い わ〜い…！

121
00:06:57,450 --> 00:07:00,453
ぶたまんまん まだきてないんだ｡

122
00:07:00,453 --> 00:07:03,453
おまたせブヒ〜！

123
00:07:04,958 --> 00:07:07,961
エッホッホッホ…｡

124
00:07:07,961 --> 00:07:09,963
フフフフ…｡

125
00:07:09,963 --> 00:07:11,963
ブヒ〜！

126
00:07:15,468 --> 00:07:17,971
は〜い トントンたべて〜｡

127
00:07:17,971 --> 00:07:20,473
たべないで〜！

128
00:07:20,473 --> 00:07:22,976
バックが ｢たべて｣って！
(さんにん) わ〜い！

129
00:07:22,976 --> 00:07:25,476
(ぶたまんまん) ちょっと あじみを｡
(みんな) あっ｡

130
00:07:28,998 --> 00:07:31,418
おいしくって
ほっぺたが おちるブヒ｡

131
00:07:31,418 --> 00:07:34,421
(コンタ:カバオ:ウサコ:クマタ) え〜⁉
ん？ あっ ごめん｡

132
00:07:34,421 --> 00:07:38,421
さぁ どうぞ！
(さんにん) いただきま〜す！

133
00:07:40,927 --> 00:07:43,930
フフフッ アハハ！

134
00:07:43,930 --> 00:07:45,932
(ドキン) ぶたまんまん どこ〜？

135
00:07:45,932 --> 00:07:48,935
ん〜 おれさま
もう おなかペコペコ〜｡

136
00:07:48,935 --> 00:07:50,937
おっ！
ん？

137
00:07:50,937 --> 00:07:53,440
わ〜い！ おかわりしないで〜！

138
00:07:53,440 --> 00:07:55,442
なんで バックがいるの？

139
00:07:55,442 --> 00:07:59,442
(ウサコ) ぶたまん さいこ〜う！
(カバオ) おかわりくださ〜い！

140
00:08:00,947 --> 00:08:03,950
はひ… おじゃまむしも いるのか｡

141
00:08:03,950 --> 00:08:05,952
わたし もう がまんできない！

142
00:08:05,952 --> 00:08:07,954
あっ｡
グフフフ…｡

143
00:08:07,954 --> 00:08:09,956
ハァハァ…｡

144
00:08:09,956 --> 00:08:11,958
⚟バック〜！⚞
ん？

145
00:08:11,958 --> 00:08:14,961
バック〜！ あそぼ〜！

146
00:08:14,961 --> 00:08:17,964
うわ〜い！

147
00:08:17,964 --> 00:08:19,966
あそぼ〜！

148
00:08:19,966 --> 00:08:21,968
あそばないぞ！

149
00:08:21,968 --> 00:08:23,968
あっ…｡

150
00:08:27,474 --> 00:08:29,476
バイバ〜イ｡

151
00:08:29,476 --> 00:08:30,976
グフッ！

152
00:08:32,479 --> 00:08:34,481
あれ？ バックは？

153
00:08:34,481 --> 00:08:36,483
さっきまでいたブヒ｡

154
00:08:36,483 --> 00:08:38,983
ぼく ちょっとみてくるね｡

155
00:08:40,487 --> 00:08:42,489
ぶたまん ちょうだ〜い！

156
00:08:42,489 --> 00:08:44,491
あっ バック｡
わたし➡

157
00:08:44,491 --> 00:08:47,994
ともだちの そのまたともだちの
ドキドキバックちゃん｡

158
00:08:47,994 --> 00:08:50,497
もう おなかペコペコよ〜｡

159
00:08:50,497 --> 00:08:54,000
え〜っと…
ペコペコのはんたいは➡

160
00:08:54,000 --> 00:08:56,002
｢ぱんぱん｣ブヒか？

161
00:08:56,002 --> 00:08:58,004
はひ？ あ〜！ ちがうちがう！

162
00:08:58,004 --> 00:09:01,007
もう〜 おなか
ペコペコじゃないんだってば〜！

163
00:09:01,007 --> 00:09:03,510
ってことは…➡

164
00:09:03,510 --> 00:09:05,512
おなかペコペコだ！

165
00:09:05,512 --> 00:09:08,014
なんだ トントンたべるブヒ｡

166
00:09:08,014 --> 00:09:11,017
わ〜い！
わ〜い！

167
00:09:11,017 --> 00:09:13,019
そのまえに あじみを｡
(ばいきんまん:ドキン) あっ！

168
00:09:13,019 --> 00:09:16,022
あっ ひとりで たべるな！
そうよ そうよ！

169
00:09:16,022 --> 00:09:18,525
あれ？ ってことは…｡

170
00:09:18,525 --> 00:09:20,527
｢みんなでたべよう｣って
いってるのね！

171
00:09:20,527 --> 00:09:22,529
え？
え？

172
00:09:22,529 --> 00:09:24,531
なるほどブヒ｡
(ばいきんまん:ドキン) いただきます｡

173
00:09:24,531 --> 00:09:28,034
どれどれ｡
(ばいきんまん:ドキン) あ〜！

174
00:09:28,034 --> 00:09:30,036
やっぱり おいしいねぇ｡

175
00:09:30,036 --> 00:09:31,971
こら！
もう〜！

176
00:09:31,971 --> 00:09:33,473
アハハハ…｡

177
00:09:33,473 --> 00:09:35,473
あれは！

178
00:09:37,477 --> 00:09:38,978
パ〜ン

179
00:09:38,978 --> 00:09:42,482
いったい どうしたの？
ん…？

180
00:09:42,482 --> 00:09:45,485
おなか
ペコペコじゃないんだってば！

181
00:09:45,485 --> 00:09:46,986
そうそう！

182
00:09:46,986 --> 00:09:48,988
お〜い｡
(ばいきんまん:ドキン) ん？ あっ｡

183
00:09:48,988 --> 00:09:50,488
げっ！

184
00:09:51,991 --> 00:09:53,993
あっ｡
あっ｡

185
00:09:53,993 --> 00:09:57,497
バックが ふたり？
どういうことブヒ？

186
00:09:57,497 --> 00:09:59,999
こら！ このニセモノめ！

187
00:09:59,999 --> 00:10:02,001
ぼく ホンモノじゃないぞ！

188
00:10:02,001 --> 00:10:04,003
えっ ということは…｡

189
00:10:04,003 --> 00:10:06,003
こっちが ホンモノ？

190
00:10:07,507 --> 00:10:10,009
ぼくがホンモノのバック！

191
00:10:10,009 --> 00:10:12,011
ん… じゃなくて➡

192
00:10:12,011 --> 00:10:15,014
そっちがニセモノ… はひ？

193
00:10:15,014 --> 00:10:17,016
えっと…？

194
00:10:17,016 --> 00:10:19,018
どっちでもいいブヒ｡

195
00:10:19,018 --> 00:10:21,521
あっ よこせ！
やめるブヒ｡

196
00:10:21,521 --> 00:10:24,023
あっ こら よこせ…｡
ブ〜！

197
00:10:24,023 --> 00:10:25,525
はひ⁉

198
00:10:25,525 --> 00:10:27,527
(バック:アンパンマン) あっ！
(ウサコ:カバオ) あっ！

199
00:10:27,527 --> 00:10:29,529
(アンパンマンたち) ばいきんまん！

200
00:10:29,529 --> 00:10:30,980
グフ…｡

201
00:10:30,980 --> 00:10:32,980
あ〜あ｡

202
00:10:33,967 --> 00:10:37,971
バレたら しょうがない！
ドキンちゃんでした！

203
00:10:37,971 --> 00:10:40,473
え〜い こうなったら！

204
00:10:40,473 --> 00:10:43,977
やめるんだ！ ばいきんまん！
うるさ〜い！

205
00:10:43,977 --> 00:10:45,979
アチョ〜！

206
00:10:45,979 --> 00:10:48,481
チョチョチョ…｡

207
00:10:48,481 --> 00:10:50,483
んっ うぅ…！

208
00:10:50,483 --> 00:10:53,987
う… うわ〜！ うわ〜…！

209
00:10:53,987 --> 00:10:55,488
あらら｡

210
00:10:55,488 --> 00:10:58,491
だぁ〜⁉
え〜い！

211
00:10:58,491 --> 00:11:00,994
え〜い まだまだ！

212
00:11:00,994 --> 00:11:03,496
ア〜ン パ〜ンチ！

213
00:11:03,496 --> 00:11:07,000
バイバイキ〜ン！

214
00:11:07,000 --> 00:11:10,500
(ドキン) まってよ〜！

215
00:11:13,006 --> 00:11:16,509
(バタコ) まぁ ばいきんまんが？
(ジャム) たいへんだったねぇ｡

216
00:11:16,509 --> 00:11:19,512
とっても たのしくなかったぞ！

217
00:11:19,512 --> 00:11:22,515
フフフ…
バックは ｢たのしかった｣って｡

218
00:11:22,515 --> 00:11:25,518
はい おまたセイロ｡

219
00:11:25,518 --> 00:11:27,520
お〜！

220
00:11:27,520 --> 00:11:30,023
がんばったごほうびブヒ｡
わ〜い！

221
00:11:30,023 --> 00:11:32,458
はい そのまえに あじみを…｡

222
00:11:32,458 --> 00:11:35,461
アンアン！
いっしょに たべたくないぞ〜！

223
00:11:35,461 --> 00:11:38,464
アハハ ごめんごめん｡
わ〜！

224
00:11:38,464 --> 00:11:40,967
バックは
ぶたまんまんの ぶたまんが➡

225
00:11:40,967 --> 00:11:42,969
きにいったみたいだねぇ｡

226
00:11:42,969 --> 00:11:44,969
そうですね｡

227
00:12:03,422 --> 00:12:07,426
んっ… うぅ…｡

228
00:12:07,426 --> 00:12:09,428
あぁ…｡

229
00:12:09,428 --> 00:12:11,931
うっ… うぅ…｡

230
00:12:11,931 --> 00:12:15,434
うっ… ハァ…｡

231
00:12:15,434 --> 00:12:17,436
うわ〜！

232
00:12:17,436 --> 00:12:20,940
わ〜！

233
00:12:20,940 --> 00:12:22,940
ん？

234
00:12:26,445 --> 00:12:27,947
フゥ…｡

235
00:12:27,947 --> 00:12:29,949
(おむすびまん)
だいじょうぶで ござんすか？

236
00:12:29,949 --> 00:12:31,450
あっ｡

237
00:12:31,450 --> 00:12:33,450
おむすびまん！

238
00:12:36,455 --> 00:12:38,457
(ジャム) さぁ やけたよ｡

239
00:12:38,457 --> 00:12:40,459
(こむすびまん) わ〜！
ア〜ン！

240
00:12:40,459 --> 00:12:43,459
(こむすびまん) いただきま〜す！
アンア アンア ア〜ン！

241
00:12:44,964 --> 00:12:47,466
きょうは
うめぼしばあやさんの うちへ➡

242
00:12:47,466 --> 00:12:49,468
とどけるんですよね？

243
00:12:49,468 --> 00:12:52,972
ああ｡
それなら オイラが いくでしゅ｡

244
00:12:52,972 --> 00:12:55,975
おや？ いいのかい？
はいでしゅ！

245
00:12:55,975 --> 00:12:58,978
オイラも うめぼしばあやさんの
おてつだいに➡

246
00:12:58,978 --> 00:13:01,378
いくところで ござんしゅから！

247
00:13:02,915 --> 00:13:05,418
(ジャム)
それじゃあ おねがいするよ｡

248
00:13:05,418 --> 00:13:07,420
うめこちゃんたちに よろしくね｡

249
00:13:07,420 --> 00:13:09,422
アン ア〜ン｡

250
00:13:09,422 --> 00:13:11,924
はいでしゅ！ それでは！

251
00:13:11,924 --> 00:13:14,427
いってくるでしゅ！

252
00:13:14,427 --> 00:13:17,430
きをつけるんだよ〜｡
(こむすびまん) は〜い！

253
00:13:17,430 --> 00:13:20,933
それじゃあ ぼくは
パトロールに いってきますね｡

254
00:13:20,933 --> 00:13:24,433
ああ たのんだよ｡
はい｡

255
00:13:28,441 --> 00:13:48,461
♬〜

256
00:13:48,461 --> 00:13:56,469
♬〜

257
00:13:56,469 --> 00:13:58,471
こおりのじょおう！

258
00:13:58,471 --> 00:14:01,407
こいつは こむすびまんといって➡

259
00:14:01,407 --> 00:14:03,909
アンパンマンの なかまなんです！

260
00:14:03,909 --> 00:14:06,412
(こおりのじょおう) ほう？
こいつを つかまえれば➡

261
00:14:06,412 --> 00:14:10,416
アンパンマンのヤツが
ぜったいに たすけにきますよ！

262
00:14:10,416 --> 00:14:13,419
おもしろいじゃないか｡

263
00:14:13,419 --> 00:14:15,919
ゆきおおかみ！

264
00:14:17,423 --> 00:14:20,426
こいつを ここへ つれておいで｡

265
00:14:20,426 --> 00:14:24,426
(ゆきおおかみ) ワオ〜ン！

266
00:14:29,935 --> 00:14:33,935
グゥ〜
おなかすいた｡

267
00:14:34,940 --> 00:14:36,442
(ふたり) ん？

268
00:14:36,442 --> 00:14:38,944
はい どうぞでしゅ｡

269
00:14:38,944 --> 00:14:40,946
⚟うわ〜！⚞
⚟わ〜い！⚞

270
00:14:40,946 --> 00:14:43,446
(ふたり) いっただっきま〜す！

271
00:14:45,951 --> 00:14:47,970
(ふたり) おいし〜い！

272
00:14:47,970 --> 00:14:49,955
ありがとう こむすびまん！

273
00:14:49,955 --> 00:14:54,455
どういたしましてで ござんしゅ
では｡

274
00:14:59,965 --> 00:15:03,903
ふたりとも よろこんでくれて
よかったでござんしゅ〜！

275
00:15:03,903 --> 00:15:05,404
グゥ〜

276
00:15:05,404 --> 00:15:07,406
えっ… アハハ…｡

277
00:15:07,406 --> 00:15:10,409
オイラも
おひるにするで ござんしゅかね｡

278
00:15:10,409 --> 00:15:13,409
ワオ〜ン！

279
00:15:24,423 --> 00:15:27,426
う〜ん！ うめぼしばあやさんの
うめぼしは➡

280
00:15:27,426 --> 00:15:30,426
つかれが
とれるでござんしゅね〜！

281
00:15:32,932 --> 00:15:36,432
いまは どこを
たびしてるでしゅかね〜｡

282
00:15:40,439 --> 00:15:42,942
さて そろそろ｡

283
00:15:42,942 --> 00:15:44,442
うぅ！

284
00:15:45,945 --> 00:15:47,947
だれでしゅ⁉

285
00:15:47,947 --> 00:15:49,949
ガウ〜｡
ワオ〜ン｡

286
00:15:49,949 --> 00:15:51,951
わ〜！

287
00:15:51,951 --> 00:15:53,953
なんでしゅか！

288
00:15:53,953 --> 00:15:57,456
ワオ〜〜ン！

289
00:15:57,456 --> 00:15:59,456
はっ！

290
00:16:00,893 --> 00:16:02,893
ワオ〜ン！

291
00:16:05,397 --> 00:16:07,399
うわぁ！
ワオ〜ン！

292
00:16:07,399 --> 00:16:08,899
ガウ〜！

293
00:16:10,402 --> 00:16:11,902
ん？

294
00:16:14,907 --> 00:16:16,909
へっ？ うわ〜！

295
00:16:16,909 --> 00:16:18,909
わ〜！

296
00:16:20,412 --> 00:16:22,915
こむすびまん
うめぼしばあやさんの うちに➡

297
00:16:22,915 --> 00:16:24,917
ついたかな〜？

298
00:16:24,917 --> 00:16:27,920
ワオ〜ン！
こら〜！ だすでしゅ！

299
00:16:27,920 --> 00:16:30,422
こっから だすでしゅ〜！

300
00:16:30,422 --> 00:16:32,422
あれは！

301
00:16:34,927 --> 00:16:36,427
うわぁ！

302
00:16:41,934 --> 00:16:43,934
(おむすびまん) んっ！

303
00:16:45,938 --> 00:16:47,940
ん？

304
00:16:47,940 --> 00:16:49,940
これは…｡

305
00:16:52,945 --> 00:16:54,945
まさか…｡

306
00:17:00,953 --> 00:17:04,456
ナ〜ッハッハッハ… つかまえた！

307
00:17:04,456 --> 00:17:09,962
フフッ これで あとは
アンパンマンを まつだけだね｡

308
00:17:09,962 --> 00:17:11,964
アンパンマンを？

309
00:17:11,964 --> 00:17:16,468
ああ ヤツは
キレイな ほうせきになるよ｡

310
00:17:16,468 --> 00:17:19,972
どうだい？
わたしのコレクションは｡

311
00:17:19,972 --> 00:17:21,974
キレイだろ？

312
00:17:21,974 --> 00:17:25,978
ヤツも ここに ならべてやるのさ｡

313
00:17:25,978 --> 00:17:29,982
こんなの ちっとも
キレイじゃないでござんしゅ｡

314
00:17:29,982 --> 00:17:32,985
ん？ なんだと？

315
00:17:32,985 --> 00:17:34,987
みんなの やさしいえがおや➡

316
00:17:34,987 --> 00:17:38,490
よろこぶ すがたのほうが➡

317
00:17:38,490 --> 00:17:40,993
ずっとキレイでござんしゅ！

318
00:17:40,993 --> 00:17:43,996
ほう そこまでいうなら➡

319
00:17:43,996 --> 00:17:46,999
おまえから
ほうせきに してあげるよ！

320
00:17:46,999 --> 00:17:49,001
やめるんだ〜！

321
00:17:49,001 --> 00:17:50,502
アンパンマン！

322
00:17:50,502 --> 00:17:54,006
こおりのじょおう！
こむすびまんを はなすんだ！

323
00:17:54,006 --> 00:17:58,510
フフフフッ
よくきてくれたね アンパンマン｡

324
00:17:58,510 --> 00:18:00,946
さぁ かんげいしておやり！

325
00:18:00,946 --> 00:18:02,948
ゆきおおかみ！

326
00:18:02,948 --> 00:18:04,948
ワオ〜ン！

327
00:18:06,952 --> 00:18:10,456
どりゃ〜！
あっ！

328
00:18:10,456 --> 00:18:12,458
ワオ〜ン！
あぁ！

329
00:18:12,458 --> 00:18:13,958
(こむすびまん) たぁ！

330
00:18:15,461 --> 00:18:16,962
こむすびまん！

331
00:18:16,962 --> 00:18:18,964
どんなもんでしゅ！

332
00:18:18,964 --> 00:18:22,468
おのれ！ まずは おまえからだ｡

333
00:18:22,468 --> 00:18:23,969
あぶない！

334
00:18:23,969 --> 00:18:26,472
おっと！
あぁ！ うっ！

335
00:18:26,472 --> 00:18:30,476
ほうせきに おなり〜！

336
00:18:30,476 --> 00:18:34,476
うぅ… うわ〜！

337
00:18:36,482 --> 00:18:38,984
あぁ！
ガウ〜！

338
00:18:38,984 --> 00:18:41,487
ガウ〜！

339
00:18:41,487 --> 00:18:43,489
ガウッ！
うわぁ！

340
00:18:43,489 --> 00:18:44,989
うっ！

341
00:18:48,494 --> 00:18:51,497
うっ うぅ…｡
これで もう とべないぞ！

342
00:18:51,497 --> 00:18:56,497
フフフ… つぎは
おまえのばんだよ アンパンマン｡

343
00:18:58,504 --> 00:19:00,904
ハァ〜！

344
00:19:05,444 --> 00:19:09,448
なに⁉
おまえは！

345
00:19:09,448 --> 00:19:11,948
あっしは…｡

346
00:19:14,453 --> 00:19:16,955
おむすびまんでござんす｡

347
00:19:16,955 --> 00:19:19,458
ゲゲッ なんで おむすびまんが！

348
00:19:19,458 --> 00:19:22,461
おのれ… アンパンマンのまえに➡

349
00:19:22,461 --> 00:19:26,465
おまえを ほうせきに
してあげようじゃないか！

350
00:19:26,465 --> 00:19:29,465
ほうせき？ ん？

351
00:19:33,972 --> 00:19:35,974
(おむすびまん) まさか！

352
00:19:35,974 --> 00:19:38,477
こむすびまんを…｡

353
00:19:38,477 --> 00:19:40,979
もとに もどすでござんす｡

354
00:19:40,979 --> 00:19:44,479
ゆきおおかみ！
ワオ〜ン！

355
00:19:47,986 --> 00:19:51,990
おむすびまん！
おまえのあいては おれさまだ！

356
00:19:51,990 --> 00:19:53,490
あっ！

357
00:19:55,494 --> 00:19:58,494
ガウ〜…｡

358
00:20:07,940 --> 00:20:09,942
ギャウ〜！

359
00:20:09,942 --> 00:20:12,444
まだまだ！

360
00:20:12,444 --> 00:20:15,447
おむすびまんは さきへ！
わかりやした！

361
00:20:15,447 --> 00:20:17,447
ハァ〜！

362
00:20:22,955 --> 00:20:24,957
クッ…｡

363
00:20:24,957 --> 00:20:26,457
ん〜！

364
00:20:27,960 --> 00:20:29,461
そ〜れ！

365
00:20:29,461 --> 00:20:31,463
あ〜！

366
00:20:31,463 --> 00:20:33,465
アンパンマン！

367
00:20:33,465 --> 00:20:34,965
ふっ！

368
00:20:36,468 --> 00:20:38,470
うわぁ〜！

369
00:20:38,470 --> 00:20:40,973
ア〜ン パ〜ンチ！

370
00:20:40,973 --> 00:20:42,473
なに⁉

371
00:20:46,478 --> 00:20:48,480
しまった！
うわ〜！

372
00:20:48,480 --> 00:20:51,984
うおお… うわ〜！
うわ〜！

373
00:20:51,984 --> 00:20:55,484
バイバイキ〜ン！

374
00:21:00,426 --> 00:21:02,426
フッ…｡

375
00:21:06,932 --> 00:21:18,944
♬〜

376
00:21:18,944 --> 00:21:21,447
えっ？
こむすびまん！

377
00:21:21,447 --> 00:21:25,451
ん？
よかった もとに もどったんだね｡

378
00:21:25,451 --> 00:21:27,453
ありがとうでござんしゅ！

379
00:21:27,453 --> 00:21:30,453
あっ｡
ん？

380
00:21:33,959 --> 00:21:36,962
(ジャム) そうかい そんなことが｡

381
00:21:36,962 --> 00:21:40,466
たいへんだったわね｡
ア〜ン｡

382
00:21:40,466 --> 00:21:42,468
はい…｡

383
00:21:42,468 --> 00:21:44,470
だから もっともっと➡

384
00:21:44,470 --> 00:21:47,473
しゅぎょうが
ひつようでござんしゅ｡

385
00:21:47,473 --> 00:21:49,475
そして いつか
おむすびまんみたいに➡

386
00:21:49,475 --> 00:21:51,477
なるんでござんしゅ！

387
00:21:51,477 --> 00:21:54,480
こむすびまんなら
きっと なれるよ｡

388
00:21:54,480 --> 00:21:57,483
フフフッ がんばってね｡

389
00:21:57,483 --> 00:21:58,984
アン ア〜ン！

390
00:21:58,984 --> 00:22:03,422
ああ おむすびまんも
まっているとおもうよ｡

391
00:22:03,422 --> 00:22:05,424
みなさん…｡

392
00:22:05,424 --> 00:22:07,424
はいでしゅ！

393
00:22:11,430 --> 00:22:13,432
《こむすびまん》

394
00:22:13,432 --> 00:22:17,432
《また あえるのを
たのしみにしてるでござんすよ》

