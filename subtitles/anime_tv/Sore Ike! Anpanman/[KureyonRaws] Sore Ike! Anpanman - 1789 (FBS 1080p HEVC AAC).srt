1
00:00:05,038 --> 00:00:25,058
♬〜

2
00:00:25,058 --> 00:00:45,078
♬〜

3
00:00:45,078 --> 00:01:05,032
♬〜

4
00:01:05,032 --> 00:01:14,032
♬〜

5
00:01:32,963 --> 00:01:37,968
(マシュマロさん) まろは まろでも
マシュマロのまろ〜｡

6
00:01:37,968 --> 00:01:39,470
ん？

7
00:01:39,470 --> 00:01:42,473
マシュマロみたいでおじゃる｡

8
00:01:42,473 --> 00:01:43,974
(ばいきんまん) ばあ〜！

9
00:01:43,974 --> 00:01:45,976
おお ばいきんまん！

10
00:01:45,976 --> 00:01:48,479
(ドキンちゃん)
ドキンちゃんもいま〜す｡

11
00:01:48,479 --> 00:01:51,482
やい！ マシュマロよこせ！

12
00:01:51,482 --> 00:01:53,984
くるしゅうない くるしゅうない｡

13
00:01:53,984 --> 00:01:57,488
それでは レインボーマシュマロ！

14
00:01:57,488 --> 00:02:01,992
(ばいきんまん:ドキン) あ〜ん｡

15
00:02:01,992 --> 00:02:03,494
おいしい！

16
00:02:03,494 --> 00:02:07,998
グフフフ…
もっと も〜っと よこすんだ〜！

17
00:02:07,998 --> 00:02:09,500
ほっ｡

18
00:02:09,500 --> 00:02:12,002
ありゃ？ この この！

19
00:02:12,002 --> 00:02:14,505
ほっ ほっ｡

20
00:02:14,505 --> 00:02:16,507
たのしいでおじゃる！

21
00:02:16,507 --> 00:02:20,511
え〜い おとなしくしろ〜！

22
00:02:20,511 --> 00:02:24,014
まろ〜 ぽ〜ん！

23
00:02:24,014 --> 00:02:27,017
あ〜…｡
なにやってんのよ〜｡

24
00:02:27,017 --> 00:02:29,019
あ… いや…｡

25
00:02:29,019 --> 00:02:32,456
⚟アハハハ…！⚞
(ばいきんまん:ドキン) ん？

26
00:02:32,456 --> 00:02:35,459
げげっ！
なに？

27
00:02:35,459 --> 00:02:37,461
(プリンちゃん:エクレアさん)
♪〜 あまくて おいしい

28
00:02:37,461 --> 00:02:39,463
♪〜 プリン プリン プリン
プリン プリン プリン

29
00:02:39,463 --> 00:02:42,466
♪〜 とろ〜り とろける
カスタード

30
00:02:42,466 --> 00:02:46,470
プリンちゃんとエクレアさん｡

31
00:02:46,470 --> 00:02:49,974
いくよ ドキンちゃん！

32
00:02:49,974 --> 00:02:52,974
ちょっと ばいきんまん！

33
00:02:54,979 --> 00:02:56,981
(プリンちゃん:エクレアさん)
♪〜 ほっぺも とろける

34
00:02:56,981 --> 00:02:58,983
♪〜 プリン プリン プリン
プリン プリン プリン

35
00:02:58,983 --> 00:03:02,987
♪〜 つんと つつけば
プルン プルン プルン

36
00:03:02,987 --> 00:03:05,489
⚟まろまろまろ〜！⚞
(プリンちゃん:エクレアさん) ん？

37
00:03:05,489 --> 00:03:06,991
ほぉ〜！

38
00:03:06,991 --> 00:03:09,493
(エクレアさん) あわわわ… おっと｡

39
00:03:09,493 --> 00:03:12,496
ホホっ ゆかい ゆかい｡

40
00:03:12,496 --> 00:03:15,499
このコ
おそらから ふってきたわ〜｡

41
00:03:15,499 --> 00:03:18,499
(プリンちゃん) うわぁ すてき〜！

42
00:03:20,004 --> 00:03:23,507
それにみて
すごくプニプニしてる｡

43
00:03:23,507 --> 00:03:26,007
やめてたもれ｡

44
00:03:28,012 --> 00:03:30,447
(ジャムおじさん) ⚟やぁ いらっしゃい⚞

45
00:03:30,447 --> 00:03:33,951
(チｰズ) アン ア〜ン｡
(バタコ) ふたりとも ありがとね｡

46
00:03:33,951 --> 00:03:36,453
(エクレアさん:プリンちゃん) フフフ…｡

47
00:03:36,453 --> 00:03:39,957
これは なんでおじゃるか？

48
00:03:39,957 --> 00:03:44,957
(ジャム) プリンとエクレアだよ｡
あまくて とってもおいしいのよ！

49
00:03:46,964 --> 00:03:48,964
ほぉ〜｡

50
00:03:50,467 --> 00:03:53,971
ほぉ〜 きにいったでおじゃる！

51
00:03:53,971 --> 00:03:57,975
ふたりを
まろの けらいにするでおじゃる｡

52
00:03:57,975 --> 00:04:00,477
(さんにん) え？
アン？

53
00:04:00,477 --> 00:04:03,981
けらい？
けらいって なにするの？

54
00:04:03,981 --> 00:04:07,985
ふ〜む…
いっしょに あそぶでおじゃる｡

55
00:04:07,985 --> 00:04:10,487
(エクレアさん:プリンちゃん) おもしろそ〜！

56
00:04:10,487 --> 00:04:14,987
(プリンちゃん) わ〜い！
あそびましょ あそびましょ〜｡

57
00:04:17,995 --> 00:04:20,497
アン〜｡
たのしそうね！

58
00:04:20,497 --> 00:04:24,501
(アンパンマン) それじゃあ ぼくは
パトロールにいってきますね｡

59
00:04:24,501 --> 00:04:28,001
ああ たのんだよ｡
はい｡

60
00:04:30,941 --> 00:04:38,949
♬〜

61
00:04:38,949 --> 00:04:41,952
ここまでくれば…｡
もう！

62
00:04:41,952 --> 00:04:44,455
いや だって…｡

63
00:04:44,455 --> 00:04:48,459
もっと マシュマロ
たべたかったのに〜｡

64
00:04:48,459 --> 00:04:50,461
だって おれさま➡

65
00:04:50,461 --> 00:04:54,465
プリンちゃんたち にがてだし…｡
わたし かえる！

66
00:04:54,465 --> 00:04:56,467
マシュマロでも
プリンでもいいから➡

67
00:04:56,467 --> 00:04:58,969
もってきて！
あ…｡

68
00:04:58,969 --> 00:05:00,969
はぁ…｡

69
00:05:03,974 --> 00:05:06,477
ねぇ なにしてあそぶ？

70
00:05:06,477 --> 00:05:09,480
うんとたのしいことが
いいわよね｡

71
00:05:09,480 --> 00:05:12,983
たのしいといえば…｡

72
00:05:12,983 --> 00:05:15,486
(プリンちゃん:エクレアさん)
ばいきんまんとあそぶ！

73
00:05:15,486 --> 00:05:17,488
ばいきんまん？

74
00:05:17,488 --> 00:05:20,991
それなら さっき
まろと あそんでいたでおじゃる｡

75
00:05:20,991 --> 00:05:22,993
(プリンちゃん:エクレアさん) え〜！

76
00:05:22,993 --> 00:05:26,997
でも いつのまにか
いなくなったでおじゃるなあ｡

77
00:05:26,997 --> 00:05:30,000
それって きっと かくれんぼよ〜｡

78
00:05:30,000 --> 00:05:33,937
ばいきんまんは
あそぶのが だ〜いすきなの！

79
00:05:33,937 --> 00:05:36,940
ほぉ そうであったか｡

80
00:05:36,940 --> 00:05:38,942
はやく さがしにいきましょう！

81
00:05:38,942 --> 00:05:41,442
さんせ〜い！

82
00:05:43,447 --> 00:05:46,447
(プリンちゃん:エクレアさん)
ばいきんま〜ん！

83
00:05:47,951 --> 00:05:50,951
(プリンちゃん:エクレアさん)
ばいきんま〜ん！

84
00:05:54,958 --> 00:05:56,960
(プリンちゃん:エクレアさん)
ばいきんま〜ん！

85
00:05:56,960 --> 00:05:59,963
ん？ どうしたんだい？

86
00:05:59,963 --> 00:06:02,966
ばいきんまん？
ア〜ン？

87
00:06:02,966 --> 00:06:05,469
いないでおじゃるなあ｡

88
00:06:05,469 --> 00:06:09,473
つぎは あっちよ｡
(プリンちゃん) うん！

89
00:06:09,473 --> 00:06:12,476
いっちゃった｡
ア〜ン｡

90
00:06:12,476 --> 00:06:19,983
♬〜

91
00:06:19,983 --> 00:06:22,986
どこに かくれてるのかしら？

92
00:06:22,986 --> 00:06:26,490
ばいきんまんは
かくれんぼが じょうずね｡

93
00:06:26,490 --> 00:06:30,427
(プリンちゃん:エクレアさん)
わぁ〜！ アハハハ…！

94
00:06:30,427 --> 00:06:32,429
ほっ ほっ！

95
00:06:32,429 --> 00:06:34,932
(プリンちゃん:エクレアさん)
そ〜れ もっと もっと〜！

96
00:06:34,932 --> 00:06:36,934
たのしいでおじゃる！

97
00:06:36,934 --> 00:06:40,437
(プリンちゃん:エクレアさん) せ〜の それ〜！

98
00:06:40,437 --> 00:06:42,940
まろまろまろ〜！

99
00:06:42,940 --> 00:06:45,442
(プリンちゃん:エクレアさん) わぁ〜！

100
00:06:45,442 --> 00:06:47,442
あっ！

101
00:06:49,947 --> 00:06:51,947
(プリンちゃん) フフフ…｡
(エクレアさん) うん｡

102
00:06:54,952 --> 00:06:57,454
わたしたちも｡
うん｡

103
00:06:57,454 --> 00:06:59,454
(プリンちゃん:エクレアさん) わぁ〜！

104
00:07:02,960 --> 00:07:05,462
マシュマロさん どこだ？

105
00:07:05,462 --> 00:07:07,965
⚟たかいでおじゃる⚞
ん？

106
00:07:07,965 --> 00:07:09,466
ほぉ〜｡

107
00:07:09,466 --> 00:07:11,468
おわぁ！ なんだ⁉

108
00:07:11,468 --> 00:07:15,472
ほ？ ここにいたでおじゃるか｡

109
00:07:15,472 --> 00:07:17,975
グフフフ ラッキー｡

110
00:07:17,975 --> 00:07:20,978
(プリンちゃん:エクレアさん) アハハハ…！
ええ〜⁉ ああ⁉

111
00:07:20,978 --> 00:07:23,981
あら ばいきんまん｡
み〜っけ！

112
00:07:23,981 --> 00:07:27,484
なんで おまえたちまで⁉

113
00:07:27,484 --> 00:07:29,987
ちょ ちょ… まえが みえない！

114
00:07:29,987 --> 00:07:32,923
はやいでおじゃる〜｡

115
00:07:32,923 --> 00:07:35,923
どわ〜〜！
(ヤギおじさん) ん？ わぁ！

116
00:07:37,427 --> 00:07:39,427
(ヤギおじさん) あ！
(よにん) わぁ〜！

117
00:07:40,931 --> 00:07:42,933
(プリンちゃん:エクレアさん) ふかふか〜｡
ほぉ〜｡

118
00:07:42,933 --> 00:07:44,935
ハヒ〜…｡

119
00:07:44,935 --> 00:07:47,938
(プリンちゃん:エクレアさん) ばいきんまん！
ん？

120
00:07:47,938 --> 00:07:50,440
くるな〜！

121
00:07:50,440 --> 00:07:53,443
(プリンちゃん:エクレアさん)
つぎは おにごっこね！

122
00:07:53,443 --> 00:07:54,943
ほっ｡

123
00:07:57,447 --> 00:07:58,949
おお！

124
00:07:58,949 --> 00:08:00,951
ハァ ハァ…｡

125
00:08:00,951 --> 00:08:02,452
ハァ… ハァ… ハァ…｡

126
00:08:02,452 --> 00:08:05,455
ドシン ドシン ドシン…
ん？

127
00:08:05,455 --> 00:08:06,957
ん⁉

128
00:08:06,957 --> 00:08:09,960
どわ〜！
(プリンちゃん) まてまて〜！

129
00:08:09,960 --> 00:08:13,463
(エクレアさん) にがさないわよ〜｡
どわ〜！

130
00:08:13,463 --> 00:08:16,463
やめろ〜！

131
00:08:20,470 --> 00:08:21,972
ん？

132
00:08:21,972 --> 00:08:24,474
どわぁ〜！

133
00:08:24,474 --> 00:08:25,976
ぐっ！

134
00:08:25,976 --> 00:08:28,979
あだだだ〜！ ん？
ゴロゴロ…

135
00:08:28,979 --> 00:08:32,983
おわわわわわ…！

136
00:08:32,983 --> 00:08:34,985
とまらな〜い！

137
00:08:34,985 --> 00:08:36,987
(プリンちゃん:エクレアさん)
ばいきんま〜ん！

138
00:08:36,987 --> 00:08:38,488
うわ〜！

139
00:08:38,488 --> 00:08:40,991
ハヒ〜！

140
00:08:40,991 --> 00:08:43,994
くるな〜！

141
00:08:43,994 --> 00:08:45,996
ん？ あれは…｡

142
00:08:45,996 --> 00:08:48,999
わわわわ…！
(プリンちゃん:エクレアさん) アハハハ…！

143
00:08:48,999 --> 00:08:51,001
どわ〜！

144
00:08:51,001 --> 00:08:53,503
あ…｡

145
00:08:53,503 --> 00:08:57,007
ぶ〜！ どわ〜！

146
00:08:57,007 --> 00:09:00,510
あ〜〜！

147
00:09:00,510 --> 00:09:03,013
ふっ！

148
00:09:03,013 --> 00:09:06,016
だいじょうぶ？

149
00:09:06,016 --> 00:09:08,518
アンパンマン…｡

150
00:09:08,518 --> 00:09:10,520
はなせ！

151
00:09:10,520 --> 00:09:13,023
(プリンちゃん:エクレアさん) わ〜い！
ほぉ〜！

152
00:09:13,023 --> 00:09:15,525
だはっ！ ぐふっ！

153
00:09:15,525 --> 00:09:18,028
なんで こんなめに…｡

154
00:09:18,028 --> 00:09:20,528
ああ…｡

155
00:09:22,032 --> 00:09:25,532
うう…｡

156
00:09:27,037 --> 00:09:30,040
げんきがないみたいで
おじゃるな｡

157
00:09:30,040 --> 00:09:35,479
そうだ！ みんなでおどれば！
(エクレアさん)きっと げんきになるわ！

158
00:09:35,479 --> 00:09:37,981
ああ…｡

159
00:09:37,981 --> 00:09:39,983
(プリンちゃん:エクレアさん)
♪〜 あまくて おいしい

160
00:09:39,983 --> 00:09:41,985
♪〜 プリン プリン プリン
プリン プリン プリン

161
00:09:41,985 --> 00:09:46,490
♪〜 とろ〜り とろける
カスタード

162
00:09:46,490 --> 00:09:50,494
♪〜 しろい マシュマロ
フワ フワ フワ フワ リン リン

163
00:09:50,494 --> 00:09:54,998
♪〜 つんと つつけば
プニン プニン

164
00:09:54,998 --> 00:09:58,502
みごとなうたでおじゃる！

165
00:09:58,502 --> 00:10:02,005
うう…｡

166
00:10:02,005 --> 00:10:05,008
もうだめ… おれさま かえる…｡

167
00:10:05,008 --> 00:10:06,508
ん？

168
00:10:09,513 --> 00:10:11,513
これは…｡

169
00:10:14,518 --> 00:10:16,520
わぁ〜！

170
00:10:16,520 --> 00:10:19,523
ドキンちゃんと たべてね｡

171
00:10:19,523 --> 00:10:24,023
ふん！ しょうがない
もらっといてやる！

172
00:10:26,029 --> 00:10:30,429
(プリンちゃん:エクレアさん) またね〜！
さよならでおじゃる〜！

173
00:10:32,469 --> 00:10:35,972
これぐらいで かんべんしてやる！

174
00:10:35,972 --> 00:10:39,472
バイバイキ〜ン！

175
00:10:47,484 --> 00:10:49,986
(プリンちゃん) うわぁ〜！
(エクレアさん) かわいい！

176
00:10:49,986 --> 00:10:51,988
まろのマシュマロで➡

177
00:10:51,988 --> 00:10:55,488
プリンが も〜っと
おいしくなるでおじゃる｡

178
00:10:56,993 --> 00:10:59,996
アン ア〜ン｡
とってもおいしいわ！

179
00:10:59,996 --> 00:11:01,998
フフフフ…｡

180
00:11:01,998 --> 00:11:05,001
そうであろう そうであろう｡

181
00:11:05,001 --> 00:11:07,504
きょうは すっごくたのしかった！

182
00:11:07,504 --> 00:11:11,508
マシュマロさん また
いっしょに あそびましょうね！

183
00:11:11,508 --> 00:11:14,010
もちろんでおじゃる！

184
00:11:14,010 --> 00:11:17,013
みんな
なかよくなったみたいだねぇ｡

185
00:11:17,013 --> 00:11:19,513
そうですね｡

186
00:11:22,519 --> 00:11:24,521
(ドキン) ⚟うわぁ〜！⚞

187
00:11:24,521 --> 00:11:29,025
おいしそう！
ありがとう ばいきんまん！

188
00:11:29,025 --> 00:11:32,462
ンフフフ…｡
(ドキン:ばいきんまん) いただきま〜す！

189
00:11:32,462 --> 00:11:35,465
あ〜ん｡

190
00:11:35,465 --> 00:11:38,468
おいしい！ グフフ｡

191
00:11:38,468 --> 00:11:43,468
う〜ん… しあわせ！ ウフフフ｡

192
00:12:07,399 --> 00:12:09,902
(ゆずじいや) ⚟よいですか ひめさま⚞

193
00:12:09,902 --> 00:12:13,906
(ゆずじいや) このせかいには
いろんなくにが あるのです｡

194
00:12:13,906 --> 00:12:16,408
ねこのくにや ちゅうかのくに｡

195
00:12:16,408 --> 00:12:19,411
キャンドルにかこまれた
ローソクじま｡

196
00:12:19,411 --> 00:12:23,415
オーロラがかがやく
こおりのくに｡

197
00:12:23,415 --> 00:12:25,415
(ゆずひめ) う〜ん…｡

198
00:12:29,922 --> 00:12:31,422
えっ⁉

199
00:12:35,928 --> 00:12:38,430
ここは…｡

200
00:12:38,430 --> 00:12:41,433
あ！

201
00:12:41,433 --> 00:12:43,936
わぁ すてき！ フフフフ…｡

202
00:12:43,936 --> 00:12:47,936
(ゆずじいや) ⚟ゆずひめさま！⚞
えっ？ ん？

203
00:12:50,442 --> 00:12:51,944
はっ！

204
00:12:51,944 --> 00:12:54,947
ひめさまのための
おべんきょうなのですぞ｡

205
00:12:54,947 --> 00:12:57,950
いねむりとは なにごとですか｡

206
00:12:57,950 --> 00:13:00,886
だって つまんないんだもん…｡

207
00:13:00,886 --> 00:13:03,889
おお またそんな…｡

208
00:13:03,889 --> 00:13:08,393
せかいじゅうのくにをしることは
と〜っても たいせつなのです｡

209
00:13:08,393 --> 00:13:10,896
りっぱなひめさまに
なってもらいたくて➡

210
00:13:10,896 --> 00:13:13,899
じいは まいにち まいにち
いっしょうけんめい…｡

211
00:13:13,899 --> 00:13:15,901
バサバサ…
ん？

212
00:13:15,901 --> 00:13:18,904
ああ〜！

213
00:13:18,904 --> 00:13:21,406
あそびにいってきま〜す！

214
00:13:21,406 --> 00:13:23,909
また やられた〜！

215
00:13:23,909 --> 00:13:27,412
(クリｰムパンダ:メロンパンナ)
⚟あそびにいってきま〜す！⚞

216
00:13:27,412 --> 00:13:31,416
(さんにん) いってらっしゃ〜い！
ア〜ン！

217
00:13:31,416 --> 00:13:33,418
きょうも いいおてんきですね｡

218
00:13:33,418 --> 00:13:36,922
ええ おせんたくもかわきそう｡

219
00:13:36,922 --> 00:13:38,423
こんやは きっと➡

220
00:13:38,423 --> 00:13:41,426
きれいなまんげつが
みられるだろうねぇ｡

221
00:13:41,426 --> 00:13:43,426
アン ア〜ン！

222
00:13:45,430 --> 00:13:48,934
はぁ… おれさま
とってもたいくつ〜｡

223
00:13:48,934 --> 00:13:50,934
ん？

224
00:13:54,439 --> 00:13:56,441
あれは… グフっ｡

225
00:13:56,441 --> 00:14:00,879
フフっ それにしても
すてきなゆめだったなぁ｡

226
00:14:00,879 --> 00:14:04,383
ハ〜ヒフ〜ヘホ〜！
えっ？

227
00:14:04,383 --> 00:14:07,886
(ハト) クルック〜⁉
ばいきんまん！

228
00:14:07,886 --> 00:14:09,905
は〜い ゆずひめちゃん｡

229
00:14:09,905 --> 00:14:13,392
おれさまと
あ〜そび〜ましょ〜！

230
00:14:13,392 --> 00:14:16,895
あっそ〜れ！
あっそれそれ そ〜れ〜！

231
00:14:16,895 --> 00:14:18,897
やめて〜！

232
00:14:18,897 --> 00:14:22,401
ナ〜ッハッハッハ…！
やめません！

233
00:14:22,401 --> 00:14:25,401
こうなったら…！

234
00:14:27,906 --> 00:14:30,909
やぁ〜〜！

235
00:14:30,909 --> 00:14:32,411
あ〜！

236
00:14:32,411 --> 00:14:34,413
あっ？ ふぎゃっ！

237
00:14:34,413 --> 00:14:37,416
どわぁ〜！
ん？

238
00:14:37,416 --> 00:14:39,918
あ！ ああ〜！

239
00:14:39,918 --> 00:14:41,920
おぼえてろ〜！

240
00:14:41,920 --> 00:14:45,420
わぁ〜〜！
クルック〜！

241
00:14:47,926 --> 00:14:50,429
(ゆずじいや) ジャムおじさ〜ん！

242
00:14:50,429 --> 00:14:52,931
えっ⁉
ゆずひめが⁉

243
00:14:52,931 --> 00:14:56,935
(ゆずじいや) そうなんです
ちょっと めをはなしたすきに…｡

244
00:14:56,935 --> 00:15:00,372
そう… ここにはきてないけど？

245
00:15:00,372 --> 00:15:03,375
まったく いったいどこへ…｡

246
00:15:03,375 --> 00:15:06,378
ぼく さがしてきますね｡
ああ｡

247
00:15:06,378 --> 00:15:08,880
わたしたちも さがしにいこうか｡

248
00:15:08,880 --> 00:15:10,882
はい！
アン！

249
00:15:10,882 --> 00:15:14,882
おお！ ありがとうございます！

250
00:15:21,393 --> 00:15:23,895
(クリｰム) できた！ みて みて！

251
00:15:23,895 --> 00:15:26,398
(メロン)
うわぁ！ じょうず じょうず！

252
00:15:26,398 --> 00:15:29,398
⚟クルック〜！⚞
(メロン:クリｰム) ん？

253
00:15:30,902 --> 00:15:33,905
あれ？ ゆずひめのハトさんだ｡

254
00:15:33,905 --> 00:15:36,408
どうしたの？ そんなにあわてて｡

255
00:15:36,408 --> 00:15:39,411
クルック〜 クルック〜！

256
00:15:39,411 --> 00:15:40,912
(クリｰム:メロン) えっ⁉

257
00:15:40,912 --> 00:15:43,415
ゆずひめが
まいごになっちゃった⁉

258
00:15:43,415 --> 00:15:46,418
すぐ さがしにいかなくっちゃ！

259
00:15:46,418 --> 00:15:50,422
カン カン カン…

260
00:15:50,422 --> 00:15:54,926
く〜 ゆずひめめ！
いまにみてろよ！

261
00:15:54,926 --> 00:15:57,429
(ゆずじいや) ひめさま〜！

262
00:15:57,429 --> 00:16:02,367
どこですか ひめさま〜！

263
00:16:02,367 --> 00:16:10,375
♬〜

264
00:16:10,375 --> 00:16:12,878
はぁ… どうしよう｡

265
00:16:12,878 --> 00:16:16,882
すっかり くらくなっちゃった…｡

266
00:16:16,882 --> 00:16:18,884
きゃっ！

267
00:16:18,884 --> 00:16:22,387
じいや
きっと しんぱいしてるよね…｡

268
00:16:22,387 --> 00:16:25,887
ごめんなさい じいや…｡

269
00:16:27,392 --> 00:16:28,892
え？

270
00:16:33,398 --> 00:16:35,400
ゆずひめ〜！

271
00:16:35,400 --> 00:16:38,403
いたら へんじして〜！

272
00:16:38,403 --> 00:16:40,903
ん？ あっ！

273
00:16:42,908 --> 00:16:44,910
みて おねえちゃん！

274
00:16:44,910 --> 00:16:47,410
ん？ あれは…｡

275
00:16:51,416 --> 00:16:53,919
あ…？

276
00:16:53,919 --> 00:16:56,421
(そらとぶベッドくん) やあ こんばんは｡

277
00:16:56,421 --> 00:17:00,425
あなたは… ゆめにでてきた…｡

278
00:17:00,425 --> 00:17:01,927
フフフフ…｡

279
00:17:01,927 --> 00:17:04,930
(クリｰム) ⚟あっ いた〜！⚞
(そらとぶベッドくん:ゆずひめ) ん？

280
00:17:04,930 --> 00:17:06,932
(メロン:クリｰム) ゆずひめ〜！

281
00:17:06,932 --> 00:17:10,936
メロンパンナちゃん
クリームパンダちゃん！

282
00:17:10,936 --> 00:17:12,938
そらとぶベッドくん？

283
00:17:12,938 --> 00:17:14,940
よろしくね ゆずひめ｡

284
00:17:14,940 --> 00:17:17,943
そらとぶベッドくんの
ゆめをみるとね➡

285
00:17:17,943 --> 00:17:21,446
まんげつのよるに
あそびにきてくれるの｡

286
00:17:21,446 --> 00:17:25,450
よぞらのおさんぽに
つれてってくれるんだよ｡

287
00:17:25,450 --> 00:17:27,953
フフ そのとおり！

288
00:17:27,953 --> 00:17:30,455
まぁ すてき！

289
00:17:30,455 --> 00:17:32,958
でも わたし…｡

290
00:17:32,958 --> 00:17:35,958
(さんにん) ん？

291
00:17:38,964 --> 00:17:41,466
どこだ ゆずひめ〜！

292
00:17:41,466 --> 00:17:44,469
むっ！

293
00:17:44,469 --> 00:17:46,972
おしろへ かえりたい？
うん｡

294
00:17:46,972 --> 00:17:48,974
きっと しんぱいしてるから｡

295
00:17:48,974 --> 00:17:51,476
ちゃんと あって
あやまらなきゃ…｡

296
00:17:51,476 --> 00:17:53,478
フフ わかった｡

297
00:17:53,478 --> 00:17:56,982
だいじょうぶ
きっと ゆるしてくれるわよ｡

298
00:17:56,982 --> 00:18:01,419
そうだよ｡
みんな… ありがとう！

299
00:18:01,419 --> 00:18:03,421
(みんな) え〜⁉

300
00:18:03,421 --> 00:18:05,924
ハ〜ヒフ〜ヘホ〜！

301
00:18:05,924 --> 00:18:07,425
(よにん) ばいきんまん！

302
00:18:07,425 --> 00:18:09,427
やい ゆずひめ！

303
00:18:09,427 --> 00:18:11,930
さっきは
よくも やってくれたな！

304
00:18:11,930 --> 00:18:15,934
やめてよ〜！
はやく はなして！

305
00:18:15,934 --> 00:18:21,439
うるさ〜い！ それ〜！
(よにん) わぁ〜！

306
00:18:21,439 --> 00:18:23,942
ガ〜ッハッハッハ…！

307
00:18:23,942 --> 00:18:26,942
⚟やめるんだ〜！⚞
ハヒ？

308
00:18:28,446 --> 00:18:30,448
(みんな) アンパンマン！

309
00:18:30,448 --> 00:18:32,450
でたな おじゃまむし！

310
00:18:32,450 --> 00:18:34,953
とまれ〜！
ああああ…｡

311
00:18:34,953 --> 00:18:38,957
グフフ こいつらが
どうなってもいいのか〜？

312
00:18:38,957 --> 00:18:40,959
(よにん) うぅ〜…｡

313
00:18:40,959 --> 00:18:42,961
ぐ…｡

314
00:18:42,961 --> 00:18:45,964
ナ〜ッハッハッハ…！

315
00:18:45,964 --> 00:18:49,467
ひめさま〜！
あ…！

316
00:18:49,467 --> 00:18:51,469
いま おたすけしますぞ〜！

317
00:18:51,469 --> 00:18:53,469
はいやぁ〜！

318
00:18:55,974 --> 00:18:57,475
な〜！

319
00:18:57,475 --> 00:18:59,978
(よにん) わぁ〜！

320
00:18:59,978 --> 00:19:02,414
フフフ…｡

321
00:19:02,414 --> 00:19:03,915
じいや！

322
00:19:03,915 --> 00:19:06,418
よくも やったな〜！

323
00:19:06,418 --> 00:19:07,919
うおっ！

324
00:19:07,919 --> 00:19:10,422
もう やめるんだ！
ばいきんまん！

325
00:19:10,422 --> 00:19:13,425
うるさい うるさ〜い！

326
00:19:13,425 --> 00:19:15,927
しょうぶは これからだ〜！

327
00:19:15,927 --> 00:19:18,930
ア〜ン パ〜ンチ！

328
00:19:18,930 --> 00:19:22,934
バイバイキ〜ン！

329
00:19:22,934 --> 00:19:25,937
おみごとですぞ〜｡

330
00:19:25,937 --> 00:19:28,937
(よにん) やった やった〜！

331
00:19:33,445 --> 00:19:37,449
じいや
しんぱいかけて ごめんなさい｡

332
00:19:37,449 --> 00:19:42,454
まったく…
でも ぶじで なによりです｡

333
00:19:42,454 --> 00:19:45,957
そらとぶベッドくんが
むかえにきてくれたのよ｡

334
00:19:45,957 --> 00:19:49,961
それで ぼくたちも
みつけることができたんだ｡

335
00:19:49,961 --> 00:19:51,963
ほぉ そうですか｡

336
00:19:51,963 --> 00:19:55,467
いやはや ありがとうございます｡

337
00:19:55,467 --> 00:19:58,470
ヘヘっ どういたしまして｡

338
00:19:58,470 --> 00:20:00,405
フフフフ…｡

339
00:20:00,405 --> 00:20:03,908
じゃあ いきましょ！
え？

340
00:20:03,908 --> 00:20:06,408
(さんにん) よぞらのおさんぽ！

341
00:20:13,418 --> 00:20:14,919
あっ！

342
00:20:14,919 --> 00:20:34,939
♬〜

343
00:20:34,939 --> 00:20:54,959
♬〜

344
00:20:54,959 --> 00:21:14,913
♬〜

345
00:21:14,913 --> 00:21:27,425
♬〜

346
00:21:27,425 --> 00:21:29,928
じつに すばらしい｡

347
00:21:29,928 --> 00:21:32,430
じいや｡
ほ？

348
00:21:32,430 --> 00:21:34,432
じいやがいったとおり➡

349
00:21:34,432 --> 00:21:36,935
せかいには
いろんなくにがあるのね｡

350
00:21:36,935 --> 00:21:39,938
わたし もっと
べんきょうしたくなっちゃった！

351
00:21:39,938 --> 00:21:41,940
ウフフフ｡

352
00:21:41,940 --> 00:21:44,442
ひめさま…｡

353
00:21:44,442 --> 00:21:47,946
(さんにん) フフフ…｡

354
00:21:47,946 --> 00:21:52,951
ほぅ〜 そらとぶベッドくんが？
はい｡

355
00:21:52,951 --> 00:21:56,454
みんなを よぞらのおさんぽへ
つれていってくれたんです｡

356
00:21:56,454 --> 00:21:59,457
まぁ すてき！
アン ア〜ン！

357
00:21:59,457 --> 00:22:01,893
え？ チーズもいきたかった？

358
00:22:01,893 --> 00:22:04,395
きっと また きてくれるよ｡

359
00:22:04,395 --> 00:22:07,899
⚟お〜い！⚞
(みんな) ん？

360
00:22:07,899 --> 00:22:12,904
(みんな) ハハハハ…！

361
00:22:12,904 --> 00:22:23,904
♬〜

