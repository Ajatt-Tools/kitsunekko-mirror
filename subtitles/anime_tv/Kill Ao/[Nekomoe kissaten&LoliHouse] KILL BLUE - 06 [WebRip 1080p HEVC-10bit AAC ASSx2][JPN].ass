Dialogue: 0,0:00:02.69,0:00:03.79,Dial_JP,,0,0,0,,キックオフ
Dialogue: 0,0:00:05.20,0:00:06.00,Dial_JP,,0,0,0,,頑張れ
Dialogue: 0,0:00:09.66,0:00:12.16,Dial_JP,,0,0,0,,僕たちの強みは　ただ一つ
Dialogue: 0,0:00:12.73,0:00:14.11,Dial_JP,,0,0,0,,数的優位
Dialogue: 0,0:00:14.88,0:00:18.41,Dial_JP,,0,0,0,,必ずフリーになる味方に　パスを回せば
Dialogue: 0,0:00:18.88,0:00:19.40,Dial_JP,,0,0,0,,来た
Dialogue: 0,0:00:20.62,0:00:21.33,Dial_JP,,0,0,0,,大狼くん
Dialogue: 0,0:00:25.39,0:00:26.92,Dial_JP,,0,0,0,,逆サイドにいたのに
Dialogue: 0,0:00:27.38,0:00:28.38,Dial_JP,,0,0,0,,速ぇ
Dialogue: 0,0:00:32.73,0:00:35.01,Dial_JP,,0,0,0,,じゃあ　まずは　挨拶代わりね
Dialogue: 0,0:00:35.42,0:00:36.53,Dial_JP,,0,0,0,,いきなり　シュート
Dialogue: 0,0:00:42.36,0:00:43.10,Dial_JP,,0,0,0,,あり
Dialogue: 0,0:00:46.35,0:00:47.43,Dial_JP,,0,0,0,,ウソだろ
Dialogue: 0,0:00:47.43,0:00:48.49,Dial_JP,,0,0,0,,ゴール　倒れた
Dialogue: 0,0:00:55.80,0:00:57.92,Dial_JP,,0,0,0,,んな思い切り　いったら　正体　バレるんじゃ
Dialogue: 0,0:00:57.92,0:00:58.82,Dial_JP,,0,0,0,,知るか
Dialogue: 0,0:00:58.82,0:01:00.01,Dial_JP,,0,0,0,,どう　ごまかすとか
Dialogue: 0,0:01:00.01,0:01:03.75,Dial_JP,,0,0,0,,そういうのはあいつをギャフンと言わせてからだ
Dialogue: 0,0:01:13.40,0:01:14.26,Dial_JP,,0,0,0,,ラインアウト
Dialogue: 0,0:01:14.64,0:01:16.48,Dial_JP,,0,0,0,,家庭科部チームで　キックイン
Dialogue: 0,0:01:18.99,0:01:20.14,Dial_JP,,0,0,0,,今の　マジか
Dialogue: 0,0:01:20.14,0:01:21.98,Dial_JP,,0,0,0,,結構すごかったんじゃね
Dialogue: 0,0:01:22.93,0:01:25.21,Dial_JP,,0,0,0,,結構どころじゃねえ
Dialogue: 0,0:01:25.21,0:01:26.73,Dial_JP,,0,0,0,,あの天馬が
Dialogue: 0,0:01:27.44,0:01:30.83,Dial_JP,,0,0,0,,キック力だけなら　全国トップクラスじゃね
Dialogue: 0,0:01:32.29,0:01:33.49,Dial_JP,,0,0,0,,やる
Dialogue: 0,0:01:33.49,0:01:35.75,Dial_JP,,0,0,0,,とりあえず　蹴るだけならな
Dialogue: 0,0:01:36.17,0:01:39.00,Dial_JP,,0,0,0,,缶蹴りの飛距離で　負けたことはねえ
Dialogue: 0,0:03:16.03,0:03:17.13,Dial_JP,,0,0,0,,やるぅ　オガー
Dialogue: 0,0:03:17.13,0:03:21.38,Dial_JP,,0,0,0,,もはや目立たずひっそり生きてくみたいな\Nスタンス忘れてない
Dialogue: 0,0:03:21.38,0:03:23.57,Dial_JP,,0,0,0,,すごいな　大狼くん
Dialogue: 0,0:03:23.57,0:03:24.97,Dial_JP,,0,0,0,,すごい　すごい
Dialogue: 0,0:03:24.97,0:03:27.44,Dial_JP,,0,0,0,,これ　もしかして　いい勝負できるんじゃない
Dialogue: 0,0:03:28.10,0:03:28.69,Dial_JP,,0,0,0,,あれ
Dialogue: 0,0:03:29.46,0:03:30.47,Dial_JP,,0,0,0,,キックインは僕が
Dialogue: 0,0:03:30.91,0:03:32.00,Dial_JP,,0,0,0,,じゃあ　頼んます
Dialogue: 0,0:03:34.22,0:03:34.89,Dial_JP,,0,0,0,,どうした
Dialogue: 0,0:03:34.89,0:03:35.45,Dial_JP,,0,0,0,,シン
Dialogue: 0,0:03:38.27,0:03:39.20,Dial_JP,,0,0,0,,古波鮫くん
Dialogue: 0,0:03:40.18,0:03:41.68,Dial_JP,,0,0,0,,おまっ　おしゃぶりは
Dialogue: 0,0:03:41.68,0:03:43.30,Dial_JP,,0,0,0,,ど…ど…　どっかいっちゃった
Dialogue: 0,0:03:43.87,0:03:44.79,Dial_JP,,0,0,0,,ト…　トド
Dialogue: 0,0:03:44.79,0:03:47.27,Dial_JP,,0,0,0,,もしかして　シュート止めにいったときか
Dialogue: 0,0:03:47.27,0:03:49.11,Dial_JP,,0,0,0,,ロス　ブラン　コス
Dialogue: 0,0:03:49.11,0:03:52.60,Dial_JP,,0,0,0,,こいつ　おしゃぶりないと\Nあがり症のポンコツになるんすよ
Dialogue: 0,0:03:53.57,0:03:57.61,Dial_JP,,0,0,0,,それ以前になんで\Nずっとくわえとんねんとは思ってたけどね
Dialogue: 0,0:03:57.61,0:03:59.01,Dial_JP,,0,0,0,,ですよね
Dialogue: 0,0:03:59.33,0:04:02.57,Dial_JP,,0,0,0,,ああ　かすってたから外れたんか
Dialogue: 0,0:04:03.52,0:04:05.27,Dial_JP,,0,0,0,,スペアとかないの
Dialogue: 0,0:04:07.56,0:04:10.15,Dial_JP,,0,0,0,,えっと　教室のかばんにあるって
Dialogue: 0,0:04:10.69,0:04:11.62,Dial_JP,,0,0,0,,取ってきます
Dialogue: 0,0:04:12.05,0:04:12.99,Dial_JP,,0,0,0,,私も行くよ
Dialogue: 0,0:04:13.41,0:04:14.82,Dial_JP,,0,0,0,,お願いします
Dialogue: 0,0:04:15.35,0:04:16.35,Dial_JP,,0,0,0,,しゃあねえ
Dialogue: 0,0:04:16.35,0:04:18.07,Dial_JP,,0,0,0,,とりあえず　ここに立っとけ
Dialogue: 0,0:04:18.07,0:04:19.63,Dial_JP,,0,0,0,,少しは邪魔になんだろ
Dialogue: 0,0:04:20.05,0:04:23.59,Dial_JP,,0,0,0,,アドバンテージ　なくなって\N普通に２対２になっちゃった
Dialogue: 0,0:04:24.02,0:04:24.95,Dial_JP,,0,0,0,,おーい
Dialogue: 0,0:04:24.95,0:04:27.54,Dial_JP,,0,0,0,,そろそろ再開してもらっていい
Dialogue: 0,0:04:30.06,0:04:32.99,Dial_JP,,0,0,0,,ノレンに膝枕で　よしよししてほしい
Dialogue: 0,0:04:32.99,0:04:34.33,Dial_JP,,0,0,0,,それが夢なん
Dialogue: 0,0:04:34.80,0:04:36.05,Dial_JP,,0,0,0,,て言ってました
Dialogue: 0,0:04:36.05,0:04:37.88,Dial_JP,,0,0,0,,いちいち　クセが強い
Dialogue: 0,0:04:41.49,0:04:42.35,Dial_JP,,0,0,0,,こいつ
Dialogue: 0,0:04:43.24,0:04:43.86,Dial_JP,,0,0,0,,あった
Dialogue: 0,0:04:44.77,0:04:46.53,Dial_JP,,0,0,0,,ケース付きでよかった
Dialogue: 0,0:04:46.53,0:04:48.68,Dial_JP,,0,0,0,,むき出しだったら　どうしようかと
Dialogue: 0,0:04:48.98,0:04:49.50,Dial_JP,,0,0,0,,よし
Dialogue: 0,0:04:49.50,0:04:50.45,Dial_JP,,0,0,0,,早く戻ろう
Dialogue: 0,0:04:52.28,0:04:55.04,Dial_JP,,0,0,0,,けど　訳ありっぽいよ　おしゃぶり
Dialogue: 0,0:04:56.17,0:04:57.56,Dial_JP,,0,0,0,,何か聞いたの
Dialogue: 0,0:04:57.56,0:04:58.20,Dial_JP,,0,0,0,,うん
Dialogue: 0,0:04:58.56,0:05:00.60,Dial_JP,,0,0,0,,「なんで　そんなもん　くわえてんの」って
Dialogue: 0,0:05:00.60,0:05:01.79,Dial_JP,,0,0,0,,質問　直球
Dialogue: 0,0:05:02.13,0:05:02.75,Dial_JP,,0,0,0,,いや
Dialogue: 0,0:05:02.75,0:05:04.74,Dial_JP,,0,0,0,,むしろ聞かねえほうが　おかしいだろ
Dialogue: 0,0:05:05.66,0:05:09.46,Dial_JP,,0,0,0,,落ち着くからだけど　なんでかっていわれると
Dialogue: 0,0:05:10.09,0:05:12.44,Dial_JP,,0,0,0,,今は　もういないお母さんは
Dialogue: 0,0:05:12.44,0:05:15.00,Dial_JP,,0,0,0,,優しい笑顔で　おしゃぶりをくれた
Dialogue: 0,0:05:15.50,0:05:18.30,Dial_JP,,0,0,0,,その感触だけが　ぼんやり残ってる
Dialogue: 0,0:05:18.89,0:05:22.30,Dial_JP,,0,0,0,,もしかしたら　それが　関係しているかもしれないね
Dialogue: 0,0:05:22.86,0:05:25.28,Dial_JP,,0,0,0,,結構ヘビーな過去があるかもね
Dialogue: 0,0:05:25.28,0:05:27.37,Dial_JP,,0,0,0,,膝枕くらい　してあげれば
Dialogue: 0,0:05:27.37,0:05:30.02,Dial_JP,,0,0,0,,いや　それと膝枕は別でしょう
Dialogue: 0,0:05:30.41,0:05:32.81,Dial_JP,,0,0,0,,よし　試合はどうなった
Dialogue: 0,0:05:35.33,0:05:36.36,Dial_JP,,0,0,0,,何があったん
Dialogue: 0,0:05:37.18,0:05:37.98,Dial_JP,,0,0,0,,おかえり
Dialogue: 0,0:05:38.49,0:05:43.00,Dial_JP,,0,0,0,,天馬くんの殺人シュートを\N神セーブ連発で　シンくん大活躍
Dialogue: 0,0:05:43.00,0:05:45.37,Dial_JP,,0,0,0,,活躍っていうか袋だたき
Dialogue: 0,0:05:45.37,0:05:46.90,Dial_JP,,0,0,0,,インターセプト
Dialogue: 0,0:05:48.09,0:05:50.02,Dial_JP,,0,0,0,,ヤバ　早く　これを
Dialogue: 0,0:05:51.02,0:05:53.42,Dial_JP,,0,0,0,,あれ以上　食らったら　間違いなく死ぬぞ
Dialogue: 0,0:05:53.95,0:05:54.88,Dial_JP,,0,0,0,,死ぬの
Dialogue: 0,0:05:54.88,0:05:55.83,Dial_JP,,0,0,0,,けど　どうやって
Dialogue: 0,0:05:55.83,0:05:56.80,Dial_JP,,0,0,0,,投げろ
Dialogue: 0,0:05:56.80,0:05:58.88,Dial_JP,,0,0,0,,たぶん　いちばん運動神経いいし
Dialogue: 0,0:05:59.33,0:06:01.84,Dial_JP,,0,0,0,,ああ　もう　なんなん　これ
Dialogue: 0,0:06:01.84,0:06:02.87,Dial_JP,,0,0,0,,シンくん
Dialogue: 0,0:06:02.87,0:06:05.09,Dial_JP,,0,0,0,,新しいおしゃぶりだよ
Dialogue: 0,0:06:17.29,0:06:20.78,Dial_JP,,0,0,0,,悪いが　もう今までのようにはいかないよ
Dialogue: 0,0:06:20.78,0:06:23.30,Dial_JP,,0,0,0,,足技には　僕も自信があるんだ
Dialogue: 0,0:06:23.70,0:06:24.60,Dial_JP,,0,0,0,,止めた
Dialogue: 0,0:06:24.60,0:06:26.99,Dial_JP,,0,0,0,,さっきまでの雰囲気と違いすぎない
Dialogue: 0,0:06:26.99,0:06:28.17,Dial_JP,,0,0,0,,シンくん
Dialogue: 0,0:06:28.17,0:06:28.74,Dial_JP,,0,0,0,,シン
Dialogue: 0,0:06:29.62,0:06:30.73,Dial_JP,,0,0,0,,よし　いこう
Dialogue: 0,0:06:31.05,0:06:32.51,Dial_JP,,0,0,0,,勝負は　これからだ
Dialogue: 0,0:06:32.51,0:06:35.71,Dial_JP,,0,0,0,,なんか　お前だけ　バトル系の人になっちまったな
Dialogue: 0,0:06:37.59,0:06:38.28,Dial_JP,,0,0,0,,いけっ
Dialogue: 0,0:06:38.28,0:06:39.14,Dial_JP,,0,0,0,,頑張れ
Dialogue: 0,0:06:45.89,0:06:48.80,Dial_JP,,0,0,0,,幼稚なフェイントだけど　単純に速い
Dialogue: 0,0:06:49.60,0:06:50.81,Dial_JP,,0,0,0,,んだ　くそ
Dialogue: 0,0:06:57.81,0:06:59.67,Dial_JP,,0,0,0,,チェンジ　オブ　ペースの一瞬で
Dialogue: 0,0:07:00.16,0:07:00.69,Dial_JP,,0,0,0,,チッ
Dialogue: 0,0:07:00.99,0:07:01.86,Dial_JP,,0,0,0,,これだ
Dialogue: 0,0:07:02.29,0:07:05.20,Dial_JP,,0,0,0,,点が入らないのは　おしゃぶりの活躍だけじゃない
Dialogue: 0,0:07:05.20,0:07:07.20,Dial_JP,,0,0,0,,どう見ても素人なのに
Dialogue: 0,0:07:07.81,0:07:08.91,Dial_JP,,0,0,0,,あいつ　何者だ
Dialogue: 0,0:07:11.88,0:07:12.81,Dial_JP,,0,0,0,,ラインアウト
Dialogue: 0,0:07:13.16,0:07:15.23,Dial_JP,,0,0,0,,ああ　惜しい
Dialogue: 0,0:07:15.85,0:07:17.30,Dial_JP,,0,0,0,,すごいよ
Dialogue: 0,0:07:17.30,0:07:19.04,Dial_JP,,0,0,0,,なんか　どんどん　うまくなってない
Dialogue: 0,0:07:19.49,0:07:23.08,Dial_JP,,0,0,0,,いや　打倒　天馬ってのは　もちろん　あるんだけど
Dialogue: 0,0:07:23.70,0:07:25.48,Dial_JP,,0,0,0,,それは　それとして
Dialogue: 0,0:07:26.74,0:07:29.68,Dial_JP,,0,0,0,,久しぶりに　スポーツやると　めっちゃ楽しいな
Dialogue: 0,0:07:29.68,0:07:30.30,Dial_JP,,0,0,0,,うん
Dialogue: 0,0:07:31.24,0:07:32.41,Dial_JP,,0,0,0,,久しぶりなの
Dialogue: 0,0:07:32.41,0:07:34.27,Dial_JP,,0,0,0,,大人あるあるっすね　それ
Dialogue: 0,0:07:34.61,0:07:38.20,Dial_JP,,0,0,0,,緊張感はあるんだけど　死なないってのがいいな
Dialogue: 0,0:07:38.20,0:07:41.02,Dial_JP,,0,0,0,,トライ　アンド　エラーしながら\N何度も挑むってのは
Dialogue: 0,0:07:41.46,0:07:42.53,Dial_JP,,0,0,0,,ワクワクすらあ
Dialogue: 0,0:07:47.39,0:07:48.74,Dial_JP,,0,0,0,,なあ　天馬
Dialogue: 0,0:07:49.01,0:07:49.48,Dial_JP,,0,0,0,,うん
Dialogue: 0,0:07:50.04,0:07:53.49,Dial_JP,,0,0,0,,お前の　大狼を特別視する感じってさ
Dialogue: 0,0:07:54.36,0:07:57.08,Dial_JP,,0,0,0,,本当は　ライバルを　求めてるんじゃないのか
Dialogue: 0,0:07:58.50,0:08:02.09,Dial_JP,,0,0,0,,天性の体格を持ちながらも　努力を惜しまない
Dialogue: 0,0:08:02.52,0:08:05.20,Dial_JP,,0,0,0,,どの競技も　ぶっちぎりで孤高
Dialogue: 0,0:08:05.59,0:08:09.18,Dial_JP,,0,0,0,,だからこそ　対等に戦える相手に\N飢えてるんじゃないのか
Dialogue: 0,0:08:09.65,0:08:10.80,Dial_JP,,0,0,0,,いや　全然
Dialogue: 0,0:08:11.85,0:08:13.67,Dial_JP,,0,0,0,,俺　ぶっちぎるのが好きだから
Dialogue: 0,0:08:14.20,0:08:16.56,Dial_JP,,0,0,0,,100対０で勝てるなら　そうしたい
Dialogue: 0,0:08:18.07,0:08:20.06,Dial_JP,,0,0,0,,全力で間違えた
Dialogue: 0,0:08:20.50,0:08:25.22,Dial_JP,,0,0,0,,３競技やるのはね　絞れないくらい\N３つ全部が大好きだから
Dialogue: 0,0:08:25.60,0:08:29.91,Dial_JP,,0,0,0,,それと　リョーヘーが言ってた\N「孤高」に　むしろ　なりたいんだよ
Dialogue: 0,0:08:30.38,0:08:32.61,Dial_JP,,0,0,0,,どのスポーツでも　レジェンドっているじゃん
Dialogue: 0,0:08:33.02,0:08:35.92,Dial_JP,,0,0,0,,で　現役選手が　どんだけ活躍したって
Dialogue: 0,0:08:35.92,0:08:38.02,Dial_JP,,0,0,0,,絶対そいつらと比較されるんだよ
Dialogue: 0,0:08:38.36,0:08:39.63,Dial_JP,,0,0,0,,それが　ムカつく
Dialogue: 0,0:08:40.06,0:08:42.92,Dial_JP,,0,0,0,,けど　３つの競技で　伝説　残したら　どうよ
Dialogue: 0,0:08:43.28,0:08:44.84,Dial_JP,,0,0,0,,ヌルい意味じゃなくて
Dialogue: 0,0:08:45.21,0:08:48.42,Dial_JP,,0,0,0,,ぐうの音も出ない　オンリーワンになるんだ　俺
Dialogue: 0,0:08:49.20,0:08:53.28,Dial_JP,,0,0,0,,いろいろと突き抜けすぎて　いっそ　すがすがしいわ
Dialogue: 0,0:08:53.28,0:08:56.43,Dial_JP,,0,0,0,,けど　幼なじみじゃなきゃ　友達やめてるな
Dialogue: 0,0:08:56.77,0:09:00.00,Dial_JP,,0,0,0,,てわけで　ライバルとかは　別に求めてないんだけど
Dialogue: 0,0:09:00.78,0:09:03.74,Dial_JP,,0,0,0,,孤高ゆえのフラストレーションも　確かにあるね
Dialogue: 0,0:09:07.82,0:09:09.25,Dial_JP,,0,0,0,,よっしゃ
Dialogue: 0,0:09:09.25,0:09:10.66,Dial_JP,,0,0,0,,うん　いいね
Dialogue: 0,0:09:10.66,0:09:11.82,Dial_JP,,0,0,0,,おもしろくなってきた
Dialogue: 0,0:09:13.90,0:09:17.79,Dial_JP,,0,0,0,,ぶっちぎりたいっていっても\N死体蹴りする趣味はないからさ
Dialogue: 0,0:09:18.19,0:09:20.00,Dial_JP,,0,0,0,,なかなか　いないんだよね
Dialogue: 0,0:09:20.62,0:09:23.44,Dial_JP,,0,0,0,,全力で　じゃれても　壊れないおもちゃは
Dialogue: 0,0:09:24.84,0:09:26.05,Dial_JP,,0,0,0,,よーし
Dialogue: 0,0:09:26.05,0:09:28.26,Dial_JP,,0,0,0,,こっから本気　出すぞ
Dialogue: 0,0:09:29.76,0:09:31.59,Dial_JP,,0,0,0,,ハッタリじゃないな
Dialogue: 0,0:09:31.59,0:09:35.26,Dial_JP,,0,0,0,,てか　真剣に　あんなこと言うやつは逆に初めてだわ
Dialogue: 0,0:09:39.14,0:09:41.39,Dial_JP,,0,0,0,,よく勘違いされるけど
Dialogue: 0,0:09:41.39,0:09:45.02,Dial_JP,,0,0,0,,天馬が本気　出さねえのは\Nなめプとは　ちょっと違う
Dialogue: 0,0:09:46.14,0:09:49.26,Dial_JP,,0,0,0,,あいつは常に　自分を　高めることしか考えていない
Dialogue: 0,0:09:49.79,0:09:53.69,Dial_JP,,0,0,0,,そのためには　どんな相手でも\N手を抜いたりはしない
Dialogue: 0,0:09:54.24,0:09:58.21,Dial_JP,,0,0,0,,けど　圧倒しすぎた結果　勝負を諦められても困る
Dialogue: 0,0:09:58.79,0:10:02.84,Dial_JP,,0,0,0,,だから　相手に応じて\Nプレイの種類や　動ける範囲を限定する
Dialogue: 0,0:10:03.35,0:10:07.04,Dial_JP,,0,0,0,,つまりは　向上心ゆえの縛りプレイ
Dialogue: 0,0:10:07.52,0:10:09.05,Dial_JP,,0,0,0,,誇っていいぜ
Dialogue: 0,0:10:09.54,0:10:13.70,Dial_JP,,0,0,0,,どの競技でも　天馬が縛りを\N取っ払うことは　めったにねえ
Dialogue: 0,0:10:22.14,0:10:25.94,Dial_JP,,0,0,0,,ただ　ドリブルしてるだけなのに　まるで岩だ
Dialogue: 0,0:10:28.09,0:10:28.63,Dial_JP,,0,0,0,,チッ
Dialogue: 0,0:10:32.60,0:10:33.36,Dial_JP,,0,0,0,,速い
Dialogue: 0,0:10:48.58,0:10:49.65,Dial_JP,,0,0,0,,天馬　決めた
Dialogue: 0,0:10:49.65,0:10:51.41,Dial_JP,,0,0,0,,さすが超人
Dialogue: 0,0:10:51.41,0:10:52.60,Dial_JP,,0,0,0,,文句なし
Dialogue: 0,0:10:52.60,0:10:54.34,Dial_JP,,0,0,0,,圧巻の３人抜き
Dialogue: 0,0:10:56.02,0:10:57.87,Dial_JP,,0,0,0,,そして　前半終了
Dialogue: 0,0:10:57.87,0:11:00.56,Dial_JP,,0,0,0,,天馬チーム　一歩リードで折り返しだ
Dialogue: 0,0:11:00.97,0:11:03.50,Dial_JP,,0,0,0,,すごいし　それ以上に
Dialogue: 0,0:11:03.50,0:11:06.65,Dial_JP,,0,0,0,,オガ寄りの私らも　つい　アガっちゃうよ　これは
Dialogue: 0,0:11:07.08,0:11:09.83,Dial_JP,,0,0,0,,一発で　こんだけ　盛り上げるのは　さすが
Dialogue: 0,0:11:09.83,0:11:11.65,Dial_JP,,0,0,0,,スーパースター感あるわ
Dialogue: 0,0:11:13.27,0:11:16.95,Dial_JP,,0,0,0,,３人がかりでもダメって　いったいどうすれば
Dialogue: 0,0:11:17.89,0:11:19.91,Dial_JP,,0,0,0,,俺だけで　やらせてくれないかな
Dialogue: 0,0:11:21.02,0:11:22.29,Dial_JP,,0,0,0,,何か勝算が
Dialogue: 0,0:11:22.29,0:11:23.51,Dial_JP,,0,0,0,,いや　ない
Dialogue: 0,0:11:24.13,0:11:27.07,Dial_JP,,0,0,0,,まあ　元はといえば俺から売ったケンカだし
Dialogue: 0,0:11:27.59,0:11:28.79,Dial_JP,,0,0,0,,いや　それは　いいか
Dialogue: 0,0:11:30.43,0:11:32.01,Dial_JP,,0,0,0,,とにかく　やらせてくれ
Dialogue: 0,0:11:32.01,0:11:32.76,Dial_JP,,0,0,0,,頼む
Dialogue: 0,0:11:35.92,0:11:37.23,Dial_JP,,0,0,0,,後半開始
Dialogue: 0,0:11:37.23,0:11:39.80,Dial_JP,,0,0,0,,家庭科部チーム　打つ手あんのか
Dialogue: 0,0:11:40.49,0:11:42.71,Dial_JP,,0,0,0,,って　マンツーマン
Dialogue: 0,0:11:43.16,0:11:44.92,Dial_JP,,0,0,0,,勝てると思ってんの
Dialogue: 0,0:11:45.52,0:11:47.39,Dial_JP,,0,0,0,,２点目　もらっちゃうよ
Dialogue: 0,0:11:50.90,0:11:53.13,Dial_JP,,0,0,0,,かわせない　なんで
Dialogue: 0,0:11:53.48,0:11:55.20,Dial_JP,,0,0,0,,どうなってんだ
Dialogue: 0,0:11:55.20,0:11:57.77,Dial_JP,,0,0,0,,並外れた運動能力があったとしても
Dialogue: 0,0:11:57.77,0:11:59.62,Dial_JP,,0,0,0,,なんで食らいつけるんだよ
Dialogue: 0,0:11:59.91,0:12:00.89,Dial_JP,,0,0,0,,なんだろう
Dialogue: 0,0:12:01.37,0:12:03.24,Dial_JP,,0,0,0,,大狼くん　なんかちょっと
Dialogue: 0,0:12:03.99,0:12:04.92,Dial_JP,,0,0,0,,楽しそう？
Dialogue: 0,0:12:06.80,0:12:09.26,Dial_JP,,0,0,0,,別に勝算も策も　マジでねえ
Dialogue: 0,0:12:09.76,0:12:12.82,Dial_JP,,0,0,0,,ただ　もっとガキの頃は負けず嫌いで
Dialogue: 0,0:12:13.39,0:12:15.12,Dial_JP,,0,0,0,,どんなくだらない勝負も
Dialogue: 0,0:12:15.12,0:12:17.19,Dial_JP,,0,0,0,,いちいち本気でやってた
Dialogue: 0,0:12:17.75,0:12:19.45,Dial_JP,,0,0,0,,けど　大人になるにつれ
Dialogue: 0,0:12:19.76,0:12:22.23,Dial_JP,,0,0,0,,そもそも　むきになることもなくなった
Dialogue: 0,0:12:22.91,0:12:25.90,Dial_JP,,0,0,0,,仕事で求められるのは確実な成果
Dialogue: 0,0:12:26.36,0:12:29.43,Dial_JP,,0,0,0,,だが　実績と年を積み重ねるほど
Dialogue: 0,0:12:29.43,0:12:32.40,Dial_JP,,0,0,0,,なぜか人生がつまらなくなっていく
Dialogue: 0,0:12:32.96,0:12:35.45,Dial_JP,,0,0,0,,あの頃の気持ちを　思い出しただけさ
Dialogue: 0,0:12:36.02,0:12:37.19,Dial_JP,,0,0,0,,やっぱ負けねえぞ
Dialogue: 0,0:12:37.19,0:12:39.45,Dial_JP,,0,0,0,,って　バチバチやんのはいいな
Dialogue: 0,0:12:39.45,0:12:40.93,Dial_JP,,0,0,0,,ありがとよ
Dialogue: 0,0:12:40.93,0:12:43.45,Dial_JP,,0,0,0,,おかげでめちゃくちゃ楽しいぜ　今
Dialogue: 0,0:12:44.78,0:12:46.65,Dial_JP,,0,0,0,,なんかやけに老けたこと言うね
Dialogue: 0,0:12:47.72,0:12:49.77,Dial_JP,,0,0,0,,けどまあ　同感だね
Dialogue: 0,0:12:49.77,0:12:52.05,Dial_JP,,0,0,0,,やっぱ勝負はこうでなきゃ
Dialogue: 0,0:12:52.05,0:12:54.67,Dial_JP,,0,0,0,,そんで最後は　俺が勝つ
Dialogue: 0,0:12:57.40,0:12:58.38,Dial_JP,,0,0,0,,すげえ攻防
Dialogue: 0,0:12:58.38,0:13:00.18,Dial_JP2,,0,0,0,,いけ
Dialogue: 0,0:12:58.38,0:13:00.18,Dial_JP,,0,0,0,,お互い一歩も譲らねえ
Dialogue: 0,0:13:02.47,0:13:05.79,Dial_JP,,0,0,0,,ついさっきまで食らいつくので\N精いっぱいだったのに
Dialogue: 0,0:13:06.48,0:13:08.54,Dial_JP,,0,0,0,,フィジカルで天馬が負けるなんてありえねえ
Dialogue: 0,0:13:08.98,0:13:09.81,Dial_JP,,0,0,0,,先読み
Dialogue: 0,0:13:10.27,0:13:10.94,Dial_JP,,0,0,0,,いや
Dialogue: 0,0:13:10.94,0:13:12.65,Dial_JP,,0,0,0,,呼吸をつかんできてる
Dialogue: 0,0:13:13.22,0:13:16.19,Dial_JP,,0,0,0,,表のスポーツだろうが　裏の殺し合いだろうが
Dialogue: 0,0:13:16.52,0:13:18.78,Dial_JP,,0,0,0,,一対一なら根っこは同じ
Dialogue: 0,0:13:18.78,0:13:22.32,Dial_JP,,0,0,0,,相手の来る瞬間を見極めて　それに合わせること
Dialogue: 0,0:13:30.42,0:13:31.79,Dial_JP,,0,0,0,,キックのぶつかり合い
Dialogue: 0,0:13:31.79,0:13:33.82,Dial_JP,,0,0,0,,絶対俺が勝つ
Dialogue: 0,0:13:34.98,0:13:36.27,Dial_JP,,0,0,0,,気合いは互角
Dialogue: 0,0:13:36.99,0:13:39.24,Dial_JP,,0,0,0,,いや　互角じゃねえわ
Dialogue: 0,0:13:39.24,0:13:41.80,Dial_JP,,0,0,0,,きっちり根に持ってんぞ　この野郎
Dialogue: 0,0:13:43.46,0:13:45.29,Dial_JP,,0,0,0,,家庭科部ナメんなよ
Dialogue: 0,0:13:45.29,0:13:47.18,Dial_JP,,0,0,0,,つうか反省して改めろ
Dialogue: 0,0:13:47.68,0:13:50.73,Dial_JP,,0,0,0,,自分にとって便利だからみたいな意味じゃなく
Dialogue: 0,0:13:50.73,0:13:53.65,Dial_JP,,0,0,0,,作ってくれたことに対しての感謝を込めて
Dialogue: 0,0:13:55.62,0:13:57.61,Dial_JP,,0,0,0,,おにぎり作ってもらったら
Dialogue: 0,0:13:57.99,0:14:00.69,Dial_JP,,0,0,0,,ちゃんと「ありがとう」言わんかい
Dialogue: 0,0:14:10.50,0:14:12.32,Dial_JP,,0,0,0,,決まった
Dialogue: 0,0:14:12.32,0:14:13.35,Dial_JP,,0,0,0,,ゴール
Dialogue: 0,0:14:13.35,0:14:15.28,Dial_JP,,0,0,0,,ウソだろ　やり返した
Dialogue: 0,0:14:15.28,0:14:18.25,Dial_JP,,0,0,0,,家庭科部チームが　まさかの同点弾
Dialogue: 0,0:14:19.88,0:14:21.35,Dial_JP,,0,0,0,,やった
Dialogue: 0,0:14:29.05,0:14:30.94,Dial_JP,,0,0,0,,ったく　どうしちまったんだよ
Dialogue: 0,0:14:30.94,0:14:32.09,Dial_JP,,0,0,0,,競り負けるなんて
Dialogue: 0,0:14:32.51,0:14:33.73,Dial_JP,,0,0,0,,とっとと取り返すぞ
Dialogue: 0,0:14:52.62,0:14:53.59,Dial_JP,,0,0,0,,まいった
Dialogue: 0,0:14:54.33,0:14:56.22,Dial_JP,,0,0,0,,これ以上はできない
Dialogue: 0,0:14:56.80,0:14:59.33,Dial_JP,,0,0,0,,ギブアップ　俺の負けだ
Dialogue: 0,0:15:03.90,0:15:04.97,Dial_JP,,0,0,0,,今　なんて
Dialogue: 0,0:15:04.97,0:15:06.04,Dial_JP,,0,0,0,,ギブアップ
Dialogue: 0,0:15:06.04,0:15:07.01,Dial_JP,,0,0,0,,これで終わり？
Dialogue: 0,0:15:07.38,0:15:09.30,Dial_JP,,0,0,0,,ギブアップ　なんでここで
Dialogue: 0,0:15:09.30,0:15:11.44,Dial_JP,,0,0,0,,そっちはなんともないの
Dialogue: 0,0:15:11.44,0:15:13.93,Dial_JP,,0,0,0,,少なからずショックだねそれも
Dialogue: 0,0:15:14.83,0:15:16.82,Dial_JP,,0,0,0,,さっきの競り合いで痛めた
Dialogue: 0,0:15:17.37,0:15:20.02,Dial_JP,,0,0,0,,このまま無理をすれば　本業に支障が出る
Dialogue: 0,0:15:20.93,0:15:22.55,Dial_JP,,0,0,0,,軽んじる気はないけど
Dialogue: 0,0:15:23.04,0:15:26.25,Dial_JP,,0,0,0,,むちゃをするのは自分が\N懸けてる競技だけって決めてる
Dialogue: 0,0:15:26.79,0:15:28.91,Dial_JP,,0,0,0,,悔しいけど　続行不能だ
Dialogue: 0,0:15:30.31,0:15:31.15,Dial_JP,,0,0,0,,勝った
Dialogue: 0,0:15:32.65,0:15:34.08,Dial_JP,,0,0,0,,ゲームセット
Dialogue: 0,0:15:34.53,0:15:37.58,Dial_JP,,0,0,0,,マジかよ　天馬が負けた
Dialogue: 0,0:15:40.38,0:15:43.23,Dial_JP,,0,0,0,,そりゃ　こんな幕切れじゃあな
Dialogue: 0,0:15:44.10,0:15:45.49,Dial_JP,,0,0,0,,しようがない
Dialogue: 0,0:15:45.49,0:15:46.74,Dial_JP,,0,0,0,,甘んじて受けるよ
Dialogue: 0,0:15:47.60,0:15:48.84,Dial_JP,,0,0,0,,それより　リョーヘー
Dialogue: 0,0:15:49.13,0:15:50.73,Dial_JP,,0,0,0,,肩貸してくんない
Dialogue: 0,0:15:50.73,0:15:52.56,Dial_JP,,0,0,0,,思ったより歩くのきつい
Dialogue: 0,0:15:53.54,0:15:56.16,Dial_JP,,0,0,0,,でけえし重いんだぜ　お前
Dialogue: 0,0:15:56.16,0:15:57.09,Dial_JP,,0,0,0,,知ってる
Dialogue: 0,0:15:58.93,0:16:02.11,Dial_JP,,0,0,0,,ねえ　テーピングって救急箱の中
Dialogue: 0,0:16:02.82,0:16:03.53,Dial_JP,,0,0,0,,うん
Dialogue: 0,0:16:08.15,0:16:09.20,Dial_JP,,0,0,0,,足出して
Dialogue: 0,0:16:09.64,0:16:10.86,Dial_JP,,0,0,0,,専門外だけど
Dialogue: 0,0:16:10.86,0:16:14.58,Dial_JP,,0,0,0,,何もしないよりはマシに\Nできるんじゃないかな　たぶん
Dialogue: 0,0:16:16.63,0:16:19.10,Dial_JP,,0,0,0,,家庭科部の　部長さん？
Dialogue: 0,0:16:19.10,0:16:20.28,Dial_JP,,0,0,0,,白石ね
Dialogue: 0,0:16:20.28,0:16:21.55,Dial_JP,,0,0,0,,白石千里
Dialogue: 0,0:16:22.09,0:16:23.28,Dial_JP,,0,0,0,,ほら　靴下も
Dialogue: 0,0:16:25.01,0:16:25.86,Dial_JP,,0,0,0,,なんで
Dialogue: 0,0:16:26.49,0:16:29.55,Dial_JP,,0,0,0,,俺まだ約束してた謝罪とかしてないよ
Dialogue: 0,0:16:29.97,0:16:31.96,Dial_JP,,0,0,0,,それに敵だよ　そもそも
Dialogue: 0,0:16:32.26,0:16:34.67,Dial_JP,,0,0,0,,何を言っとるんだね　君は
Dialogue: 0,0:16:34.67,0:16:35.84,Dial_JP,,0,0,0,,まったく
Dialogue: 0,0:16:35.84,0:16:39.77,Dial_JP,,0,0,0,,戦闘民族の頭の中は　敵か味方しかおらんのか
Dialogue: 0,0:16:40.31,0:16:44.19,Dial_JP,,0,0,0,,まあ　私も君の発言にイラッときたのは事実だし
Dialogue: 0,0:16:44.19,0:16:46.49,Dial_JP,,0,0,0,,なんなら率先して
Dialogue: 0,0:16:46.49,0:16:49.05,Dial_JP,,0,0,0,,けど　それとこれとは別問題
Dialogue: 0,0:16:49.05,0:16:51.09,Dial_JP,,0,0,0,,困ったときはお互い様
Dialogue: 0,0:16:51.48,0:16:53.11,Dial_JP,,0,0,0,,それだけのことじゃないか
Dialogue: 0,0:16:54.42,0:16:55.62,Dial_JP,,0,0,0,,うん　できた
Dialogue: 0,0:16:58.93,0:17:01.60,Dial_JP,,0,0,0,,そんな感じでやってるから　うちの部は
Dialogue: 0,0:17:02.27,0:17:03.92,Dial_JP,,0,0,0,,だからとは言わないが
Dialogue: 0,0:17:04.48,0:17:07.69,Dial_JP,,0,0,0,,たとえ　そのときブーイングを\N浴びることになったとしても
Dialogue: 0,0:17:08.14,0:17:11.55,Dial_JP,,0,0,0,,最優先すべき確固たる夢を持ってる君は
Dialogue: 0,0:17:12.11,0:17:14.31,Dial_JP,,0,0,0,,尊敬に値するとも思うよ
Dialogue: 0,0:17:14.78,0:17:16.45,Dial_JP,,0,0,0,,松葉づえ　借りてきたよ
Dialogue: 0,0:17:16.45,0:17:17.18,Dial_JP,,0,0,0,,使う
Dialogue: 0,0:17:22.35,0:17:23.77,Dial_JP,,0,0,0,,家庭科部の皆さん
Dialogue: 0,0:17:24.29,0:17:25.90,Dial_JP,,0,0,0,,約束だからじゃなく
Dialogue: 0,0:17:25.90,0:17:28.15,Dial_JP,,0,0,0,,本当の本当にそう思って言うよ
Dialogue: 0,0:17:29.64,0:17:31.66,Dial_JP,,0,0,0,,バカにしたことを言って　ごめんなさい
Dialogue: 0,0:17:32.23,0:17:34.41,Dial_JP,,0,0,0,,差し入れのおにぎりうまかったです
Dialogue: 0,0:17:34.41,0:17:35.86,Dial_JP,,0,0,0,,ありがとうございました
Dialogue: 0,0:17:36.95,0:17:40.64,Dial_JP,,0,0,0,,素直ではあるんだよな　よくも悪くも
Dialogue: 0,0:17:46.12,0:17:47.13,Dial_JP,,0,0,0,,おいっす
Dialogue: 0,0:17:47.45,0:17:49.90,Dial_JP,,0,0,0,,あれ　遼くんも一緒
Dialogue: 0,0:17:49.90,0:17:52.92,Dial_JP,,0,0,0,,ちょっと大狼くんに　渡しそびれた本があって
Dialogue: 0,0:17:53.79,0:17:55.70,Dial_JP,,0,0,0,,もうすぐ来るんじゃないかな
Dialogue: 0,0:17:55.70,0:17:56.93,Dial_JP,,0,0,0,,うぃっす
Dialogue: 0,0:17:56.93,0:17:58.06,Dial_JP,,0,0,0,,ああ　大狼く…
Dialogue: 0,0:17:58.76,0:18:00.93,Dial_JP,,0,0,0,,大狼くん？
Dialogue: 0,0:18:00.93,0:18:02.21,Dial_JP,,0,0,0,,何があったの
Dialogue: 0,0:18:02.83,0:18:05.84,Dial_JP,,0,0,0,,いや　あのあとからなんかめちゃくちゃ
Dialogue: 0,0:18:05.84,0:18:07.82,Dial_JP,,0,0,0,,勧誘されるようになっちまって
Dialogue: 0,0:18:07.82,0:18:10.90,Dial_JP,,0,0,0,,確かに　すごい活躍だったもんね
Dialogue: 0,0:18:10.90,0:18:13.39,Dial_JP,,0,0,0,,ちょっと　普通じゃないくらい
Dialogue: 0,0:18:13.39,0:18:14.32,Dial_JP,,0,0,0,,うん…
Dialogue: 0,0:18:14.69,0:18:16.24,Dial_JP,,0,0,0,,あれはまぐれ
Dialogue: 0,0:18:16.24,0:18:18.33,Dial_JP,,0,0,0,,なんか火事場のバカ力みたいな
Dialogue: 0,0:18:18.57,0:18:20.15,Dial_JP,,0,0,0,,どうするんすか
Dialogue: 0,0:18:20.15,0:18:22.68,Dial_JP,,0,0,0,,やっぱめちゃくちゃ注目されちゃってるじゃないすか
Dialogue: 0,0:18:22.68,0:18:23.48,Dial_JP,,0,0,0,,どうしよう
Dialogue: 0,0:18:23.90,0:18:25.04,Dial_JP,,0,0,0,,こんにちは
Dialogue: 0,0:18:28.22,0:18:29.05,Dial_JP,,0,0,0,,なんで
Dialogue: 0,0:18:29.36,0:18:31.09,Dial_JP,,0,0,0,,天童天馬
Dialogue: 0,0:18:31.09,0:18:34.55,Dial_JP,,0,0,0,,いや　人をそんなお化けみたいに
Dialogue: 0,0:18:34.98,0:18:37.85,Dial_JP,,0,0,0,,まさか　お前も家庭科部に入部を
Dialogue: 0,0:18:37.85,0:18:39.07,Dial_JP,,0,0,0,,いや　しないよ
Dialogue: 0,0:18:39.76,0:18:41.47,Dial_JP,,0,0,0,,つうか　ずっと何くわえてんの
Dialogue: 0,0:18:42.73,0:18:44.89,Dial_JP,,0,0,0,,用事があって来たんだよ
Dialogue: 0,0:18:45.88,0:18:49.39,Dial_JP,,0,0,0,,てか　伝えたいことかな千里さんに
Dialogue: 0,0:18:49.39,0:18:50.09,Dial_JP,,0,0,0,,うん？
Dialogue: 0,0:18:53.99,0:18:55.45,Dial_JP,,0,0,0,,好きになりました
Dialogue: 0,0:18:56.00,0:18:57.45,Dial_JP,,0,0,0,,俺と　つきあってください
Dialogue: 0,0:19:05.12,0:19:07.66,Dial_JP,,0,0,0,,俺　スポーツは最強だけど
Dialogue: 0,0:19:07.66,0:19:09.91,Dial_JP,,0,0,0,,それ以外は何もわかってなかった
Dialogue: 0,0:19:10.72,0:19:12.76,Dial_JP,,0,0,0,,千里さんに言われて気づいて
Dialogue: 0,0:19:13.28,0:19:16.76,Dial_JP,,0,0,0,,千里さんと　ずっと一緒にいたいと思ったんだ
Dialogue: 0,0:19:16.76,0:19:17.65,Dial_JP,,0,0,0,,いや
Dialogue: 0,0:19:18.73,0:19:20.15,Dial_JP,,0,0,0,,ちょっと待ってくれ
Dialogue: 0,0:19:20.15,0:19:23.28,Dial_JP,,0,0,0,,こういうのは　慣れてないというか
Dialogue: 0,0:19:23.28,0:19:23.84,Dial_JP,,0,0,0,,なぜ
Dialogue: 0,0:19:23.84,0:19:25.73,Dial_JP,,0,0,0,,苦手というか
Dialogue: 0,0:19:25.73,0:19:28.44,Dial_JP,,0,0,0,,どれだけ生き方直球なんだ　チミは
Dialogue: 0,0:19:30.77,0:19:31.48,Dial_JP,,0,0,0,,師匠
Dialogue: 0,0:19:31.48,0:19:35.60,Dial_JP,,0,0,0,,大切な姉ちゃんに　何いきなりナンパキメてんだ
Dialogue: 0,0:19:35.60,0:19:36.22,Dial_JP,,0,0,0,,クソが
Dialogue: 0,0:19:36.22,0:19:37.61,Dial_JP,,0,0,0,,ぶっ殺すぞ
Dialogue: 0,0:19:37.61,0:19:39.78,Dial_JP,,0,0,0,,もしかして　お姉さん大好きな人？
Dialogue: 0,0:19:39.78,0:19:43.00,Dial_JP,,0,0,0,,ユニコーンだか　ポップコーンだか知らねえが
Dialogue: 0,0:19:43.00,0:19:45.21,Dial_JP,,0,0,0,,ひき肉にしてやんよ
Dialogue: 0,0:19:45.21,0:19:46.50,Dial_JP,,0,0,0,,お…落ち着いて師匠
Dialogue: 0,0:19:46.83,0:19:47.47,Dial_JP,,0,0,0,,天馬
Dialogue: 0,0:19:47.47,0:19:48.87,Dial_JP,,0,0,0,,とりあえず　外出ろ
Dialogue: 0,0:19:49.23,0:19:50.18,Dial_JP,,0,0,0,,いいから
Dialogue: 0,0:19:50.18,0:19:52.67,Dial_JP,,0,0,0,,師匠　霹靂一閃の構えとってるから
Dialogue: 0,0:19:55.47,0:19:57.71,Dial_JP,,0,0,0,,たく　勘弁してくれ
Dialogue: 0,0:19:57.71,0:19:59.41,Dial_JP,,0,0,0,,どういうつもりだよ
Dialogue: 0,0:19:59.41,0:20:00.80,Dial_JP,,0,0,0,,いきなり　あんな冗談
Dialogue: 0,0:20:00.80,0:20:02.77,Dial_JP,,0,0,0,,いや　本気だから
Dialogue: 0,0:20:02.77,0:20:05.10,Dial_JP,,0,0,0,,こいつといい　シンといい
Dialogue: 0,0:20:05.46,0:20:08.81,Dial_JP,,0,0,0,,あれ以来　いろんな運動部に追い回されるわ
Dialogue: 0,0:20:08.81,0:20:10.96,Dial_JP,,0,0,0,,学園生活に集中できないわで
Dialogue: 0,0:20:11.42,0:20:15.11,Dial_JP,,0,0,0,,とにかく目立たず平穏に勉強したいんだよ　俺は
Dialogue: 0,0:20:15.11,0:20:16.62,Dial_JP,,0,0,0,,目立たず？
Dialogue: 0,0:20:16.62,0:20:19.24,Dial_JP,,0,0,0,,平穏に？勉強したい？
Dialogue: 0,0:20:19.24,0:20:21.20,Dial_JP,,0,0,0,,目立ちたくて　活躍したくて
Dialogue: 0,0:20:21.20,0:20:23.66,Dial_JP,,0,0,0,,勉強したくないやつだもんな　お前
Dialogue: 0,0:20:23.66,0:20:25.69,Dial_JP,,0,0,0,,それは無理でしょう
Dialogue: 0,0:20:25.69,0:20:26.91,Dial_JP,,0,0,0,,もうなってるし
Dialogue: 0,0:20:28.42,0:20:30.61,Dial_JP,,0,0,0,,何を隠してるか知らんけど
Dialogue: 0,0:20:30.61,0:20:32.21,Dial_JP,,0,0,0,,いずれ全部　バレるよ
Dialogue: 0,0:20:32.65,0:20:34.63,Dial_JP,,0,0,0,,君が　いちばん普通じゃないもん
Dialogue: 0,0:20:35.16,0:20:37.64,Dial_JP,,0,0,0,,素人が俺に競り勝つなんて
Dialogue: 0,0:20:37.64,0:20:40.14,Dial_JP,,0,0,0,,まぐれや気合いだけで　できるわけないでしょ
Dialogue: 0,0:20:40.46,0:20:43.89,Dial_JP,,0,0,0,,そんなやつは　どの競技のトップにもいなかった
Dialogue: 0,0:20:48.95,0:20:49.97,Dial_JP,,0,0,0,,そうだな
Dialogue: 0,0:20:50.57,0:20:52.26,Dial_JP,,0,0,0,,今回のことがなくても
Dialogue: 0,0:20:52.26,0:20:54.96,Dial_JP,,0,0,0,,時間の問題でしかないのかもな
Dialogue: 0,0:20:54.96,0:20:56.65,Dial_JP,,0,0,0,,ただ　それでも
Dialogue: 0,0:20:57.53,0:21:00.10,Dial_JP,,0,0,0,,平穏な学園生活ってやつは
Dialogue: 0,0:21:00.58,0:21:03.19,Dial_JP,,0,0,0,,俺にとっては何物にも代えがたい
Dialogue: 0,0:21:03.19,0:21:05.27,Dial_JP,,0,0,0,,かけがえのないものなんだよ
Dialogue: 0,0:21:05.65,0:21:09.41,Dial_JP,,0,0,0,,だから　一秒でも長く続けたいとは思ってる
Dialogue: 0,0:22:43.43,0:22:46.61,Dial_JP,,0,0,0,,あのあと　俺に対するお詫びのつもりか
Dialogue: 0,0:22:46.61,0:22:49.20,Dial_JP,,0,0,0,,あいつからのちょっとした計らいがあった
Dialogue: 0,0:22:50.06,0:22:52.25,Dial_JP,,0,0,0,,天童天馬のケガがリークされ
Dialogue: 0,0:22:52.25,0:22:54.15,Dial_JP,,0,0,0,,スポーツ系の雑誌やニュースが
Dialogue: 0,0:22:54.15,0:22:56.11,Dial_JP,,0,0,0,,その話題一色になった
Dialogue: 0,0:22:57.11,0:22:59.11,Dial_JP,,0,0,0,,もちろん　それは事実ではなく
Dialogue: 0,0:22:59.54,0:23:00.83,Dial_JP,,0,0,0,,広めたかったのは
Dialogue: 0,0:23:00.83,0:23:03.12,Dial_JP,,0,0,0,,大狼十三が勝てたのは
Dialogue: 0,0:23:03.12,0:23:07.65,Dial_JP,,0,0,0,,天馬のコンディションが\N最悪に近い状態だったから　ということ
Dialogue: 0,0:23:08.40,0:23:10.97,Dial_JP,,0,0,0,,相対的に俺の評価も下がり
Dialogue: 0,0:23:10.97,0:23:15.04,Dial_JP,,0,0,0,,運動部の勧誘やら　周囲の騒ぎも落ち着いていった
Dialogue: 0,0:23:16.25,0:23:17.11,Dial_JP,,0,0,0,,ちなみに
Dialogue: 0,0:23:17.11,0:23:21.38,Dial_JP,,0,0,0,,「各競技の夏の大会は　欠場するのか」と聞いたら
Dialogue: 0,0:23:21.80,0:23:23.46,Dial_JP,,0,0,0,,「治った」って言って
Dialogue: 0,0:23:23.46,0:23:25.42,Dial_JP,,0,0,0,,奇跡の復活しちゃえばいいじゃん
Dialogue: 0,0:23:25.80,0:23:26.76,Dial_JP,,0,0,0,,だそうだ
Dialogue: 0,0:23:29.02,0:23:30.98,Dial_JP,,0,0,0,,よかったっすね　兄貴
Dialogue: 0,0:23:30.98,0:23:32.35,Dial_JP,,0,0,0,,危ねえ
Dialogue: 0,0:23:32.35,0:23:35.50,Dial_JP,,0,0,0,,なんとかごまかせた　かな
Dialogue: 0,0:01:48.30,0:01:52.01,OP_JP,,0,0,0,,{\fax-0.1\blur2}Imma go and do it my way　邪魔させない
Dialogue: 0,0:01:52.01,0:01:54.59,OP_JP,,0,0,0,,{\fax-0.1\blur2}Making my way to the top
Dialogue: 0,0:01:54.97,0:01:57.51,OP_JP,,0,0,0,,{\fax-0.1\blur2}堂々としてる I know だって
Dialogue: 0,0:01:57.51,0:01:58.47,OP_JP,,0,0,0,,{\fax-0.1\blur2}Proud of my life
Dialogue: 0,0:01:58.47,0:02:00.73,OP_JP,,0,0,0,,{\fax-0.1\blur2}Manners? I left them behind
Dialogue: 0,0:02:01.02,0:02:04.23,OP_JP,,0,0,0,,{\fax-0.1\blur2}Hold up hold up 抑えようなんて無駄 Duh duh
Dialogue: 0,0:02:04.23,0:02:08.48,OP_JP,,0,0,0,,{\fax-0.1\blur2}Shout out shout out 引き金になる Sound now
Dialogue: 0,0:02:09.19,0:02:10.69,OP_JP,,0,0,0,,{\fax-0.1\blur2}Boy you’re playing with fire
Dialogue: 0,0:02:10.69,0:02:12.32,OP_JP,,0,0,0,,{\fax-0.1\blur2}負ける気しないわ
Dialogue: 0,0:02:13.40,0:02:17.74,OP_JP,,0,0,0,,{\fax-0.1\blur2}Don’t stop 志込めた銃弾
Dialogue: 0,0:02:17.74,0:02:22.83,OP_JP,,0,0,0,,{\fax-0.1\blur2}狙い定めて Don’t look back
Dialogue: 0,0:02:22.83,0:02:24.21,OP_JP,,0,0,0,,{\fax-0.1\blur2}Oh yeah oh yeah
Dialogue: 0,0:02:24.21,0:02:25.12,OP_JP,,0,0,0,,{\fax-0.1\blur2}Oh yeah oh yeah
Dialogue: 0,0:02:25.12,0:02:26.54,OP_JP,,0,0,0,,{\fax-0.1\blur2}Giving you my attitude
Dialogue: 0,0:02:28.25,0:02:30.55,OP_JP,,0,0,0,,{\fax-0.1\blur2}躊躇わないのが Mood
Dialogue: 0,0:02:31.30,0:02:34.13,OP_JP,,0,0,0,,{\fax-0.1\blur2}信じないなら I’ll prove
Dialogue: 0,0:02:34.13,0:02:36.30,OP_JP,,0,0,0,,{\fax-0.1\blur2}So I’m giving you my attitude
Dialogue: 0,0:02:37.43,0:02:39.47,OP_JP,,0,0,0,,{\fax-0.1\blur2}Attitude
Dialogue: 0,0:02:39.47,0:02:41.35,OP_JP,,0,0,0,,{\fax-0.1\blur2}とめられない You can’t kill my vibe
Dialogue: 0,0:02:41.35,0:02:42.64,OP_JP,,0,0,0,,{\fax-0.1\blur2}自由に I can blow your mind
Dialogue: 0,0:02:42.64,0:02:44.48,OP_JP,,0,0,0,,{\fax-0.1\blur2}何度だって You’ll see me rise
Dialogue: 0,0:02:44.48,0:02:45.94,OP_JP,,0,0,0,,{\fax-0.1\blur2}Tryna get to me and pay the price
Dialogue: 0,0:02:45.94,0:02:48.98,OP_JP,,0,0,0,,{\fax-0.1\blur2}描いた未来へ　進んで行くだけ
Dialogue: 0,0:02:48.98,0:02:51.78,OP_JP,,0,0,0,,{\fax-0.1\blur2}Won’t look back
Dialogue: 0,0:02:53.74,0:02:57.03,OP_JP,,0,0,0,,{\fax-0.1\blur2}Giving you my attitude
Dialogue: 0,0:02:57.03,0:03:00.16,OP_JP,,0,0,0,,{\fax-0.1\blur2}躊躇わないのが Mood
Dialogue: 0,0:03:00.16,0:03:03.00,OP_JP,,0,0,0,,{\fax-0.1\blur2}信じないなら I’ll prove
Dialogue: 0,0:03:03.00,0:03:05.75,OP_JP,,0,0,0,,{\fax-0.1\blur2}So I’m giving you my attitude
Dialogue: 0,0:03:06.33,0:03:08.50,OP_JP,,0,0,0,,{\fax-0.1\blur2}Attitude
