Dialogue: 0,0:04:45.06,0:04:45.20,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}30
Dialogue: 0,0:04:45.20,0:04:45.37,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300
Dialogue: 0,0:04:45.37,0:04:46.12,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300战
Dialogue: 0,0:04:46.12,0:04:46.25,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300战 2
Dialogue: 0,0:04:46.25,0:04:46.37,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300战 29
Dialogue: 0,0:04:46.37,0:04:47.08,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300战 299
Dialogue: 0,0:04:47.08,0:04:48.35,Screen,,0,0,0,,{\an7\pos(835,785)\bord0.5\blur5}300战 299平
