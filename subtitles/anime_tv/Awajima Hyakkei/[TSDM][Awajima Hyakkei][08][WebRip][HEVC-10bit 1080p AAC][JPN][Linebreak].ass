Dialogue: 0,0:02:32.17,0:02:35.08,淡岛_对白 日语,Sara's Dad,0,0,0,,ハッピーニューイヤー!
Dialogue: 0,0:02:35.43,0:02:38.22,淡岛_对白 日语,Sara's Grandmother,0,0,0,,あー 一番やかましいのが来た
Dialogue: 0,0:02:38.39,0:02:40.64,淡岛_对白 日语,Sara's Dad,0,0,0,,そう言うなよ かわいい息子に
Dialogue: 0,0:02:40.76,0:02:42.42,淡岛_对白 日语,Sara's Grandmother,0,0,0,,いらっしゃい サラちゃん
Dialogue: 0,0:02:43.89,0:02:45.94,淡岛_对白 日语,Sara,0,0,0,,あけましておめでとうございます
Dialogue: 0,0:02:46.10,0:02:47.02,淡岛_对白 日语,Sara's Grandmother,0,0,0,,おめでとう
Dialogue: 0,0:02:47.06,0:02:48.68,淡岛_对白 日语,Sara's Grandmother,0,0,0,,{\an8\pos(960,14)}さ あがってあがって
Dialogue: 0,0:02:47.35,0:02:49.44,淡岛_对白 日语,Sara's Uncle,0,0,0,,兄ちゃん あけましておめでとう
Dialogue: 0,0:02:49.61,0:02:50.97,淡岛_对白 日语,Sara's Dad,0,0,0,,あー ことよろ
Dialogue: 0,0:02:51.11,0:02:53.19,淡岛_对白 日语,Sara's Dad,0,0,0,,そんなことより \Nお前の奥さん紹介してくれ
Dialogue: 0,0:02:53.57,0:02:55.45,淡岛_对白 日语,Sara's Uncle,0,0,0,,変なこと 聞いたりすんなよ
Dialogue: 0,0:02:55.49,0:02:57.70,淡岛_对白 日语,Sara's Dad,0,0,0,,しねえよ 失礼なヤツだな
Dialogue: 0,0:02:57.99,0:02:59.07,淡岛_对白 日语,Sara's Uncle,0,0,0,,とか言って
Dialogue: 0,0:02:59.87,0:03:01.58,淡岛_对白 日语,Sara's Dad,0,0,0,,はじめまして 良子さん!
Dialogue: 0,0:03:02.04,0:03:05.19,淡岛_对白 日语,Ryoko,0,0,0,,お義兄さんのお話は \Nいつもいろいろうかがってます
Dialogue: 0,0:03:05.33,0:03:06.42,淡岛_对白 日语,Sara's Dad,0,0,0,,マジで?
Dialogue: 0,0:03:06.54,0:03:09.59,淡岛_对白 日语,Sara's Dad,0,0,0,,どうせ子供の頃の\Nくっだらない話でしょ
Dialogue: 0,0:03:10.00,0:03:12.79,淡岛_对白 日语,Sara's Dad,0,0,0,,海外赴任からやっと戻った\Nばっかりでね
Dialogue: 0,0:03:13.01,0:03:15.34,淡岛_对白 日语,Sara's Dad,0,0,0,,オレだけご挨拶が遅れて \Nごめんなさいね
Dialogue: 0,0:03:15.51,0:03:17.16,淡岛_对白 日语,Sara's Uncle,0,0,0,,それもう話してあるから
Dialogue: 0,0:03:17.26,0:03:18.34,淡岛_对白 日语,Sara's Dad,0,0,0,,うるせーな
Dialogue: 0,0:03:18.89,0:03:23.89,淡岛_对白 日语,Sara's Dad,0,0,0,,あっ あとうちの子がね \N良子さんに聞きたいことがあるんだって
Dialogue: 0,0:03:23.93,0:03:24.93,淡岛_对白 日语,Sara's Dad,0,0,0,,なっ サラちゃん
Dialogue: 0,0:03:26.52,0:03:29.36,淡岛_对白 日语,Sara,0,0,0,,はじめまして 小鳥遊紗羅と申します
Dialogue: 0,0:03:29.94,0:03:30.97,淡岛_对白 日语,Ryoko,0,0,0,,はじめまして
Dialogue: 0,0:03:31.07,0:03:32.24,淡岛_对白 日语,Ryoko,0,0,0,,良子と 申します
Dialogue: 0,0:03:32.44,0:03:33.56,淡岛_对白 日语,Sara,0,0,0,,あっ あの…
Dialogue: 0,0:03:33.73,0:03:35.19,淡岛_对白 日语,Sara,0,0,0,,背 高いんですね
Dialogue: 0,0:03:35.44,0:03:36.52,淡岛_对白 日语,Sara,0,0,0,,ステキです!
Dialogue: 0,0:03:36.99,0:03:39.49,淡岛_对白 日语,Sara,0,0,0,,あっ すみません じゃなくて
Dialogue: 0,0:03:39.53,0:03:40.49,淡岛_对白 日语,Sara's Uncle,0,1000,0,,落ち着け
Dialogue: 0,0:03:40.20,0:03:41.58,淡岛_对白 日语,Sara's Dad,1000,0,0,,サラちゃん 頑張れ!
Dialogue: 0,0:03:42.08,0:03:45.45,淡岛_对白 日语,Sara,0,0,0,,この人と お友達って本当ですか?
Dialogue: 0,0:03:49.58,0:03:52.04,淡岛_对白 日语,Ryoko,0,0,0,,ほんとほんと 中等部まで一緒でね
Dialogue: 0,0:03:52.09,0:03:53.40,淡岛_对白 日语,Sara,0,0,0,,す…すごい!
Dialogue: 0,0:03:53.55,0:03:55.84,淡岛_对白 日语,Sara's Uncle,0,0,0,,その人 結婚式にも来てくれたんだぞ
Dialogue: 0,0:03:55.97,0:03:57.13,淡岛_对白 日语,Sara,0,0,0,,うそ マジやばい!
Dialogue: 0,0:03:57.51,0:03:59.06,淡岛_对白 日语,Sara's Dad,0,0,0,,男役のトップだろ?
Dialogue: 0,0:03:59.18,0:04:00.80,淡岛_对白 日语,Sara's Dad,0,0,0,,お前の立場なかったんじゃない?
Dialogue: 0,0:04:00.93,0:04:01.89,淡岛_对白 日语,Sara,0,0,0,,だよねぇ
Dialogue: 0,0:04:02.10,0:04:05.39,淡岛_对白 日语,Sara's Uncle,0,0,0,,陽様と良子の結婚式って感じだったわ
Dialogue: 0,0:04:05.98,0:04:10.10,淡岛_对白 日语,Sara,0,0,0,,お父さん 小鳥遊って苗字に\Nなってくれてありがと
Dialogue: 0,0:04:10.15,0:04:12.52,淡岛_对白 日语,Sara's Dad,0,0,0,,別にオレが決めた\Nわけじゃないけどなぁ
Dialogue: 0,0:04:13.07,0:04:15.03,淡岛_对白 日语,Sara's Dad,0,0,0,,まあ 喜んでもらえてオレも嬉しいよ
Dialogue: 0,0:04:15.07,0:04:18.86,淡岛_对白 日语,Sara,0,0,0,,おじちゃんも \N良子さんと結婚してくれてありがとう
Dialogue: 0,0:04:18.07,0:04:19.31,淡岛_对白 日语,Sara's Uncle,0,0,0,,{\an8\pos(960,14)}現金なやつ
Dialogue: 0,0:04:19.36,0:04:21.38,淡岛_对白 日语,Sara's Grandmother,0,0,0,,はい お雑煮食べる人
Dialogue: 0,0:04:21.03,0:04:22.06,淡岛_对白 日语,Sara,0,0,0,,{\an8\pos(960,14)}はーい!
Dialogue: 0,0:04:22.95,0:04:26.48,淡岛_对白 日语,Sara,0,0,0,,というわけで 小鳥遊陽様の母校
Dialogue: 0,0:04:26.62,0:04:31.54,淡岛_对白 日语,Sara,0,0,0,,淡島歌劇学校に 私 \N小鳥遊紗羅が入学しました!
Dialogue: 0,0:04:33.96,0:04:35.41,淡岛_对白 日语,Sara,0,0,0,,ここだぁ!
Dialogue: 0,0:04:36.46,0:04:38.33,淡岛_对白 日语,Sara,0,0,0,,通称「寄宿舎」
Dialogue: 0,0:04:38.47,0:04:40.92,淡岛_对白 日语,Sara,0,0,0,,淡島歌劇学校合宿所
Dialogue: 0,0:04:41.18,0:04:42.08,淡岛_对白 日语,Sara,0,0,0,,本物!
Dialogue: 0,0:04:43.64,0:04:46.85,淡岛_对白 日语,Sara,0,0,0,,本日入寮することになった \N小鳥遊紗羅です
Dialogue: 0,0:04:47.02,0:04:48.60,淡岛_对白 日语,Dorm Mother,0,0,0,,あー はいはい
Dialogue: 0,0:04:48.73,0:04:50.52,淡岛_对白 日语,Dorm Mother,0,0,0,,まもなく寮長さんが来るので
Dialogue: 0,0:04:50.60,0:04:52.06,淡岛_对白 日语,Dorm Mother,0,0,0,,そちらでお待ち下さい
Dialogue: 0,0:04:53.90,0:04:54.91,淡岛_对白 日语,Sara,0,0,0,,応接間?
Dialogue: 0,0:04:55.02,0:04:56.65,淡岛_对白 日语,Sara,0,0,0,,渋くて 格好いい!
Dialogue: 0,0:04:56.78,0:04:57.61,淡岛_对白 日语,Sara,0,0,0,,階段!
Dialogue: 0,0:04:57.65,0:05:00.20,淡岛_对白 日语,Sara,0,0,0,,ボロ… 古くて 格好いい!
Dialogue: 0,0:05:01.74,0:05:05.20,淡岛_对白 日语,Sara,0,0,0,,歩くと ギシギシいう床 格好いい!
Dialogue: 0,0:05:06.74,0:05:08.50,淡岛_对白 日语,Koshimizu,0,0,0,,何をやってるのかしら…
Dialogue: 0,0:05:09.83,0:05:11.04,淡岛_对白 日语,Koshimizu,0,0,0,,お待たせしてすみません
Dialogue: 0,0:05:11.67,0:05:13.77,淡岛_对白 日语,Koshimizu,0,0,0,,寮長の小清水と申します
Dialogue: 0,0:05:14.00,0:05:15.34,淡岛_对白 日语,Sara,0,0,0,,こちらこそ すいません
Dialogue: 0,0:05:16.71,0:05:20.75,淡岛_对白 日语,Sara,0,0,0,,こしみずって 小さい \N清らかな水と書きますか?
Dialogue: 0,0:05:21.01,0:05:21.88,淡岛_对白 日语,Koshimizu,0,0,0,,そうですが…
Dialogue: 0,0:05:22.38,0:05:26.14,淡岛_对白 日语,Sara,0,0,0,,私は 小さい鳥が遊ぶと書いて \Nたかなしといいます
Dialogue: 0,0:05:26.56,0:05:28.26,淡岛_对白 日语,Sara,0,0,0,,き…奇遇ですね!
Dialogue: 0,0:05:30.52,0:05:33.20,淡岛_对白 日语,Koshimizu,0,0,0,,小鳥遊紗羅って 美しい名前ですね
Dialogue: 0,0:05:33.40,0:05:34.65,淡岛_对白 日语,Sara,0,0,0,,ありがとうございます
Dialogue: 0,0:05:34.98,0:05:36.13,淡岛_对白 日语,Sara,0,0,0,,よく言われます
Dialogue: 0,0:05:36.32,0:05:38.30,淡岛_对白 日语,Koshimizu,0,0,0,,そのまま芸名になりそうな
Dialogue: 0,0:05:38.48,0:05:40.28,淡岛_对白 日语,Sara,0,0,0,,そ…それなんですよねぇ
Dialogue: 0,0:05:40.74,0:05:44.03,淡岛_对白 日语,Sara,0,0,0,,すでに 小鳥遊陽様という\Nスターがいる手前
Dialogue: 0,0:05:44.07,0:05:47.20,淡岛_对白 日语,Sara,0,0,0,,たぶん変えざるを\N得ないのだろうなー と
Dialogue: 0,0:05:47.41,0:05:49.08,淡岛_对白 日语,Koshimizu,0,0,0,,あー 確かに
Dialogue: 0,0:05:50.79,0:05:52.08,淡岛_对白 日语,Koshimizu,0,0,0,,ここが洗面所です
Dialogue: 0,0:05:54.12,0:05:55.46,淡岛_对白 日语,Sara,0,0,0,,古っ 渋っ
Dialogue: 0,0:05:55.92,0:05:58.34,淡岛_对白 日语,Sara,0,0,0,,あの… 写真 撮っていいですか?
Dialogue: 0,0:05:58.38,0:06:00.30,淡岛_对白 日语,Koshimizu,0,0,0,,えっ いいですけど
Dialogue: 0,0:06:00.71,0:06:02.78,淡岛_对白 日语,Koshimizu,0,0,0,,SNSに上げたりはダメですよ
Dialogue: 0,0:06:02.97,0:06:04.27,淡岛_对白 日语,Sara,0,0,0,,はい 大丈夫です
Dialogue: 0,0:06:04.34,0:06:05.18,淡岛_对白 日语,Sara,0,0,0,,気をつけます
Dialogue: 0,0:06:05.64,0:06:07.38,淡岛_对白 日语,Sara,0,0,0,,個人的に楽しみます
Dialogue: 0,0:06:08.51,0:06:09.85,淡岛_对白 日语,Koshimizu,0,0,0,,こっちが共同浴場
Dialogue: 0,0:06:11.56,0:06:12.80,淡岛_对白 日语,Koshimizu,0,0,0,,写真 どうぞ
Dialogue: 0,0:06:13.06,0:06:14.19,淡岛_对白 日语,Sara,0,0,0,,ありがとうございます!
Dialogue: 0,0:06:14.60,0:06:16.44,淡岛_对白 日语,Sara,0,0,0,,激渋銭湯み!
Dialogue: 0,0:06:18.23,0:06:20.44,淡岛_对白 日语,Koshimizu,0,0,0,,なんという屈託のなさ
Dialogue: 0,0:06:21.44,0:06:22.97,淡岛_对白 日语,Koshimizu,0,0,0,,なんだかいいなあ
Dialogue: 0,0:06:23.20,0:06:25.11,淡岛_对白 日语,Koshimizu,0,0,0,,風通しがよくなるというか
Dialogue: 0,0:06:26.62,0:06:30.33,淡岛_对白 日语,Koshimizu,0,0,0,,私が予科生の頃は \N息が詰まりそうだったもの
Dialogue: 0,0:06:31.33,0:06:33.82,淡岛_对白 日语,Koshimizu,0,0,0,,後輩たちにあんな思いをさせたくない
Dialogue: 0,0:06:34.96,0:06:36.08,淡岛_对白 日语,Koshimizu,0,0,0,,変えていきたい
Dialogue: 0,0:06:37.84,0:06:40.90,淡岛_对白 日语,Koshimizu,0,0,0,,どうするのが \N一番良いことなのだろう?
Dialogue: 0,0:06:45.05,0:06:46.54,淡岛_对白 日语,Koshimizu,0,0,0,,ここがあなたの部屋です
Dialogue: 0,0:06:47.68,0:06:50.99,淡岛_对白 日语,Koshimizu,0,0,0,,同室は本科生の柳原さんという方です
Dialogue: 0,0:06:52.52,0:06:53.35,淡岛_对白 日语,Koshimizu,0,0,0,,なんですか?
Dialogue: 0,0:06:53.81,0:06:55.75,淡岛_对白 日语,Sara,0,0,0,,いえ あの…
Dialogue: 0,0:06:56.69,0:07:00.60,淡岛_对白 日语,Sara,0,0,0,,小清水先輩と \N同じ部屋だと思ってたので
Dialogue: 0,0:07:00.77,0:07:04.38,淡岛_对白 日语,Sara,0,0,0,,すみません 残念とか思ってしまい…
Dialogue: 0,0:07:04.95,0:07:06.14,淡岛_对白 日语,Koshimizu,0,0,0,,すごい
Dialogue: 0,0:07:06.24,0:07:08.59,淡岛_对白 日语,Koshimizu,0,0,0,,さっき会ったばかりだというのに
Dialogue: 0,0:07:09.20,0:07:11.59,淡岛_对白 日语,Koshimizu,0,0,0,,なんという人懐こさというか
Dialogue: 0,0:07:11.83,0:07:13.11,淡岛_对白 日语,Koshimizu,0,0,0,,人たらし?
Dialogue: 0,0:07:14.29,0:07:17.00,淡岛_对白 日语,Koshimizu,0,0,0,,まあ 柳原さんもいい人ですよ
Dialogue: 0,0:07:18.08,0:07:20.09,淡岛_对白 日语,Yanagihara,0,0,0,,変えていきたいって…
Dialogue: 0,0:07:20.50,0:07:22.26,淡岛_对白 日语,Yanagihara,0,0,0,,政治家にでもなんの?
Dialogue: 0,0:07:22.38,0:07:24.54,淡岛_对白 日语,Koshimizu,0,0,0,,そういうわけじゃないけど
Dialogue: 0,0:07:25.05,0:07:28.58,淡岛_对白 日语,Yanagihara,0,0,0,,まあ うちらの先輩 \Nほとんどクソだったからな
Dialogue: 0,0:07:28.93,0:07:30.47,淡岛_对白 日语,Koshimizu,0,0,0,,いい人というか
Dialogue: 0,0:07:32.97,0:07:36.03,淡岛_对白 日语,Koshimizu,0,0,0,,ちょっと変わってるけど \N怖い人ではないです
Dialogue: 0,0:07:36.27,0:07:37.39,淡岛_对白 日语,Sara,0,0,0,,ありがとうございます
Dialogue: 0,0:07:39.35,0:07:40.52,淡岛_对白 日语,Sara,0,0,0,,小鳥遊紗羅です
Dialogue: 0,0:07:40.56,0:07:41.71,淡岛_对白 日语,Eri,0,0,0,,本名が!?
Dialogue: 0,0:07:42.23,0:07:45.49,淡岛_对白 日语,Eri,0,0,0,,小鳥が遊ぶと書いて \N「たかなし」だと
Dialogue: 0,0:07:45.65,0:07:47.36,淡岛_对白 日语,Eri,0,0,0,,出来すぎだ
Dialogue: 0,0:07:47.86,0:07:49.25,淡岛_对白 日语,Instructor,0,0,0,,次 藤沢さん
Dialogue: 0,0:07:49.41,0:07:50.28,淡岛_对白 日语,Eri,0,0,0,,は はい!
Dialogue: 0,0:07:51.91,0:07:53.78,淡岛_对白 日语,Eri,0,0,0,,私は 藤沢江里
Dialogue: 0,0:07:54.45,0:07:57.52,淡岛_对白 日语,Eri,0,0,0,,別に自分の名前がイヤなわけじゃない
Dialogue: 0,0:07:57.75,0:08:00.64,淡岛_对白 日语,Eri,0,0,0,,どうせなら 藤「澤」がよかったし
Dialogue: 0,0:08:00.91,0:08:02.11,淡岛_对白 日语,Eri,0,0,0,,「絵莉」がよかった
Dialogue: 0,0:08:03.55,0:08:07.45,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんは中学の時の\Nクラスメイトに既にいて
Dialogue: 0,0:08:08.01,0:08:12.24,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんが \N絵莉だったから私も 絵莉がよかった
Dialogue: 0,0:08:13.22,0:08:16.52,淡岛_对白 日语,Eri,0,0,0,,澤乃井くんの \N澤の字もかっこよかった
Dialogue: 0,0:08:17.59,0:08:19.77,淡岛_对白 日语,Eri,0,0,0,,いつも 誰かになりたかった
Dialogue: 0,0:08:21.24,0:08:24.74,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんは \N名前に絵が付く宿命なのか
Dialogue: 0,0:08:24.74,0:08:26.46,淡岛_对白 日语,Eri,0,0,0,,絵がとてもうまかった
Dialogue: 0,0:08:27.31,0:08:31.51,淡岛_对白 日语,Eri,0,0,0,,ネットに絵を上げていて \Nその時の名前は本名じゃない
Dialogue: 0,0:08:32.27,0:08:36.83,淡岛_对白 日语,Eri,0,0,0,,私は絵莉ちゃんの絵莉って名前が\N好きなんだけど
Dialogue: 0,0:08:36.83,0:08:40.15,淡岛_对白 日语,Eri,0,0,0,,別の誰かになっているのが\Nかっこいいと思った
Dialogue: 0,0:08:41.12,0:08:45.51,淡岛_对白 日语,Eri,0,0,0,,澤乃井くんはSNSをやっていて \Nノイと名乗っていた
Dialogue: 0,0:08:46.29,0:08:48.54,淡岛_对白 日语,Eri,0,0,0,,なんで知っているのかというと
Dialogue: 0,0:08:48.54,0:08:51.27,淡岛_对白 日语,Eri,0,0,0,,澤乃井くんに\Nそっと教えてもらったから
Dialogue: 0,0:08:51.98,0:08:55.18,淡岛_对白 日语,Eri,0,0,0,,澤乃井くん 私のことが好きなの?
Dialogue: 0,0:08:56.34,0:08:59.25,淡岛_对白 日语,Eri,0,0,0,,まあ それはいい \Nひとまず置いておく
Dialogue: 0,0:09:00.47,0:09:04.83,淡岛_对白 日语,Eri,0,0,0,,私も 自分に自分じゃない名前を\N付けたくなった
Dialogue: 0,0:09:04.83,0:09:07.30,淡岛_对白 日语,Eri,0,0,0,,だから 淡島に来ました
Dialogue: 0,0:09:07.30,0:09:09.74,淡岛_对白 日语,Eri,0,0,0,,というわけでは もちろんない
Dialogue: 0,0:09:10.82,0:09:15.52,淡岛_对白 日语,Eri,0,0,0,,ないけど 私が別の誰かに\Nなりたいと思ったのは
Dialogue: 0,0:09:17.63,0:09:20.02,淡岛_对白 日语,Eri,0,0,0,,小鳥遊陽に憧れたから
Dialogue: 0,0:09:20.02,0:09:22.46,淡岛_对白 日语,Sara,0,0,0,,そっ…そうなんだよね
Dialogue: 0,0:09:22.46,0:09:26.68,淡岛_对白 日语,Sara,0,0,0,,陽様がいるから \N自分が違う名前にしないとなあって
Dialogue: 0,0:09:26.68,0:09:28.80,淡岛_对白 日语,Eri,0,0,0,,ああ そっかあ
Dialogue: 0,0:09:28.80,0:09:31.73,淡岛_对白 日语,Eri,0,0,0,,小鳥遊さんは明るくて人見知りしない
Dialogue: 0,0:09:33.00,0:09:36.28,淡岛_对白 日语,Eri,0,0,0,,いつの間にか私たちは 仲よくなった
Dialogue: 0,0:09:38.45,0:09:41.46,淡岛_对白 日语,Eri,0,0,0,,おじさんの結婚式に小鳥遊陽?
Dialogue: 0,0:09:41.46,0:09:42.37,淡岛_对白 日语,Eri,0,0,0,,どういうこと
Dialogue: 0,0:09:42.37,0:09:44.09,淡岛_对白 日语,Sara,0,0,0,,すごいでしょすごいでしょ
Dialogue: 0,0:09:44.09,0:09:46.79,淡岛_对白 日语,Sara,0,0,0,,でもうちお父さん海外行ってたし
Dialogue: 0,0:09:46.79,0:09:50.09,淡岛_对白 日语,Sara,0,0,0,,私もその時入院してて \N結婚式行けなかったの
Dialogue: 0,0:09:50.09,0:09:53.78,淡岛_对白 日语,Eri,0,0,0,,うそ 本物の小鳥遊陽様見逃したの
Dialogue: 0,0:09:53.78,0:09:55.35,淡岛_对白 日语,Sara,0,0,0,,そうなんだよ
Dialogue: 0,0:09:55.35,0:09:57.22,淡岛_对白 日语,Sara,0,0,0,,一生の不覚
Dialogue: 0,0:09:58.07,0:10:01.39,淡岛_对白 日语,Shizuka,0,0,0,,だったら 舞台の上で\N何度も会ったらいいよ
Dialogue: 0,0:10:02.00,0:10:04.49,淡岛_对白 日语,Eri; Sara,0,0,0,,た…確かに
Dialogue: 0,0:10:04.49,0:10:08.41,淡岛_对白 日语,Shizuka,0,0,0,,それより あんまりそういう\N話しない方がいいと思う
Dialogue: 0,0:10:08.86,0:10:11.23,淡岛_对白 日语,Shizuka,0,0,0,,親戚に誰がいると かそういうの
Dialogue: 0,0:10:11.99,0:10:14.00,淡岛_对白 日语,Shizuka,0,0,0,,ぶっちゃけると 妬まれるよ
Dialogue: 0,0:10:14.84,0:10:16.47,淡岛_对白 日语,Shizuka,0,0,0,,余計なことだったらごめんね
Dialogue: 0,0:10:17.19,0:10:19.77,淡岛_对白 日语,Sara,0,0,0,,あ ううん ありがとう
Dialogue: 0,0:10:23.36,0:10:25.75,淡岛_对白 日语,Eri,0,0,0,,ちょっと怖かったね 今…
Dialogue: 0,0:10:27.45,0:10:31.91,淡岛_对白 日语,Sara,0,0,0,,でも ドラマっぽくてかっこいいと\N思ってしまった
Dialogue: 0,0:10:31.91,0:10:33.28,淡岛_对白 日语,Eri,0,0,0,,ドラマ?
Dialogue: 0,0:10:33.28,0:10:35.67,淡岛_对白 日语,Eri,0,0,0,,さてはこれっぽちも気にしてないな
Dialogue: 0,0:10:35.67,0:10:37.63,淡岛_对白 日语,Sara,0,0,0,,そ…そういうわけでは
Dialogue: 0,0:10:38.49,0:10:41.24,淡岛_对白 日语,Eri,0,0,0,,でも 気にすることでもないよね
Dialogue: 0,0:10:41.80,0:10:45.78,淡岛_对白 日语,Eri,0,0,0,,だって 小鳥遊さんは別に\N自慢したわけじゃないし
Dialogue: 0,0:10:45.78,0:10:51.86,淡岛_对白 日语,Eri,0,0,0,,先の人もさ 怖って思ったけど \Nつまりは処世術を教えてくれたんだよね
Dialogue: 0,0:10:51.86,0:10:53.37,淡岛_对白 日语,Sara,0,0,0,,しょせいじゅつ?
Dialogue: 0,0:10:53.37,0:10:54.63,淡岛_对白 日语,Eri,0,0,0,,世渡り的な?
Dialogue: 0,0:10:56.61,0:11:00.56,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんと澤乃井くんが\N付き合ってるって 知らなかった
Dialogue: 0,0:11:01.57,0:11:07.22,淡岛_对白 日语,Eri,0,0,0,,私は絵莉ちゃんのことが好きだったし \N澤乃井くんも仲のいいクラスメイト
Dialogue: 0,0:11:08.21,0:11:13.93,淡岛_对白 日语,Eri,0,0,0,,あと…よしんば小鳥遊さんが\N自慢したとして
Dialogue: 0,0:11:13.93,0:11:15.98,淡岛_对白 日语,Eri,0,0,0,,それの何が悪いのってこと
Dialogue: 0,0:11:17.38,0:11:19.79,淡岛_对白 日语,Eri,0,0,0,,でも 面白く思わない人もいる
Dialogue: 0,0:11:21.15,0:11:23.88,淡岛_对白 日语,Eri,0,0,0,,それをさっきの人は\N忠告してくれたわけだ
Dialogue: 0,0:11:24.97,0:11:26.11,淡岛_对白 日语,Sara,0,0,0,,なるほど
Dialogue: 0,0:11:27.16,0:11:29.71,淡岛_对白 日语,Eri,0,0,0,,私だって自慢したわけじゃない
Dialogue: 0,0:11:30.44,0:11:35.61,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんのアカウントと \N澤乃井くんのアカウントとが繋がってないことなんか
Dialogue: 0,0:11:35.61,0:11:37.79,淡岛_对白 日语,Eri,0,0,0,,知らなかったし どうでもいい
Dialogue: 0,0:11:38.66,0:11:44.99,淡岛_对白 日语,Eri,0,0,0,,澤乃井くんが私に教えてくれたアカウントが \N秘密でスペシャルなアカウントだったなんて
Dialogue: 0,0:11:44.99,0:11:46.93,淡岛_对白 日语,Eri,0,0,0,,知らなかったしどうでもいい
Dialogue: 0,0:11:47.89,0:11:50.80,淡岛_对白 日语,Eri,0,0,0,,私は絵莉ちゃんのことが\N好きだったのに
Dialogue: 0,0:11:51.41,0:11:54.69,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんからは \N大嫌いと言われてしまった
Dialogue: 0,0:11:56.15,0:12:01.32,淡岛_对白 日语,Eri,0,0,0,,「淡島なんて 受かるはずがない」\Nそう言われてしまった
Dialogue: 0,0:12:02.76,0:12:04.12,淡岛_对白 日语,Eri,0,0,0,,「受かったよ」
Dialogue: 0,0:12:04.12,0:12:05.32,淡岛_对白 日语,Eri,0,0,0,,って言ってあった
Dialogue: 0,0:12:06.56,0:12:08.93,淡岛_对白 日语,Eri,0,0,0,,その時の絵莉ちゃんの顔
Dialogue: 0,0:12:08.93,0:12:14.33,淡岛_对白 日语,Eri,0,0,0,,ぎゅっと 唇を\N噛んでるような ふーんだって
Dialogue: 0,0:12:15.45,0:12:18.56,淡岛_对白 日语,Eri,0,0,0,,そこはせめて強がってでも\Nおめでとうだろ
Dialogue: 0,0:12:20.52,0:12:22.60,淡岛_对白 日语,Shizuka,0,0,0,,はい 消しゴム落ちたよ
Dialogue: 0,0:12:23.24,0:12:24.98,淡岛_对白 日语,Eri,0,0,0,,あ ありがとう
Dialogue: 0,0:12:26.23,0:12:27.94,淡岛_对白 日语,Eri,0,0,0,,さっきの忠告さん
Dialogue: 0,0:12:27.94,0:12:30.12,淡岛_对白 日语,Eri,0,0,0,,笑うとかわいい
Dialogue: 0,0:12:30.12,0:12:32.21,淡岛_对白 日语,Eri,0,0,0,,なんて名前だったっけ
Dialogue: 0,0:12:32.21,0:12:35.48,淡岛_对白 日语,Eri,0,0,0,,確か うたがわ…うたがわ…
Dialogue: 0,0:12:36.62,0:12:39.72,淡岛_对白 日语,Eri,0,0,0,,雅楽の川で静かに香るだと?
Dialogue: 0,0:12:40.55,0:12:43.36,淡岛_对白 日语,Eri,0,0,0,,すごい 名前負けしてない
Dialogue: 0,0:12:44.76,0:12:49.47,淡岛_对白 日语,Eri,0,0,0,,その後 雅やかな忠告者の\N静香さんとも仲良くなった
Dialogue: 0,0:12:50.44,0:12:52.58,淡岛_对白 日语,Eri,0,0,0,,気づけば3人でつるんでいる
Dialogue: 0,0:12:54.56,0:12:56.49,淡岛_对白 日语,Shizuka,0,0,0,,人間関係ね
Dialogue: 0,0:12:56.49,0:12:57.97,淡岛_对白 日语,Shizuka,0,0,0,,確かに難しいわ
Dialogue: 0,0:12:59.31,0:13:01.80,淡岛_对白 日语,Shizuka,0,0,0,,私も人間関係リセット組だもん
Dialogue: 0,0:13:01.80,0:13:03.52,淡岛_对白 日语,Eri,0,0,0,,静香さんも?!
Dialogue: 0,0:13:04.15,0:13:07.23,淡岛_对白 日语,Shizuka,0,0,0,,ま 色んな人が集まってるってことよ
Dialogue: 0,0:13:07.99,0:13:10.01,淡岛_对白 日语,Shizuka,0,0,0,,芸能関係者も多いしね
Dialogue: 0,0:13:14.94,0:13:17.47,淡岛_对白 日语,Eri,0,0,0,,絵莉ちゃんに自分を描いてほしかった
Dialogue: 0,0:13:18.45,0:13:21.10,淡岛_对白 日语,Eri,0,0,0,,この子 私の友達よって
Dialogue: 0,0:13:21.76,0:13:24.13,淡岛_对白 日语,Eri,0,0,0,,いつか 誇ってほしかった
Dialogue: 0,0:13:28.45,0:13:31.02,淡岛_对白 日语,Shizuka,0,0,0,,大変 江里さんが泣いてる
Dialogue: 0,0:13:31.02,0:13:32.97,淡岛_对白 日语,Sara,0,0,0,,どうしたの 大丈夫?\N どっか怪我した?
Dialogue: 0,0:13:32.97,0:13:35.48,淡岛_对白 日语,Eri,0,0,0,,目敏く見つけないでよ もう
Dialogue: 0,0:13:35.48,0:13:38.25,淡岛_对白 日语,Shizuka,0,0,0,,同室の先輩と\Nうまくやらないんじゃない?
Dialogue: 0,0:13:38.25,0:13:40.07,淡岛_对白 日语,Eri,0,0,0,,何の問題もありません
Dialogue: 0,0:13:43.12,0:13:44.59,淡岛_对白 日语,Shizuka,0,0,0,,紗羅さんはどう?
Dialogue: 0,0:13:44.59,0:13:45.62,淡岛_对白 日语,Shizuka,0,0,0,,関係は良好?
Dialogue: 0,0:13:46.18,0:13:46.76,淡岛_对白 日语,Sara,0,0,0,,うん
Dialogue: 0,0:13:47.81,0:13:49.86,淡岛_对白 日语,Shizuka,0,0,0,,でも 本当に大丈夫?
Dialogue: 0,0:13:49.86,0:13:51.57,淡岛_对白 日语,Eri,0,0,0,,大丈夫大丈夫
Dialogue: 0,0:13:55.58,0:14:01.33,淡岛_对白 日语,Eri,0,0,0,,さっきの人間関係の話 \Nあれをちょっと思い出してた
Dialogue: 0,0:14:07.86,0:14:11.64,淡岛_对白 日语,Sara,0,0,0,,こんなこと言うのって \Nよくないかもしれないけれど
Dialogue: 0,0:14:12.57,0:14:15.78,淡岛_对白 日语,Sara,0,0,0,,うちに秘蔵のDVDがあるの
Dialogue: 0,0:14:15.78,0:14:16.85,淡岛_对白 日语,Shizuka,0,0,0,,なんの話?
Dialogue: 0,0:14:19.31,0:14:25.13,淡岛_对白 日语,Sara,0,0,0,,小鳥遊陽様が映っている \Nうちのおじさんの結婚式の DVDが
Dialogue: 0,0:14:25.89,0:14:29.13,淡岛_对白 日语,Sara,0,0,0,,今度送ってもらうから \Nみんなでこっそり見よ
Dialogue: 0,0:14:29.13,0:14:30.95,淡岛_对白 日语,Sara,0,0,0,,もしくはうちに泊まりに来て
Dialogue: 0,0:14:31.74,0:14:34.60,淡岛_对白 日语,Shizuka,0,0,0,,紗羅さんなりに江里さんを\N励まそうとしてるんだわ
Dialogue: 0,0:14:34.60,0:14:36.26,淡岛_对白 日语,Eri,0,0,0,,紗羅さんたら
Dialogue: 0,0:14:38.34,0:14:43.27,淡岛_对白 日语,Eri,0,0,0,,いつか誰かに \Nできるなら私たち みんなで
Dialogue: 0,0:14:50.02,0:14:52.27,淡岛_对白 日语,Kanon,0,0,0,,すごい すごかった
Dialogue: 0,0:14:52.27,0:14:54.66,淡岛_对白 日语,Kanon,0,0,0,,本当におじちゃまが脚本を書いたの?
Dialogue: 0,0:14:54.66,0:14:56.02,淡岛_对白 日语,Arikawa,0,0,0,,失礼だな
Dialogue: 0,0:14:56.02,0:14:57.51,淡岛_对白 日语,Arikawa,0,0,0,,ゴーストライターじゃないぞ
Dialogue: 0,0:14:58.48,0:15:01.89,淡岛_对白 日语,Kanon,0,0,0,,わかってるけど そうじゃなくて
Dialogue: 0,0:15:02.98,0:15:04.80,淡岛_对白 日语,Arikawa,0,0,0,,みんなも来てくれてありがとうね
Dialogue: 0,0:15:05.27,0:15:08.06,淡岛_对白 日语,Arikawa,0,0,0,,鏑木夕希さんの楽屋には \Nもう行ったの?
Dialogue: 0,0:15:08.06,0:15:09.99,淡岛_对白 日语,Miki,0,0,0,,ええ いいんですか
Dialogue: 0,0:15:09.99,0:15:13.05,淡岛_对白 日语,Kanon,0,0,0,,鏑木夕希さんの楽屋前は\Nすごい行列だったもん
Dialogue: 0,0:15:13.05,0:15:16.17,淡岛_对白 日语,Miki,0,0,0,,すごいよね 芸能人ばっかり並んでた
Dialogue: 0,0:15:16.17,0:15:18.82,淡岛_对白 日语,Shizuka,0,0,0,,本当に夢のような
Dialogue: 0,0:15:18.82,0:15:22.52,淡岛_对白 日语,Shizuka,0,0,0,,現実に戻った今も \N夢の中にいるような
Dialogue: 0,0:15:23.35,0:15:24.97,淡岛_对白 日语,Shizuka,0,0,0,,そんな一日だった
Dialogue: 0,0:15:26.28,0:15:28.72,淡岛_对白 日语,Miki,0,0,0,,荒木玲奈が楽屋挨拶に並んでて
Dialogue: 0,0:15:28.72,0:15:29.81,淡岛_对白 日语,Friend A,0,0,0,,マジできれい
Dialogue: 0,0:15:29.81,0:15:31.11,淡岛_对白 日语,Friend B,0,0,0,,顔ちっちゃい
Dialogue: 0,0:15:31.11,0:15:33.01,淡岛_对白 日语,Friend B,0,0,0,,ヤバいよね
Dialogue: 0,0:15:33.01,0:15:34.65,淡岛_对白 日语,Shizuka,0,0,0,,佐々木香音さん
Dialogue: 0,0:15:35.27,0:15:37.16,淡岛_对白 日语,Kanon,0,0,0,,鏑木夕希さん好きなの?
Dialogue: 0,0:15:38.62,0:15:44.84,淡岛_对白 日语,Shizuka,0,0,0,,仲良くなったきっかけは \Nクリアファイルに挟んでおいた雑誌の切り抜き
Dialogue: 0,0:15:44.84,0:15:46.65,淡岛_对白 日语,Miki,0,0,0,,芸能人とか好きなんだ
Dialogue: 0,0:15:48.48,0:15:53.00,淡岛_对白 日语,Miki,0,0,0,,なんで有川瞬が\N自分の親戚って教えたと思う 香音
Dialogue: 0,0:15:54.62,0:15:57.64,淡岛_对白 日语,Shizuka,0,0,0,,みんなを楽屋に\N招待してくれるためでしょ
Dialogue: 0,0:15:59.77,0:16:01.92,淡岛_对白 日语,Miki,0,0,0,,自慢するために決まってんじゃん
Dialogue: 0,0:16:03.05,0:16:05.36,淡岛_对白 日语,Miki,0,0,0,,「あ これ他の人には内緒ね」
Dialogue: 0,0:16:05.69,0:16:07.70,淡岛_对白 日语,Friend A,0,0,0,,内緒なら黙ってればいいのに
Dialogue: 0,0:16:07.99,0:16:10.02,淡岛_对白 日语,Miki,0,0,0,,あっ あとあと「おじちゃま」
Dialogue: 0,0:16:10.18,0:16:11.57,淡岛_对白 日语,Friend A; Friend B,0,0,0,,おじちゃま!
Dialogue: 0,0:16:11.73,0:16:13.73,淡岛_对白 日语,Miki,0,0,0,,あと有川瞬て 正直よく知らない
Dialogue: 0,0:16:13.86,0:16:14.51,淡岛_对白 日语,Friend A,0,0,0,,わかる――
Dialogue: 0,0:16:14.64,0:16:16.99,淡岛_对白 日语,Friend B,0,0,0,,うちお母さんが好きって言ってたかな
Dialogue: 0,0:16:18.45,0:16:20.16,淡岛_对白 日语,Shizuka,0,0,0,,えっ…こっわ…
Dialogue: 0,0:16:21.66,0:16:23.11,淡岛_对白 日语,Shizuka,0,0,0,,なんだこれ
Dialogue: 0,0:16:24.69,0:16:27.64,淡岛_对白 日语,Shizuka,0,0,0,,あんなにニコニコして \N記念写真撮ってたのに
Dialogue: 0,0:16:28.28,0:16:30.58,淡岛_对白 日语,Shizuka,0,0,0,,みんなできゃあきゃあ\N質問責めにしたのに
Dialogue: 0,0:16:31.47,0:16:35.12,淡岛_对白 日语,Shizuka,0,0,0,,その裏で こんなに怖いことを\N笑顔で昼食のつまみに?
Dialogue: 0,0:16:36.48,0:16:39.32,淡岛_对白 日语,Miki,0,0,0,,初等部から一緒だから \Nみんな知ってるけどさ
Dialogue: 0,0:16:39.75,0:16:41.20,淡岛_对白 日语,Miki,0,0,0,,あの子ずっとああだよ
Dialogue: 0,0:16:41.87,0:16:43.67,淡岛_对白 日语,Miki,0,0,0,,「児童未来劇団」てあるじゃん
Dialogue: 0,0:16:44.09,0:16:46.13,淡岛_对白 日语,Miki,0,0,0,,赤ちゃんのころからあそこ入ってて
Dialogue: 0,0:16:46.84,0:16:49.80,淡岛_对白 日语,Kanon,0,0,0,,「私実は 未来劇団にいるの」
Dialogue: 0,0:16:50.38,0:16:52.36,淡岛_对白 日语,Miki,0,0,0,,だから何? だよね
Dialogue: 0,0:16:52.72,0:16:55.72,淡岛_对白 日语,Friend A,0,0,0,,今日休みなのも \Nエキストラの一人でしょ 確か
Dialogue: 0,0:16:55.97,0:16:56.87,淡岛_对白 日语,Friend B,0,0,0,,へ――
Dialogue: 0,0:16:57.78,0:16:59.71,淡岛_对白 日语,Shizuka,0,0,0,,怖すぎて 食欲失せた
Dialogue: 0,0:17:01.00,0:17:04.87,淡岛_对白 日语,Shizuka,0,0,0,,意見しようものなら \N多分白けるタイプの人たちだ
Dialogue: 0,0:17:05.89,0:17:07.60,淡岛_对白 日语,Miki,0,0,0,,は?意味わかんね
Dialogue: 0,0:17:08.26,0:17:09.25,淡岛_对白 日语,Miki,0,0,0,,なんかキレてる
Dialogue: 0,0:17:09.93,0:17:11.79,淡岛_对白 日语,Shizuka,0,0,0,,と 軽くいなしてくる
Dialogue: 0,0:17:12.49,0:17:13.62,淡岛_对白 日语,Shizuka,0,0,0,,そういうタイプだ
Dialogue: 0,0:17:14.99,0:17:16.88,淡岛_对白 日语,Shizuka,0,0,0,,私はせめて中立でいよう
Dialogue: 0,0:17:17.70,0:17:19.23,淡岛_对白 日语,Shizuka,0,0,0,,どちらの側にも立たない
Dialogue: 0,0:17:19.88,0:17:21.38,淡岛_对白 日语,Shizuka,0,0,0,,どちらの味方もしない
Dialogue: 0,0:17:22.72,0:17:25.17,淡岛_对白 日语,Shizuka,0,0,0,,彼女をバカにする一人にも加わらず
Dialogue: 0,0:17:26.13,0:17:28.51,淡岛_对白 日语,Shizuka,0,0,0,,彼女らと波風立てることもせず
Dialogue: 0,0:17:30.27,0:17:32.25,淡岛_对白 日语,Shizuka,0,0,0,,一匹狼の方がマシだ
Dialogue: 0,0:17:32.99,0:17:37.52,淡岛_对白 日语,Shizuka,0,0,0,,ただひっそりと \N平熱で 平穏な日々を
Dialogue: 0,0:17:39.34,0:17:40.78,淡岛_对白 日语,Miki,0,0,0,,うそお――
Dialogue: 0,0:17:41.08,0:17:41.93,淡岛_对白 日语,Friend A,0,0,0,,どうした
Dialogue: 0,0:17:41.26,0:17:43.11,淡岛_对白 日语,Miki,0,0,0,,{\an8\pos(960,14)}マジやばい マジやばい マジやばい
Dialogue: 0,0:17:43.22,0:17:44.94,淡岛_对白 日语,Kinue,0,0,0,,今度きゃなめの舞台あんだけど{きゃなめ：要の愛称}
Dialogue: 0,0:17:45.02,0:17:45.75,淡岛_对白 日语,Friend A,0,0,0,,あ――
Dialogue: 0,0:17:45.83,0:17:48.54,淡岛_对白 日语,Miki,0,0,0,,かの~ん 見たこれ!\N? すっごいマジで!?
Dialogue: 0,0:17:48.93,0:17:50.85,淡岛_对白 日语,Kanon,0,0,0,,あ そうみたいだね
Dialogue: 0,0:17:51.21,0:17:52.68,淡岛_对白 日语,Kanon,0,0,0,,ミキちゃん 好きなんだっけ
Dialogue: 0,0:17:53.35,0:17:54.70,淡岛_对白 日语,Miki,0,0,0,,超 すっき!
Dialogue: 0,0:17:55.52,0:17:58.57,淡岛_对白 日语,Miki,0,0,0,,楽屋挨拶…ダメかなあ
Dialogue: 0,0:18:03.57,0:18:05.26,淡岛_对白 日语,Shizuka,0,0,0,,自慢するためなんでしょう
Dialogue: 0,0:18:05.96,0:18:09.29,淡岛_对白 日语,Shizuka,0,0,0,,有名人の身内ってこと \Nひけらかしてんでしょ
Dialogue: 0,0:18:10.53,0:18:12.44,淡岛_对白 日语,Shizuka,0,0,0,,有川瞬なんて よく知らないし
Dialogue: 0,0:18:13.09,0:18:14.17,淡岛_对白 日语,Shizuka,0,0,0,,興味もないんでしょ
Dialogue: 0,0:18:15.56,0:18:18.08,淡岛_对白 日语,Shizuka,0,0,0,,どうしたらそんなに\N厚かましくなれるものなの?
Dialogue: 0,0:18:20.31,0:18:23.24,淡岛_对白 日语,Miki,0,0,0,,雅楽川って名前なんかスゴいね \Nかっこいい
Dialogue: 0,0:18:23.42,0:18:23.93,淡岛_对白 日语,Friend A,0,0,0,,ね
Dialogue: 0,0:18:24.18,0:18:26.36,淡岛_对白 日语,Friend B,0,0,0,,雅楽川さんに合ってる感じがする
Dialogue: 0,0:18:26.47,0:18:28.39,淡岛_对白 日语,Miki,0,0,0,,わかる! クールって感じ
Dialogue: 0,0:18:29.73,0:18:32.69,淡岛_对白 日语,Shizuka,0,0,0,,私は別に クールでも\Nなんでもないのだが
Dialogue: 0,0:18:33.39,0:18:35.97,淡岛_对白 日语,Shizuka,0,0,0,,その時からそう演じる\Nようになったと思う
Dialogue: 0,0:18:36.94,0:18:37.74,淡岛_对白 日语,Shizuka,0,0,0,,んだけど
Dialogue: 0,0:18:38.15,0:18:40.89,淡岛_对白 日语,Miki,0,0,0,,え…なんかキレてる? なんで?
Dialogue: 0,0:18:42.51,0:18:44.78,淡岛_对白 日语,Shizuka,0,0,0,,演じる って難しいな…
Dialogue: 0,0:18:46.89,0:18:48.97,淡岛_对白 日语,Kanon,0,0,0,,みんな初等部のころから一緒で
Dialogue: 0,0:18:49.37,0:18:51.37,淡岛_对白 日语,Kanon,0,0,0,,昔からの知り合いというか
Dialogue: 0,0:18:52.03,0:18:56.11,淡岛_对白 日语,Kanon,0,0,0,,だから 結構キツイことも言うけど \N悪い子たちじゃないんだ
Dialogue: 0,0:18:56.67,0:18:58.87,淡岛_对白 日语,Kanon,0,0,0,,私が注意されることも多いしね
Dialogue: 0,0:18:59.79,0:19:04.75,淡岛_对白 日语,Shizuka,0,0,0,,佐々木さんの方がよほど中立で \Nクールで 大人だ
Dialogue: 0,0:19:06.50,0:19:07.90,淡岛_对白 日语,Kanon,0,0,0,,でも 嬉しかった
Dialogue: 0,0:19:08.72,0:19:09.48,淡岛_对白 日语,Kanon,0,0,0,,ありがとう
Dialogue: 0,0:19:11.86,0:19:12.62,淡岛_对白 日语,Shizuka,0,0,0,,佐々木さん
Dialogue: 0,0:19:13.88,0:19:14.55,淡岛_对白 日语,Shizuka,0,0,0,,香音さん
Dialogue: 0,0:19:16.51,0:19:20.18,淡岛_对白 日语,Shizuka,0,0,0,,私実はね 淡島にいきたい
Dialogue: 0,0:19:24.32,0:19:25.94,淡岛_对白 日语,Kanon,0,0,0,,緊張してきた
Dialogue: 0,0:19:26.45,0:19:28.44,淡岛_对白 日语,Shizuka,0,0,0,,だから来なくていいって言ったのに
Dialogue: 0,0:19:29.60,0:19:32.37,淡岛_对白 日语,Kanon,0,0,0,,でも合格発表に立ち会いたいから!
Dialogue: 0,0:19:32.76,0:19:34.54,淡岛_对白 日语,Shizuka,0,0,0,,不合格だったら気まずいじゃない?
Dialogue: 0,0:19:34.83,0:19:36.45,淡岛_对白 日语,Kanon,0,0,0,,そしたら慰める
Dialogue: 0,0:19:37.97,0:19:40.15,淡岛_对白 日语,Kanon,0,0,0,,泣くのも笑うのも \Nとことん付き合う!
Dialogue: 0,0:19:41.26,0:19:42.33,淡岛_对白 日语,Shizuka,0,0,0,,困った人だ
Dialogue: 0,0:19:43.77,0:19:46.22,淡岛_对白 日语,Shizuka,0,0,0,,初めて自分の夢を打ち明けた人
Dialogue: 0,0:19:47.88,0:19:49.12,淡岛_对白 日语,Shizuka,0,0,0,,私は淡島に
Dialogue: 0,0:19:50.48,0:19:53.06,淡岛_对白 日语,Shizuka,0,0,0,,香音さんは留学する\Nことが決まっていた
Dialogue: 0,0:20:02.52,0:20:06.04,淡岛_对白 日语,Eri,0,0,0,,おっ!静香さんがお顔を\Nほころばせていらっしゃるぞ
Dialogue: 0,0:20:06.18,0:20:07.02,淡岛_对白 日语,Sara,0,0,0,,なになに!
Dialogue: 0,0:20:07.64,0:20:09.13,淡岛_对白 日语,Shizuka,0,0,0,,中学のときの友達
Dialogue: 0,0:20:09.86,0:20:10.93,淡岛_对白 日语,Shizuka,0,0,0,,いま 留学中なの
Dialogue: 0,0:20:11.44,0:20:12.95,淡岛_对白 日语,Eri,0,0,0,,うっ嘘つき
Dialogue: 0,0:20:13.15,0:20:15.92,淡岛_对白 日语,Eri,0,0,0,,人間関係リセット組って言ったくせに
Dialogue: 0,0:20:16.12,0:20:18.11,淡岛_对白 日语,Eri,0,0,0,,そんなホットなやり取りして!
Dialogue: 0,0:20:18.48,0:20:18.82,淡岛_对白 日语,Shizuka,0,0,0,,あら
Dialogue: 0,0:20:19.13,0:20:21.49,淡岛_对白 日语,Shizuka,0,0,0,,仲良しグループは空中分解したわよ
Dialogue: 0,0:20:22.04,0:20:23.63,淡岛_对白 日语,Shizuka,0,0,0,,でも味方が一人いたの
Dialogue: 0,0:20:25.38,0:20:26.56,淡岛_对白 日语,Eri,0,0,0,,うっ羨ましい
Dialogue: 0,0:20:27.10,0:20:29.33,淡岛_对白 日语,Eri,0,0,0,,あたしには誰もいなかったのに…
Dialogue: 0,0:20:29.84,0:20:32.07,淡岛_对白 日语,Sara,0,0,0,,今は私たちがいるじゃないか
Dialogue: 0,0:20:33.20,0:20:33.91,淡岛_对白 日语,Shizuka,0,0,0,,そうよ
Dialogue: 0,0:20:34.28,0:20:36.34,淡岛_对白 日语,Eri,0,0,0,,ありがとう…
Dialogue: 0,0:20:41.02,0:20:43.29,淡岛_对白 日语,Kanon,0,0,0,,もしも――し もしもし?
Dialogue: 0,0:20:44.23,0:20:46.64,淡岛_对白 日语,Shizuka,0,0,0,,す…すみません
Dialogue: 0,0:20:47.28,0:20:49.79,淡岛_对白 日语,Shizuka,0,0,0,,電話は談話室でと決められているのに
Dialogue: 0,0:20:50.31,0:20:54.02,淡岛_对白 日语,Shizuka,0,0,0,,留学中の友人からだったので \Nつい はしゃいでしまい…
Dialogue: 0,0:20:54.80,0:20:55.32,淡岛_对白 日语,Koshimizu,0,0,0,,いえ…
Dialogue: 0,0:20:57.95,0:21:01.18,淡岛_对白 日语,Koshimizu,0,0,0,,なんというか 物静かな人というか
Dialogue: 0,0:21:01.70,0:21:05.89,淡岛_对白 日语,Koshimizu,0,0,0,,至って冷静な そういう人だと\N勝手な印象を持っていたので
Dialogue: 0,0:21:06.74,0:21:10.38,淡岛_对白 日语,Koshimizu,0,0,0,,こんなにお茶目な人だとわかって \N親近感がわきました
Dialogue: 0,0:21:10.61,0:21:12.10,淡岛_对白 日语,Shizuka,0,0,0,,大変恐縮です
Dialogue: 0,0:21:13.15,0:21:15.21,淡岛_对白 日语,Koshimizu,0,0,0,,電話しながら\Nストレッチしてたんですか?
Dialogue: 0,0:21:15.67,0:21:16.57,淡岛_对白 日语,Shizuka,0,0,0,,は はい
Dialogue: 0,0:21:17.40,0:21:19.81,淡岛_对白 日语,Shizuka,0,0,0,,子供のころからの癖で どうしても
Dialogue: 0,0:21:20.68,0:21:21.55,淡岛_对白 日语,Koshimizu,0,0,0,,いいと思います
Dialogue: 0,0:21:22.07,0:21:23.43,淡岛_对白 日语,Koshimizu,0,0,0,,柔軟は大事ですから
Dialogue: 0,0:21:23.85,0:21:24.85,淡岛_对白 日语,Shizuka,0,0,0,,恐れ入ります
Dialogue: 0,0:21:25.51,0:21:28.31,淡岛_对白 日语,Koshimizu,0,0,0,,ただ 相手の方には\N失礼かもしれませんね
Dialogue: 0,0:21:28.70,0:21:30.31,淡岛_对白 日语,Shizuka,0,0,0,,おっしゃる通りです
Dialogue: 0,0:21:31.16,0:21:33.50,淡岛_对白 日语,Koshimizu,0,0,0,,あとは 今後気をつけてください
Dialogue: 0,0:21:34.47,0:21:35.21,淡岛_对白 日语,Shizuka,0,0,0,,はい!
Dialogue: 0,0:21:35.89,0:21:38.02,淡岛_对白 日语,Koshimizu,0,0,0,,じゃあ寝る前の\Nストレッチしましょうか
Dialogue: 0,0:21:40.14,0:21:41.83,淡岛_对白 日语,Koshimizu,0,0,0,,柔軟は大事ですから
Dialogue: 0,0:21:43.75,0:21:44.51,淡岛_对白 日语,Shizuka,0,0,0,,それから
Dialogue: 0,0:21:45.61,0:21:50.66,淡岛_对白 日语,Shizuka,0,0,0,,私と同室の小清水先輩は \Nそれぞれのベッドに横たわると
Dialogue: 0,0:21:51.51,0:21:53.81,淡岛_对白 日语,Shizuka,0,0,0,,二人静かにストレッチを行った
Dialogue: 0,0:21:57.13,0:21:58.85,淡岛_对白 日语,Shizuka,0,0,0,,香音さんに早く会いたい
Dialogue: 0,0:22:00.15,0:22:03.92,淡岛_对白 日语,Shizuka,0,0,0,,優しくて お茶目な友達や\N先輩がいるの
Dialogue: 0,0:22:06.98,0:22:08.56,淡岛_对白 日语,Shizuka,0,0,0,,早くみんなに会わせたい!
