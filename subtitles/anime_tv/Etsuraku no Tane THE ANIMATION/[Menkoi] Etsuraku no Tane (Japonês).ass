Dialogue: 0,0:00:48.72,0:00:50.53,Default,,0,0,0,,もう 許して！
Dialogue: 0,0:00:51.04,0:00:53.21,Default,,0,0,0,,そんなこと言っていいの？
Dialogue: 0,0:00:59.94,0:01:01.34,Default,,0,0,0,,伊月ちゃん
Dialogue: 0,0:01:14.08,0:01:15.46,Default,,0,0,0,,ひよりちゃん！
Dialogue: 0,0:01:17.97,0:01:20.59,Default,,0,0,0,,まだ十回以上残っている
Dialogue: 0,0:01:45.38,0:01:46.67,Default,,0,0,0,,あら いたの？
Dialogue: 0,0:01:46.67,0:01:48.00,Default,,0,0,0,,空気人間
Dialogue: 0,0:01:48.63,0:01:50.91,Default,,0,0,0,,ごめんなさい
Dialogue: 0,0:01:51.05,0:01:53.13,Default,,0,0,0,,存在気づかなかたわ
Dialogue: 0,0:02:23.16,0:02:24.75,Default,,0,0,0,,伊月ちゃん
Dialogue: 0,0:02:24.80,0:02:26.63,Default,,0,0,0,,ひよりちゃん
Dialogue: 0,0:02:29.15,0:02:30.46,Default,,0,0,0,,おかしいな
Dialogue: 0,0:02:32.59,0:02:34.71,Default,,0,0,0,,泣けてきちゃって
Dialogue: 0,0:02:34.72,0:02:37.18,Default,,0,0,0,,私は伊月ちゃんが好き
Dialogue: 0,0:02:37.18,0:02:40.68,Default,,0,0,0,,伊月ちゃんも私のこと\N好きって言ってくれて
Dialogue: 0,0:02:40.68,0:02:42.10,Default,,0,0,0,,幸せなの
Dialogue: 0,0:02:42.10,0:02:43.52,Default,,0,0,0,,泣けちゃうの
Dialogue: 0,0:02:44.02,0:02:45.45,Default,,0,0,0,,私もう
Dialogue: 0,0:02:47.22,0:02:49.40,Default,,0,0,0,,好きになるって
Dialogue: 0,0:02:49.40,0:02:50.86,Default,,0,0,0,,切ないね
Dialogue: 0,0:03:19.35,0:03:21.81,Default,,0,0,0,,私のも触って
Dialogue: 0,0:03:35.90,0:03:37.57,Default,,0,0,0,,伊月ちゃん
Dialogue: 0,0:04:29.42,0:04:31.93,Default,,0,0,0,,イク！イク！
Dialogue: 0,0:06:11.06,0:06:13.10,Default,,0,0,0,,ダメ！
Dialogue: 0,0:06:13.11,0:06:15.98,Default,,0,0,0,,ひよりちゃん！ひよりちゃん！
Dialogue: 0,0:06:25.50,0:06:27.45,Default,,0,0,0,,ひよりちゃん
Dialogue: 0,0:06:27.45,0:06:29.49,Default,,0,0,0,,大丈夫だよ
Dialogue: 0,0:06:29.49,0:06:30.91,Default,,0,0,0,,伊月ちゃんの
Dialogue: 0,0:06:30.91,0:06:32.82,Default,,0,0,0,,伊月ちゃんの触手も
Dialogue: 0,0:06:32.82,0:06:35.04,Default,,0,0,0,,私がちゃんと受け止めるから
Dialogue: 0,0:06:36.17,0:06:37.71,Default,,0,0,0,,これ以上
Dialogue: 0,0:06:37.71,0:06:40.29,Default,,0,0,0,,誰にも触手が寄生しないよ
Dialogue: 0,0:06:40.32,0:06:41.90,Default,,0,0,0,,受け止める
Dialogue: 0,0:06:42.62,0:06:44.51,Default,,0,0,0,,ひよりちゃん
Dialogue: 0,0:07:20.34,0:07:22.67,Default,,0,0,0,,何で私が取りに\N来なきゃいけないんだ
Dialogue: 0,0:07:30.26,0:07:31.97,Default,,0,0,0,,誰かいるのか
Dialogue: 0,0:07:42.43,0:07:43.90,Default,,0,0,0,,気のせいか
Dialogue: 0,0:07:46.90,0:07:48.45,Default,,0,0,0,,何だこれ
Dialogue: 0,0:07:52.24,0:07:53.41,Default,,0,0,0,,待ってたわ
Dialogue: 0,0:07:53.41,0:07:55.20,Default,,0,0,0,,寺島さん
Dialogue: 0,0:07:58.42,0:08:00.08,Default,,0,0,0,,てめえ！
Dialogue: 0,0:08:00.08,0:08:01.50,Default,,0,0,0,,乃野原
Dialogue: 0,0:08:02.86,0:08:04.67,Default,,0,0,0,,乃野原麗奈
Dialogue: 0,0:08:04.67,0:08:06.55,Default,,0,0,0,,私の名前
Dialogue: 0,0:08:06.55,0:08:10.89,Default,,0,0,0,,これから あなたを支配\Nする者の名前になるわ
Dialogue: 0,0:08:10.89,0:08:12.97,Default,,0,0,0,,何言って？
Dialogue: 0,0:08:12.97,0:08:15.85,Default,,0,0,0,,あなたが踏んでいるそれ
Dialogue: 0,0:08:15.85,0:08:18.44,Default,,0,0,0,,それは私の触手よ
Dialogue: 0,0:08:25.87,0:08:27.36,Default,,0,0,0,,どう言う事だ？
Dialogue: 0,0:08:27.65,0:08:29.03,Default,,0,0,0,,離して！
Dialogue: 0,0:08:32.78,0:08:38.04,Default,,0,0,0,,恥辱には見れる\Nあなたの顔見てみたい
Dialogue: 0,0:08:40.12,0:08:45.25,Default,,0,0,0,,いつもバカにしていた人間に\N支配される気分はどうなのかしらね
Dialogue: 0,0:08:46.21,0:08:48.22,Default,,0,0,0,,楽しみましょう
Dialogue: 0,0:08:56.68,0:08:58.02,Default,,0,0,0,,やめて
Dialogue: 0,0:09:25.80,0:09:27.71,Default,,0,0,0,,いい顔ね
Dialogue: 0,0:09:27.71,0:09:32.01,Default,,0,0,0,,私の触手とても\N元気になってきちゃった
Dialogue: 0,0:09:39.39,0:09:41.27,Default,,0,0,0,,痛い！痛い！
Dialogue: 0,0:09:41.27,0:09:43.90,Default,,0,0,0,,突きちゃう
Dialogue: 0,0:09:57.99,0:10:00.00,Default,,0,0,0,,ダメ！
Dialogue: 0,0:10:15.93,0:10:18.10,Default,,0,0,0,,いい君
Dialogue: 0,0:11:28.33,0:11:32.50,Default,,0,0,0,,人は悦楽の前に膝をつく
Dialogue: 0,0:11:32.50,0:11:36.84,Default,,0,0,0,,もっと、もっと気持ち\Nいいことしたいでしょ
Dialogue: 0,0:11:38.34,0:11:39.60,Default,,0,0,0,,はい
Dialogue: 0,0:11:40.64,0:11:43.43,Default,,0,0,0,,協力してね
Dialogue: 0,0:11:57.36,0:11:59.91,Default,,0,0,0,,誰がこんな
Dialogue: 0,0:12:08.62,0:12:09.79,Default,,0,0,0,,何だろう
Dialogue: 0,0:12:13.80,0:12:15.67,Default,,0,0,0,,藤森ひより
Dialogue: 0,0:12:15.67,0:12:17.22,Default,,0,0,0,,村沢伊月
Dialogue: 0,0:12:17.22,0:12:19.80,Default,,0,0,0,,あなた達の秘密を知っている
Dialogue: 0,0:12:20.43,0:12:22.85,Default,,0,0,0,,誰にも話されたくなければ
Dialogue: 0,0:12:22.85,0:12:25.58,Default,,0,0,0,,旧校舎に来い
Dialogue: 0,0:12:44.63,0:12:45.62,Default,,0,0,0,,待っていたわ
Dialogue: 0,0:12:46.87,0:12:48.21,Default,,0,0,0,,あなた
Dialogue: 0,0:12:48.21,0:12:49.62,Default,,0,0,0,,乃野原さん？
Dialogue: 0,0:12:54.15,0:12:56.21,Default,,0,0,0,,触手？そんな！
Dialogue: 0,0:12:57.17,0:12:58.72,Default,,0,0,0,,伊月ちゃん！
Dialogue: 0,0:13:00.13,0:13:03.30,Default,,0,0,0,,二人ともずるいんだから
Dialogue: 0,0:13:03.30,0:13:05.85,Default,,0,0,0,,こんな素敵な触手
Dialogue: 0,0:13:05.85,0:13:09.02,Default,,0,0,0,,独占しようとするなんて
Dialogue: 0,0:13:09.02,0:13:11.06,Default,,0,0,0,,それは...
Dialogue: 0,0:13:11.06,0:13:13.56,Default,,0,0,0,,抵抗はしないでね
Dialogue: 0,0:13:13.56,0:13:15.73,Default,,0,0,0,,抵抗したら
Dialogue: 0,0:13:15.73,0:13:18.65,Default,,0,0,0,,村沢さん壊されちゃうから
Dialogue: 0,0:13:21.78,0:13:23.53,Default,,0,0,0,,どうすれば？
Dialogue: 0,0:13:54.15,0:13:55.73,Default,,0,0,0,,これで十回
Dialogue: 0,0:13:55.73,0:13:58.36,Default,,0,0,0,,よく頑張ったわね\N藤森さん
Dialogue: 0,0:14:26.14,0:14:28.18,Default,,0,0,0,,残念でした
Dialogue: 0,0:14:28.88,0:14:33.14,Default,,0,0,0,,これであなたも\N私達の仲間に
Dialogue: 0,0:14:40.40,0:14:42.69,Default,,0,0,0,,あれだけ言った後だもの
Dialogue: 0,0:14:42.69,0:14:45.20,Default,,0,0,0,,とっても気持ちいいわよね
Dialogue: 0,0:14:56.04,0:14:59.17,Default,,0,0,0,,藤森さんの中すごい
Dialogue: 0,0:15:06.64,0:15:09.18,Default,,0,0,0,,藤森さん気持ちよさそう
Dialogue: 0,0:15:14.18,0:15:17.35,Default,,0,0,0,,私達も気持ちよくなりましょう
Dialogue: 0,0:16:20.01,0:16:22.96,Default,,0,0,0,,牢獄の中は心地よく
Dialogue: 0,0:16:22.96,0:16:25.55,Default,,0,0,0,,やがて思考は停止する
Dialogue: 0,0:16:29.22,0:16:30.80,Default,,0,0,0,,よく見て
Dialogue: 0,0:16:30.80,0:16:34.89,Default,,0,0,0,,愛なんて快楽の前でには等しい
Dialogue: 0,0:16:35.56,0:16:39.94,Default,,0,0,0,,いく！いちゃう！\N気持ちいい
Dialogue: 0,0:16:39.94,0:16:42.31,Default,,0,0,0,,気持ちいいよ！
Dialogue: 0,0:16:42.86,0:16:44.32,Default,,0,0,0,,もっと
Dialogue: 0,0:16:44.73,0:16:46.32,Default,,0,0,0,,もっと！
Dialogue: 0,0:16:46.94,0:16:49.61,Default,,0,0,0,,もっとちょうだい
Dialogue: 0,0:16:50.53,0:16:52.20,Default,,0,0,0,,聞こえないわ
Dialogue: 0,0:16:52.20,0:16:54.54,Default,,0,0,0,,もっと 大きな声で言いなさい
Dialogue: 0,0:16:58.54,0:17:01.54,Default,,0,0,0,,もっと！
Dialogue: 0,0:17:05.67,0:17:10.55,Default,,0,0,0,,触手チンポで、もっと深いして
Dialogue: 0,0:17:22.65,0:17:24.57,Default,,0,0,0,,悲しい？
Dialogue: 0,0:17:24.57,0:17:27.86,Default,,0,0,0,,でも興奮してるのね
Dialogue: 0,0:17:34.74,0:17:37.04,Default,,0,0,0,,すごい ぐちゅぐちゅ
Dialogue: 0,0:17:59.47,0:18:03.56,Default,,0,0,0,,お願い！激しい！
Dialogue: 0,0:18:12.65,0:18:15.24,Default,,0,0,0,,みんなで\Nひとつに届け合いましょう
Dialogue: 0,0:19:20.81,0:19:24.35,Default,,0,0,0,,触手チンポ！チンポ！
Dialogue: 0,0:20:14.19,0:20:17.61,Default,,0,0,0,,チンポ！触手チンポ！
Dialogue: 0,0:20:17.61,0:20:19.82,Default,,0,0,0,,チンポちょうだい！
Dialogue: 0,0:20:34.93,0:20:37.92,Default,,0,0,0,,牢獄の中は心地よく
Dialogue: 0,0:20:37.92,0:20:40.34,Default,,0,0,0,,やがて思考は停止する
Dialogue: 0,0:20:42.85,0:20:46.89,Default,,0,0,0,,全てが悦楽には溶けていく
Dialogue: 0,0:20:50.40,0:20:53.48,Default,,0,0,0,,ずっと ずっと
Dialogue: 0,0:21:02.95,0:21:06.12,Default,,0,0,0,,もう、人間 辞めた
