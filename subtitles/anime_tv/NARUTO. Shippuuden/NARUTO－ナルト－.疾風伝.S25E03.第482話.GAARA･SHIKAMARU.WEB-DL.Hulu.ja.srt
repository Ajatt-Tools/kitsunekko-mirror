1
00:01:42,186 --> 00:01:47,066
(赤ちゃんの笑い声)

2
00:01:47,358 --> 00:01:48,609
ママ

3
00:01:50,152 --> 00:01:51,529
(赤ちゃんの笑い声)

4
00:02:00,579 --> 00:02:01,997
僕は

5
00:02:05,835 --> 00:02:07,127
僕は

6
00:02:19,348 --> 00:02:20,933
うううっ

7
00:02:48,377 --> 00:02:50,921
うわー
すげえなお前

8
00:02:50,921 --> 00:02:51,755
ん？

9
00:03:03,267 --> 00:03:04,810
うわあ！

10
00:03:06,020 --> 00:03:07,271
んー

11
00:03:10,566 --> 00:03:13,652
じゃあさごちそう作れるか？

12
00:03:13,986 --> 00:03:15,070
んー

13
00:03:19,742 --> 00:03:20,618
うん

14
00:03:28,959 --> 00:03:30,336
うわあ

15
00:03:32,504 --> 00:03:34,340
おおイカ焼き！

16
00:03:35,674 --> 00:03:36,800
うわあ

17
00:03:39,470 --> 00:03:40,220
ラーメン！

18
00:03:40,220 --> 00:03:41,347
へっへへ

19
00:03:46,101 --> 00:03:47,770
んーチェリー！

20
00:03:50,314 --> 00:03:51,732
ロブスター！

21
00:03:54,902 --> 00:03:57,905
あうーん
ウニ丼！

22
00:03:57,905 --> 00:03:58,447
アハハ

23
00:03:58,447 --> 00:04:03,118
すっげえすげえ
お前すげえぞ

24
00:04:03,911 --> 00:04:04,787
うん

25
00:04:10,209 --> 00:04:11,168
じゃあ

26
00:04:12,211 --> 00:04:14,296
でっかいうんち作れるか？

27
00:04:14,296 --> 00:04:15,422
んー

28
00:04:22,888 --> 00:04:23,889
テマリ

29
00:04:23,931 --> 00:04:24,598
あっ

30
00:04:26,684 --> 00:04:27,643
カンクロウ

31
00:04:27,810 --> 00:04:28,602
ん？

32
00:04:31,855 --> 00:04:32,481
ん

33
00:04:32,564 --> 00:04:33,524
はーい

34
00:04:41,031 --> 00:04:42,157
我愛羅

35
00:04:44,243 --> 00:04:45,119
テマリ

36
00:04:45,995 --> 00:04:47,079
はい

37
00:05:07,641 --> 00:05:09,184
ああ…

38
00:05:27,494 --> 00:05:29,455
気味が悪いぜ

39
00:05:30,164 --> 00:05:31,582
なんだあいつ

40
00:05:31,582 --> 00:05:33,542
いやあこわーい

41
00:05:33,667 --> 00:05:35,586
まじでキモイ

42
00:05:36,420 --> 00:05:38,213
呪われたガキだ

43
00:06:28,764 --> 00:06:31,183
ねえ夜叉丸

44
00:06:35,187 --> 00:06:36,522
どうして

45
00:06:38,107 --> 00:06:40,692
どうしてお腹ってすくの？

46
00:06:44,863 --> 00:06:46,657
それはですね

47
00:06:49,535 --> 00:06:51,995
美味しいものを食べるためかな

48
00:06:52,121 --> 00:06:53,789
そうかあ

49
00:06:54,790 --> 00:06:56,333
そうだね

50
00:06:56,834 --> 00:06:57,584
うん

51
00:07:00,754 --> 00:07:04,883
夜叉丸の作ってくれるご飯は
美味しいよ

52
00:07:33,537 --> 00:07:35,664
ゴホッゴホッ
んがー

53
00:08:07,946 --> 00:08:10,449
ねえ夜叉丸

54
00:08:13,118 --> 00:08:15,412
なんで空って青いのかな？

55
00:08:16,663 --> 00:08:18,040
そうですね

56
00:08:18,624 --> 00:08:24,796
それは多分青い空を見ていると
透き通った気持ちになれるから

57
00:08:24,796 --> 00:08:25,881
ですかね

58
00:08:26,715 --> 00:08:28,217
そうかあ

59
00:08:29,176 --> 00:08:30,510
そうだね

60
00:08:31,261 --> 00:08:32,262
僕

61
00:08:32,930 --> 00:08:37,935
空を見上げてると少しだけ
胸の痛いのが安らぐんだ

62
00:08:39,561 --> 00:08:40,520
うふふ

63
00:08:57,079 --> 00:08:58,914
ねえ夜叉丸

64
00:08:59,831 --> 00:09:04,711
僕夜になっても眠たくならないんだ
なんでかな？

65
00:09:08,840 --> 00:09:10,884
それは困りましたね

66
00:09:11,969 --> 00:09:15,597
普通は目を閉じてると
眠くなるんですよ

67
00:09:15,597 --> 00:09:17,724
へえそうなんだ

68
00:09:18,976 --> 00:09:19,893
ねえ

69
00:09:21,311 --> 00:09:22,604
なんで

70
00:09:23,563 --> 00:09:26,191
なんで僕には母さんがいないの？

71
00:09:26,191 --> 00:09:27,401
それは

72
00:09:29,736 --> 00:09:33,282
我愛羅様には
私がいるじゃないですか

73
00:09:38,203 --> 00:09:42,040
私が我愛羅様の
おそばにいますからね

74
00:09:43,959 --> 00:09:45,419
ずーっと

75
00:10:10,444 --> 00:10:11,194
おっ

76
00:10:11,403 --> 00:10:12,362
えへっ

77
00:10:15,449 --> 00:10:19,119
ハアハア
ハアハア

78
00:10:19,244 --> 00:10:20,162
おおっ

79
00:10:21,496 --> 00:10:22,205
えっ

80
00:11:03,205 --> 00:11:06,124
ああお弁当？

81
00:11:06,124 --> 00:11:06,917
ええ

82
00:11:08,960 --> 00:11:10,462
ふふ

83
00:11:37,572 --> 00:11:40,826
えー体術というものは

84
00:11:40,909 --> 00:11:44,413
いわゆる忍が
生きていく上での1つの

85
00:11:44,538 --> 00:11:46,039
そうだな

86
00:11:46,248 --> 00:11:51,128
例えば人が生きるということは
どんなことかというと

87
00:11:51,336 --> 00:11:53,880
それは魚が川を上るという…

88
00:11:53,880 --> 00:11:55,924
あーめんどくせ！

89
00:11:55,924 --> 00:11:58,427
自然の摂理と言っても過言ではなく

90
00:11:58,552 --> 00:12:01,888
私達が常に
考えなくてはならないのは…

91
00:12:18,947 --> 00:12:21,616
あっああ…

92
00:12:22,367 --> 00:12:24,870
ああっ
なに？なにー？

93
00:12:25,370 --> 00:12:26,788
んー

94
00:12:26,913 --> 00:12:27,789
あっ

95
00:12:29,166 --> 00:12:31,501
えっへへへへ

96
00:12:31,626 --> 00:12:32,252
あいたっ！

97
00:12:32,419 --> 00:12:34,754
何寝ぼけてるんだ！

98
00:12:36,214 --> 00:12:37,215
てへっ

99
00:12:37,340 --> 00:12:38,341
んー？

100
00:12:38,592 --> 00:12:43,096
あーっシカマルでしょ！
もーう

101
00:12:43,096 --> 00:12:46,683
シーカーマールー！

102
00:12:46,683 --> 00:12:47,434
ふん

103
00:12:48,935 --> 00:12:49,853
あっ

104
00:12:49,853 --> 00:12:50,687
ハッ

105
00:12:50,687 --> 00:12:51,646
んぐっ

106
00:12:52,230 --> 00:12:53,106
ホイッ

107
00:12:53,440 --> 00:12:53,982
この！

108
00:12:53,982 --> 00:12:54,900
ギャー

109
00:12:57,277 --> 00:13:02,157
んーもうお前たちってば
うるせんだってばよ

110
00:13:02,157 --> 00:13:04,242
寝てらんねーじゃんかよ

111
00:13:05,785 --> 00:13:10,165
おいナルト
今はな授業中なんだ

112
00:13:10,332 --> 00:13:12,334
寝る時間じゃ…

113
00:13:12,334 --> 00:13:14,336
へっへへー

114
00:13:14,377 --> 00:13:16,213
ないだろうが！

115
00:13:16,963 --> 00:13:19,341
ナルトシカマル
チョウジ

116
00:13:19,341 --> 00:13:21,760
3人とも廊下で立ってろ

117
00:13:21,760 --> 00:13:22,844
えー！

118
00:13:22,844 --> 00:13:24,471
えーじゃない！

119
00:13:24,471 --> 00:13:26,264
はーい

120
00:13:29,476 --> 00:13:33,772
あーあまたイルカ先生を
怒らしちゃった

121
00:13:35,106 --> 00:13:39,945
えっとお
お菓子あるけど食べる？

122
00:13:40,153 --> 00:13:41,863
おおー！

123
00:13:42,489 --> 00:13:44,407
しーっ

124
00:13:44,616 --> 00:13:45,450
へっ

125
00:13:45,700 --> 00:13:48,036
ふふうん！

126
00:13:49,412 --> 00:13:51,248
食べるってばよ

127
00:13:54,709 --> 00:13:58,463
どうだお前たち
少しは反省している…

128
00:14:06,513 --> 00:14:09,099
ホントお前たちは…

129
00:14:20,902 --> 00:14:22,320
うわー！

130
00:14:23,863 --> 00:14:24,864
ハッハハハ

131
00:14:24,864 --> 00:14:28,910
イルカ先生ってば
びっくりしたってばよ

132
00:14:29,160 --> 00:14:30,245
ぶっ殺す…

133
00:14:30,245 --> 00:14:32,414
えっ　なに？
なにー？

134
00:14:45,385 --> 00:14:48,013
あーやっぱここだ

135
00:14:48,847 --> 00:14:52,559
ねえねえシカマル
お金貸して

136
00:14:52,642 --> 00:14:56,062
んーなんだよ
お前またお菓子か

137
00:14:56,229 --> 00:14:57,814
そうそう

138
00:14:57,856 --> 00:15:01,985
だってお菓子以外に
何か買うものなんてある？

139
00:15:01,985 --> 00:15:04,779
もうめんどくせえな

140
00:15:04,779 --> 00:15:05,363
んー？

141
00:15:05,363 --> 00:15:08,241
そんなやつお前だけだよ

142
00:15:09,909 --> 00:15:10,702
へっ

143
00:15:20,128 --> 00:15:21,504
なんだその目

144
00:15:21,504 --> 00:15:22,797
気持ちわりい

145
00:15:22,797 --> 00:15:24,215
こっち見んな！

146
00:15:24,215 --> 00:15:26,051
変なんだよお前

147
00:15:26,051 --> 00:15:31,139
なーなななもうやめろってばよ
こいつがお前らに何かしたのか？

148
00:15:31,139 --> 00:15:31,723
はあ？

149
00:15:31,723 --> 00:15:34,559
何だよヒーロー気取りかよ

150
00:15:36,144 --> 00:15:38,813
弱い者いじめはするなってばよ

151
00:15:39,064 --> 00:15:41,399
ん？うっぜー

152
00:15:45,695 --> 00:15:48,865
はっしらけちまった
おいみんな行こうぜ

153
00:15:48,865 --> 00:15:52,827
あーあつまんねーの
行こう行こうハハハ

154
00:15:53,703 --> 00:15:57,832
なんだよあいつったら
めんどくせえことして

155
00:15:58,083 --> 00:16:02,879
他人の世話焼いてる暇があったら
自分の術でも磨けっつうの

156
00:16:03,296 --> 00:16:04,506
馬鹿ナルト

157
00:16:06,883 --> 00:16:08,176
馬鹿って言うな

158
00:16:08,176 --> 00:16:10,011
えなんだ？

159
00:16:11,096 --> 00:16:13,223
ナルトは馬鹿じゃない

160
00:16:13,723 --> 00:16:19,270
だってシカマルだって
将棋の駒は数が揃わなきゃって

161
00:16:19,562 --> 00:16:20,939
僕のこと…

162
00:16:21,064 --> 00:16:24,484
はあ？おめえ何言ってんだ

163
00:16:25,276 --> 00:16:28,863
さっきお金貸さなかったから
怒ってんだろ

164
00:16:32,117 --> 00:16:33,201
違う

165
00:16:34,119 --> 00:16:35,453
ナルトは

166
00:16:35,829 --> 00:16:39,541
ナルトはシカマルなんだ
馬鹿って言うな

167
00:16:39,708 --> 00:16:40,917
取り消せ

168
00:16:41,418 --> 00:16:42,252
チェッ

169
00:16:42,585 --> 00:16:47,382
めんどくせえいいから
ちゃんとわかるように話せよ

170
00:16:49,551 --> 00:16:53,263
ぼ僕に命令すんな

171
00:16:54,389 --> 00:16:56,224
おっおい
おい！

172
00:16:56,224 --> 00:16:58,518
お前ら何してんだってばよ
あっあっ

173
00:16:58,518 --> 00:17:02,230
お前ら仲良しじゃん
なんで喧嘩してんだってばよ

174
00:17:02,230 --> 00:17:03,440
おいって

175
00:17:03,565 --> 00:17:04,524
この…

176
00:17:05,775 --> 00:17:08,695
このデブが文句言ってくるからよ

177
00:17:09,154 --> 00:17:11,614
シカマルの目は節穴だ

178
00:17:12,449 --> 00:17:14,534
僕はデブじゃない

179
00:17:17,162 --> 00:17:19,080
ぽっちゃり系だ

180
00:17:20,832 --> 00:17:22,167
この喧嘩

181
00:17:23,168 --> 00:17:24,919
俺が買うってばよ

182
00:17:25,462 --> 00:17:26,504
え？

183
00:17:26,504 --> 00:17:27,297
ヘッ

184
00:17:27,797 --> 00:17:29,257
何それ？

185
00:17:30,216 --> 00:17:34,304
あっじゃあ
そのお金でお菓子を買う

186
00:17:34,304 --> 00:17:35,805
えええ…

187
00:17:36,514 --> 00:17:37,932
何それ？

188
00:17:42,520 --> 00:17:45,190
アッハハハハ

189
00:17:46,107 --> 00:17:49,611
ハハハハハ
何だよそれヒヒヒ

190
00:17:49,611 --> 00:17:52,697
ハハハハハ
おもしれえ

191
00:17:52,697 --> 00:17:56,242
アハハハハ
ムハハハハ

192
00:18:04,459 --> 00:18:06,461
バッとさあやっちゃってさあ

193
00:18:06,586 --> 00:18:09,464
そんでいつものとこに
行ったってばよ

194
00:18:09,464 --> 00:18:10,882
はーあ

195
00:18:10,882 --> 00:18:12,008
そうか

196
00:18:13,426 --> 00:18:15,929
ナルトお菓子食べる？

197
00:18:15,929 --> 00:18:18,139
おっサンキュー

198
00:18:19,390 --> 00:18:20,350
へっ

199
00:18:23,269 --> 00:18:24,062
あ？

200
00:18:24,604 --> 00:18:26,064
おいあれ！

201
00:18:26,481 --> 00:18:27,440
ん？

202
00:18:50,839 --> 00:18:53,758
わーマジかよ
めんどくせえ

203
00:18:53,758 --> 00:18:56,886
やだやだ女やだー

204
00:18:56,886 --> 00:18:57,929
うおーちょっちょ

205
00:18:57,929 --> 00:18:59,514
ややべえ

206
00:19:01,224 --> 00:19:02,350
こっちだ！

207
00:19:02,350 --> 00:19:04,686
わっ来たー
来た！

208
00:19:11,150 --> 00:19:13,987
駄目行こう
逃げろこっち

209
00:19:13,987 --> 00:19:17,407
もう無理ひーいいい

210
00:19:18,533 --> 00:19:21,411
ひいいい
ハアハア

211
00:19:21,411 --> 00:19:24,664
んああ
ハアハア

212
00:19:24,664 --> 00:19:25,999
いののやつ

213
00:19:26,666 --> 00:19:30,169
怒るとすげえな
ハアハア

214
00:19:30,169 --> 00:19:33,256
ありゃ絶対売れ残るよ

215
00:19:36,092 --> 00:19:37,468
ほらあそこあそこ！

216
00:19:37,468 --> 00:19:38,011
え？

217
00:19:38,011 --> 00:19:41,848
スケベーなイルカ先生
発見だってばよ

218
00:19:43,182 --> 00:19:44,559
おいナルト

219
00:19:47,061 --> 00:19:48,438
あれやるか？

220
00:19:48,438 --> 00:19:49,439
マジ？

221
00:19:49,439 --> 00:19:49,939
おお！

222
00:19:49,939 --> 00:19:51,816
ムッフフーうん！

223
00:19:52,442 --> 00:19:53,985
ねえいいでしょう？

224
00:19:53,985 --> 00:19:58,406
ええいやあ
まいったなあ

225
00:19:58,406 --> 00:20:00,408
あっおお

226
00:20:01,034 --> 00:20:05,079
なんだナルトか
こんな時間に出歩いて

227
00:20:05,330 --> 00:20:06,539
子供は寝てる時間…

228
00:20:06,539 --> 00:20:08,082
お色気の術！

229
00:20:16,507 --> 00:20:19,969
ぐあああーっ

230
00:20:20,970 --> 00:20:22,931
くっくっく

231
00:20:27,769 --> 00:20:29,729
キャーッ

232
00:20:35,652 --> 00:20:37,236
じゃあなナルト

233
00:20:37,320 --> 00:20:39,530
お色気の術すごかったぜ

234
00:20:39,530 --> 00:20:41,240
バイバイナルト

235
00:20:42,951 --> 00:20:47,080
ねえねえシカマル
僕んち今夜はカレー曜日

236
00:20:47,080 --> 00:20:50,875
いいなあ俺
母ちゃんの作る飯もう飽きた

237
00:20:51,042 --> 00:20:52,543
ハハハハハ

238
00:20:54,462 --> 00:20:55,838
また明日！

239
00:20:55,838 --> 00:20:56,965
んおー！

240
00:20:56,965 --> 00:20:58,549
明日ねー

241
00:22:38,316 --> 00:22:42,737
なあ今宵はワシらの夢でも
語り合わんかのう

242
00:22:42,820 --> 00:22:43,905
夢？

243
00:22:43,905 --> 00:22:48,159
まあ夢があればの話だがのう

244
00:22:48,910 --> 00:22:50,995
すごいよねカカシくん

245
00:22:50,995 --> 00:22:55,166
そっかあ？あいつさ
きっとむっつりスケベだぜ

