1
00:00:07,508 --> 00:00:09,135
あっ…

2
00:00:19,770 --> 00:00:20,479
チッ

3
00:00:23,816 --> 00:00:25,067
うわっ！

4
00:00:25,234 --> 00:00:27,027
うおーっ！

5
00:00:27,153 --> 00:00:28,279
とうっ！

6
00:00:30,489 --> 00:00:31,240
ふんっ！

7
00:00:31,615 --> 00:00:33,659
なんて凶悪な風ぼう

8
00:00:33,743 --> 00:00:35,828
極悪人だろ 貴様！

9
00:00:35,828 --> 00:00:37,872
そいつは九尾化したナルトだ

10
00:00:37,872 --> 00:00:38,664
えっ？

11
00:00:38,956 --> 00:00:41,876
もっとも 影分身とも違うようだが…

12
00:00:43,669 --> 00:00:45,921
ものすごい九尾のチャクラだ

13
00:00:46,213 --> 00:00:48,758
本物と変わらないクローンさ

14
00:00:48,758 --> 00:00:53,554
ついでに九尾のチャクラまで
一緒に複製したみたいだけどね

15
00:00:53,763 --> 00:00:54,472
んっ！

16
00:00:54,805 --> 00:00:56,015
うらーっ！

17
00:01:00,770 --> 00:01:01,479
フンッ

18
00:01:09,195 --> 00:01:10,029
チッ

19
00:01:10,029 --> 00:01:11,655
ナ… ナルト君！

20
00:01:11,989 --> 00:01:13,908
飛段を生んだ まやかしか

21
00:01:14,200 --> 00:01:15,826
いつナルトに仕込んだ？

22
00:01:16,202 --> 00:01:18,078
ほんの偶然さ

23
00:01:18,537 --> 00:01:21,791
まあ 結果は僕も想定外だったけど…

24
00:01:23,209 --> 00:01:24,376
逃がさんぞ

25
00:01:24,752 --> 00:01:25,503
フッ

26
00:01:27,213 --> 00:01:28,088
んんっ！

27
00:01:37,431 --> 00:01:39,141
楽しいことに

28
00:01:39,683 --> 00:01:41,101
なりそうだ

29
00:01:41,519 --> 00:01:42,603
あっ！

30
00:01:42,937 --> 00:01:44,104
ぬわーっ！

31
00:01:45,940 --> 00:01:46,607
うおっ！

32
00:01:46,607 --> 00:01:47,399
とうっ！

33
00:01:48,067 --> 00:01:49,276
うっ うう…

34
00:01:50,528 --> 00:01:52,279
うおーっ！

35
00:01:54,782 --> 00:01:55,783
ふんっ！

36
00:01:56,075 --> 00:01:56,992
えいっ！

37
00:01:57,326 --> 00:01:58,035
うおっ！

38
00:01:59,245 --> 00:01:59,954
ふんっ！

39
00:02:02,289 --> 00:02:02,832
はっ！

40
00:02:05,459 --> 00:02:06,669
えーいっ！

41
00:02:10,381 --> 00:02:11,257
ぐはっ！

42
00:02:15,302 --> 00:02:17,930
これが忍の戦い…

43
00:02:17,930 --> 00:02:19,515
すっげー！

44
00:02:19,515 --> 00:02:20,808
うわっ！

45
00:02:21,851 --> 00:02:22,309
くっ…

46
00:02:22,309 --> 00:02:23,602
ううっ…

47
00:02:29,024 --> 00:02:30,526
リー！ やるぞ！

48
00:02:30,526 --> 00:02:31,610
はい！

49
00:02:34,613 --> 00:02:36,407
うおーっ！

50
00:02:36,407 --> 00:02:39,451
おおーっ！

51
00:02:46,333 --> 00:02:49,169
はあーっ！

52
00:02:49,169 --> 00:02:50,588
うおーっ！

53
00:02:50,588 --> 00:02:52,298
とりゃーっ！

54
00:02:59,221 --> 00:03:00,014
とうっ！

55
00:03:00,723 --> 00:03:02,391
キャーッ！

56
00:03:07,938 --> 00:03:08,731
もっと…

57
00:03:08,731 --> 00:03:09,690
あっ！

58
00:03:11,275 --> 00:03:13,485
もっと…

59
00:03:14,403 --> 00:03:16,655
力を！

60
00:03:18,365 --> 00:03:19,074
ハッ！

61
00:03:25,873 --> 00:03:26,624
キャーッ！

62
00:03:26,624 --> 00:03:27,249
あっ！

63
00:03:27,374 --> 00:03:28,667
ヒナタ様！

64
00:03:31,170 --> 00:03:32,004
ぐはっ！

65
00:03:32,004 --> 00:03:34,798
力！

66
00:03:34,798 --> 00:03:38,510
面白い 面白いぞ

67
00:03:38,510 --> 00:03:43,140
喜んでチャクラをくれてやる

68
00:03:50,105 --> 00:03:50,773
ハッ！

69
00:03:52,566 --> 00:03:53,275
ん？

70
00:03:58,906 --> 00:04:01,408
わあー！ うわっ！

71
00:04:05,496 --> 00:04:06,538
あ…

72
00:04:06,538 --> 00:04:07,498
何だ？

73
00:04:08,082 --> 00:04:09,541
おわーっ！

74
00:04:11,085 --> 00:04:12,544
人が降ってきた

75
00:04:12,544 --> 00:04:13,420
何だ？

76
00:04:14,755 --> 00:04:16,715
(クローンナルトの雄たけび)

77
00:04:16,715 --> 00:04:17,591
あっ…

78
00:04:34,066 --> 00:04:34,942
あれは！

79
00:04:39,905 --> 00:04:40,489
ハッ！

80
00:04:40,489 --> 00:04:40,948
んっ？

81
00:04:40,948 --> 00:04:41,824
ああ？

82
00:04:46,745 --> 00:04:47,496
うっ…

83
00:04:48,247 --> 00:04:49,331
何だ？

84
00:04:54,878 --> 00:04:56,714
うわーっ！

85
00:04:57,256 --> 00:04:58,173
あっ！

86
00:05:00,926 --> 00:05:02,386
キャーッ！

87
00:05:05,639 --> 00:05:06,974
カカシ！

88
00:05:07,099 --> 00:05:10,227
よし！ 俺たちも住人を助けるぞ！

89
00:05:14,314 --> 00:05:16,442
うわーっ！

90
00:05:28,162 --> 00:05:30,539
わあーっ！

91
00:05:34,043 --> 00:05:34,877
あっ！

92
00:05:38,839 --> 00:05:39,757
あ…

93
00:05:39,923 --> 00:05:40,799
ああ…

94
00:05:45,054 --> 00:05:45,804
うん

95
00:05:45,929 --> 00:05:46,972
シセル！

96
00:05:47,639 --> 00:05:48,849
子供たちを！

97
00:05:49,058 --> 00:05:50,225
お兄ちゃん！

98
00:05:52,519 --> 00:05:53,062
さあ…

99
00:05:53,062 --> 00:05:53,687
あっ…

100
00:05:59,777 --> 00:06:00,944
シセルさん！

101
00:06:03,947 --> 00:06:05,574
ナルト君 ナルト君

102
00:06:05,574 --> 00:06:06,825
ナルト君！

103
00:06:09,953 --> 00:06:10,788
ん？

104
00:06:24,676 --> 00:06:25,260
あっ！

105
00:06:25,260 --> 00:06:26,470
あっ ああっ…

106
00:06:26,470 --> 00:06:27,846
先生！

107
00:06:30,849 --> 00:06:31,975
あっ…

108
00:06:37,231 --> 00:06:37,940
ふんっ！

109
00:06:39,483 --> 00:06:40,150
あ…

110
00:08:17,497 --> 00:08:19,208
すばらしい…

111
00:08:19,917 --> 00:08:23,003
すばらしいぞ ナルト

112
00:08:26,798 --> 00:08:28,800
滅ぼせ

113
00:08:31,970 --> 00:08:34,056
滅ぼせ

114
00:08:36,391 --> 00:08:38,602
世界を！

115
00:08:38,644 --> 00:08:39,436
ハッ！

116
00:08:42,397 --> 00:08:44,233
はっ！ えいっ！

117
00:08:44,233 --> 00:08:44,983
ハッ！

118
00:08:53,450 --> 00:08:54,326
どいてくれ！

119
00:08:54,326 --> 00:08:55,369
すみません！

120
00:08:56,203 --> 00:09:00,123
はい 気づいたときには町長はどこにも…

121
00:09:00,624 --> 00:09:03,043
ご無事でいらっしゃるとよいのですが…

122
00:09:03,043 --> 00:09:03,961
そうですね

123
00:09:03,961 --> 00:09:04,920
(ノックの音)

124
00:09:05,587 --> 00:09:06,380
あ…

125
00:09:06,463 --> 00:09:07,631
すみません

126
00:09:12,970 --> 00:09:14,930
皆さん 朗報です

127
00:09:15,472 --> 00:09:18,767
幸いにも死者は出なかったようです

128
00:09:20,185 --> 00:09:21,520
よかった

129
00:09:21,520 --> 00:09:24,147
でもナルトとドックさんは？

130
00:09:24,481 --> 00:09:25,357
うっ！

131
00:09:26,566 --> 00:09:27,150
ふんっ！

132
00:09:27,150 --> 00:09:28,068
おっちゃん…

133
00:09:28,068 --> 00:09:28,986
あ…

134
00:09:29,278 --> 00:09:30,529
ナルト君！

135
00:09:31,863 --> 00:09:36,994
踏み潰される瞬間に大蛇のようなものを見たと
シセルさんが言っていた

136
00:09:37,160 --> 00:09:39,913
死体もないし おそらく…

137
00:09:39,913 --> 00:09:41,832
カブトの手中に…

138
00:09:41,873 --> 00:09:47,754
戦闘中に急に暁連中を収監したのも
本来の目的を達成したからですね

139
00:09:49,172 --> 00:09:50,299
ここは？

140
00:09:50,632 --> 00:09:51,883
分かんない

141
00:09:51,883 --> 00:09:53,969
気づいたら もう居たんだ

142
00:09:55,429 --> 00:09:56,263
んっ…

143
00:09:56,263 --> 00:09:57,556
あ… 待ってて

144
00:09:59,141 --> 00:10:00,309
うわーっ！

145
00:10:00,309 --> 00:10:02,060
あっ！ あっ ああ…

146
00:10:02,185 --> 00:10:02,853
あ…

147
00:10:06,064 --> 00:10:09,318
それと あのクローンとかいう九尾…

148
00:10:09,776 --> 00:10:12,487
なぜか急速に力を失っていった

149
00:10:14,114 --> 00:10:16,742
カブトも制御に手こずっていたようだし

150
00:10:16,950 --> 00:10:19,077
おそらく不完全な状態なんだろう

151
00:10:20,454 --> 00:10:23,582
そもそも奴の目的は何なんだ？

152
00:10:23,707 --> 00:10:29,504
穢土転生した忍たちのレベルからして
マジで戦ってるようには見えねえしな

153
00:10:29,504 --> 00:10:30,464
ああ

154
00:10:31,548 --> 00:10:34,551
本当 無事でよかったわ！

155
00:10:34,551 --> 00:10:35,969
ありがとう

156
00:10:36,470 --> 00:10:37,763
それじゃあ…

157
00:10:38,180 --> 00:10:39,264
はい

158
00:10:39,389 --> 00:10:40,557
シセルさん

159
00:10:42,351 --> 00:10:45,312
そうね 信じるしかないわね

160
00:10:45,604 --> 00:10:47,898
2人が無事でいてくれることを…

161
00:10:50,025 --> 00:10:51,318
お兄ちゃん…

162
00:10:53,987 --> 00:10:55,238
子供たちは？

163
00:10:55,989 --> 00:11:01,578
みんなが血やケガをした人を怖がるんで
いったん うちに連れて帰ったの

164
00:11:08,794 --> 00:11:11,963
うっ うう… うっ うっ…

165
00:11:11,963 --> 00:11:13,632
うわーん！

166
00:11:13,632 --> 00:11:18,220
うわーん うう…

167
00:11:34,820 --> 00:11:37,155
フフフフフフフッ

168
00:11:37,489 --> 00:11:39,282
フフフフフッ

169
00:11:40,283 --> 00:11:42,369
もう認めろ

170
00:11:43,412 --> 00:11:47,082
あれはお前の本性だ

171
00:11:48,125 --> 00:11:52,379
わしとお前は一心同体

172
00:11:55,132 --> 00:11:56,633
さあ

173
00:11:57,300 --> 00:11:59,761
その身を委ねろ

174
00:12:02,597 --> 00:12:04,349
わしを

175
00:12:05,100 --> 00:12:08,103
解放しろ！

176
00:12:11,106 --> 00:12:12,149
ナルト

177
00:12:12,399 --> 00:12:13,150
ハッ！

178
00:12:13,150 --> 00:12:15,944
ナルト君 ナルト君！ あっ…

179
00:12:16,570 --> 00:12:17,696
大丈夫？

180
00:12:17,779 --> 00:12:18,780
構うな！

181
00:12:18,780 --> 00:12:19,823
わっ！

182
00:12:23,743 --> 00:12:26,538
あ… ああ…

183
00:12:31,084 --> 00:12:32,502
すまねえ

184
00:12:35,714 --> 00:12:38,467
出てけ！ 出てけ！ 出てけ！

185
00:12:38,467 --> 00:12:40,385
ミィナちゃん ミィナちゃん！

186
00:12:40,844 --> 00:12:42,429
出てけー！

187
00:12:42,429 --> 00:12:43,305
ミィナ！

188
00:12:43,889 --> 00:12:44,890
ハア…

189
00:13:06,828 --> 00:13:09,414
ハア やっちゃった

190
00:13:10,165 --> 00:13:14,961
本当の母親でもないのに
マジでひっぱたいちゃった

191
00:13:15,212 --> 00:13:20,634
それは君があの子たちと
本気で接しているからだと思う

192
00:13:22,802 --> 00:13:25,388
でも僕はミィナが…

193
00:13:26,139 --> 00:13:28,642
村でのあの子をよく知ってるから

194
00:13:28,850 --> 00:13:31,478
あんなことを言ったりする子じゃないって…

195
00:13:32,312 --> 00:13:35,232
きっと何か別の理由が…

196
00:13:40,570 --> 00:13:44,157
やっぱり施設に預けるべきだよね

197
00:13:45,700 --> 00:13:47,577
あの子たちのためにも…

198
00:13:54,584 --> 00:13:59,381
僕も ずっと君には甘えてはいられない

199
00:14:07,347 --> 00:14:08,598
私…

200
00:14:09,140 --> 00:14:10,350
私ね

201
00:14:10,684 --> 00:14:15,105
あの子たち引き取って
一緒に住めればいいなって思ってたの

202
00:14:15,105 --> 00:14:16,314
わあっ！

203
00:14:16,523 --> 00:14:18,525
みんなとワイワイやって

204
00:14:18,650 --> 00:14:24,072
笑ったり 一緒に泣いたり
時々ケンカしたりしてね

205
00:14:24,739 --> 00:14:25,740
でね…

206
00:14:26,074 --> 00:14:29,119
いつも誰かさんが そばにいて…

207
00:14:36,376 --> 00:14:37,419
あ…

208
00:14:39,588 --> 00:14:40,922
ダメかな？

209
00:14:41,339 --> 00:14:42,007
ん…

210
00:14:58,690 --> 00:14:59,649
ああっ…

211
00:15:05,030 --> 00:15:07,324
お兄ちゃんのままでもいいから…

212
00:15:08,658 --> 00:15:09,618
ダメ？

213
00:15:12,954 --> 00:15:15,582
もしかして まだ気にしてる？

214
00:15:16,458 --> 00:15:19,544
あれは お兄ちゃんのせいなんかじゃないのに！

215
00:15:20,712 --> 00:15:23,256
もう全然 平気だから！

216
00:15:23,465 --> 00:15:24,132
あ…

217
00:15:34,643 --> 00:15:36,603
そんなこと言うなよ

218
00:15:37,520 --> 00:15:39,439
産めなくなったんだぞ

219
00:15:45,528 --> 00:15:46,863
ごめんなさい

220
00:15:48,990 --> 00:15:50,241
どうか…

221
00:15:50,992 --> 00:15:52,661
どうか みんな無事で…

222
00:15:52,661 --> 00:15:54,621
すまねえ おっちゃん

223
00:15:54,954 --> 00:15:55,914
あ…

224
00:15:57,248 --> 00:15:58,667
俺のせいだ

225
00:15:59,959 --> 00:16:02,128
あいつも俺だ

226
00:16:03,088 --> 00:16:07,509
俺の中に潜んでる もう一つの本性なんだ

227
00:16:09,260 --> 00:16:11,930
おばさんやあの子たちに何かあったら

228
00:16:14,265 --> 00:16:15,266
俺…

229
00:16:16,059 --> 00:16:19,354
違うよ！ 君は利用されただけじゃないか！

230
00:16:19,479 --> 00:16:22,148
あれは君なんかじゃない あんな姿や…

231
00:16:22,148 --> 00:16:23,608
俺は俺だ！

232
00:16:23,608 --> 00:16:24,150
あっ…

233
00:16:25,151 --> 00:16:29,280
殺す！ 壊す！ 何もかも！

234
00:16:29,322 --> 00:16:31,908
わしがすべてを！

235
00:16:36,454 --> 00:16:37,914
ハアッ…！

236
00:16:43,461 --> 00:16:44,087
サクラ

237
00:16:44,087 --> 00:16:44,796
あ…

238
00:16:44,921 --> 00:16:47,716
準備をしろ もうすぐ出立する

239
00:16:47,716 --> 00:16:48,550
はい

240
00:16:48,925 --> 00:16:50,260
でも どこへ？

241
00:16:50,260 --> 00:16:51,428
ホールだ

242
00:16:51,553 --> 00:16:53,388
おそらくカブトはそこにいる

243
00:16:53,680 --> 00:16:54,806
私も！

244
00:16:55,724 --> 00:16:58,393
私も ぜひ同行させてください！

245
00:16:58,852 --> 00:17:03,314
忍の皆さんからすると
足手まといになるかもしれませんが…

246
00:17:05,650 --> 00:17:07,485
そんなことありませんよ

247
00:17:07,527 --> 00:17:10,280
大切な人を思う気持ちはよく分かります

248
00:17:10,530 --> 00:17:11,781
一緒に行きましょう

249
00:17:14,200 --> 00:17:15,326
んっ…

250
00:17:15,869 --> 00:17:17,704
んっ んんっ…

251
00:17:17,996 --> 00:17:21,124
ぐうっ ぐっ…！

252
00:17:24,002 --> 00:17:28,840
確かに君のような とてもすごい力を持つ人は

253
00:17:29,007 --> 00:17:33,678
その力を正しく使えても 悪いことに使っても

254
00:17:34,429 --> 00:17:38,767
その結果には 大きな責任を
負わないといけないと思う

255
00:17:40,018 --> 00:17:40,977
でも…

256
00:17:42,771 --> 00:17:44,314
君が力を…

257
00:17:47,817 --> 00:17:51,070
強くなりたいと思ったのは どうして？

258
00:17:56,367 --> 00:17:57,619
仲間を…

259
00:17:59,078 --> 00:18:00,872
大切な人たちを…

260
00:18:01,998 --> 00:18:03,208
守りたい

261
00:18:12,175 --> 00:18:13,301
友達を

262
00:18:14,761 --> 00:18:15,970
助けたい

263
00:18:21,518 --> 00:18:24,938
その強い思いが君を…

264
00:18:25,563 --> 00:18:27,065
君の力を…

265
00:18:27,899 --> 00:18:30,068
きっと導いてくれる

266
00:18:35,198 --> 00:18:36,366
迷うな

267
00:18:41,037 --> 00:18:42,038
お前を

268
00:18:44,332 --> 00:18:45,542
信じてる

269
00:18:59,722 --> 00:19:01,057
拾っておいたよ

270
00:19:03,268 --> 00:19:04,310
君を…

271
00:19:05,645 --> 00:19:07,814
君の正しい力を…

272
00:19:08,982 --> 00:19:10,108
信じてる

273
00:19:19,450 --> 00:19:21,661
先生 助けに行こう

274
00:19:21,870 --> 00:19:23,413
え…？

275
00:19:23,621 --> 00:19:24,873
あ…

276
00:19:26,291 --> 00:19:28,418
むちゃだよ 殺されるよ！

277
00:19:28,418 --> 00:19:29,711
危ないわ！

278
00:19:29,711 --> 00:19:33,089
それにシセルさんが ここで待ってろって！

279
00:19:36,384 --> 00:19:39,220
僕ら 先生がいなかったら

280
00:19:39,679 --> 00:19:40,930
死んでた

281
00:19:41,014 --> 00:19:41,723
あ…

282
00:19:41,848 --> 00:19:42,932
あっ…

283
00:19:43,975 --> 00:19:45,018
それに…

284
00:19:47,103 --> 00:19:50,356
あいつらの欲しがってる物を持ってる

285
00:19:50,356 --> 00:19:51,441
あ…

286
00:19:53,776 --> 00:19:57,196
そいつと先生を交換してもらう！

287
00:20:03,745 --> 00:20:04,621
うん

288
00:20:05,246 --> 00:20:05,955
うん

289
00:20:07,081 --> 00:20:10,627
今度は僕らが先生を助ける番だ！

290
00:20:18,426 --> 00:20:19,218
うん

291
00:20:19,636 --> 00:20:20,553
うん

292
00:20:20,970 --> 00:20:21,930
うん

293
00:20:23,222 --> 00:20:24,390
行こう！

294
00:20:24,390 --> 00:20:25,642
うん

295
00:20:26,392 --> 00:20:28,394
でも どこへ？

296
00:20:28,937 --> 00:20:31,064
行く場所なんて決まってる

297
00:20:31,814 --> 00:20:34,192
僕たちの村

298
00:20:40,156 --> 00:20:41,115
あ…

299
00:20:48,247 --> 00:20:49,082
あっ

300
00:20:49,832 --> 00:20:50,959
町長！

301
00:20:56,589 --> 00:20:58,800
もう茶番はやめだ！

302
00:20:59,175 --> 00:21:01,052
町役場のバカが

303
00:21:01,386 --> 00:21:06,224
国に報告などしなければ
とっくにけりが付いていたものを…

304
00:21:07,266 --> 00:21:08,601
お前

305
00:21:09,018 --> 00:21:12,981
お前は持っている音の価値を分かってんのか？

306
00:21:15,108 --> 00:21:15,775
ん？

307
00:21:18,194 --> 00:21:19,237
うわっ！

308
00:21:22,865 --> 00:21:24,158
あ…

309
00:21:26,744 --> 00:21:28,913
フフッ フフフフフッ

310
00:23:13,768 --> 00:23:15,728
そいつは俺がやる！

311
00:23:17,647 --> 00:23:20,566
ああ すげえ すげえ！ すげえぞ！

312
00:23:20,566 --> 00:23:21,901
驚いたな

313
00:23:21,984 --> 00:23:24,529
これが天の矛？

314
00:23:24,529 --> 00:23:29,617
俺は今まで いろんな大切なことを
いろんな人に教わってきた

315
00:23:29,617 --> 00:23:35,248
こんなとこで諦めてたまるかー！

316
00:23:40,211 --> 00:23:42,004
俺の力は…！

