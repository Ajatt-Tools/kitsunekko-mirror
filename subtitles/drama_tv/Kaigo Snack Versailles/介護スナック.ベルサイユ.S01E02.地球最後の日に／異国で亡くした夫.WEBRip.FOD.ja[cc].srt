425
00:25:42,543 --> 00:25:44,545
((右…))

426
00:25:44,545 --> 00:26:00,561
♬～

427
00:26:00,561 --> 00:26:02,896
(男性)((降りて))

428
00:26:02,896 --> 00:26:04,898
♬～

429
00:26:04,898 --> 00:26:06,900
(男性)
((あっ 君は ここで待ってて))

430
00:26:06,900 --> 00:26:10,237
(男性)((ﾗｲﾄ消して
ｴﾝｼﾞﾝ かけたままね))

431
00:26:10,237 --> 00:26:12,239
((はい…))

432
00:26:12,239 --> 00:26:32,259
♬～

433
00:26:32,259 --> 00:26:52,279
♬～

434
00:26:52,279 --> 00:27:00,954
